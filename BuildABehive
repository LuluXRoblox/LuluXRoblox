local function TrackWebhookBuy(boughtList)
    if not BuyWebhookEnabled then return end
    if WebhookURL == "" then return end
    for _, entry in ipairs(boughtList) do
        table.insert(WebhookBoughtQueue, entry)
    end
    if #WebhookBoughtQueue == 0 then return end
    WebhookLastBuyTime = tick()
    if WebhookFlushThread then
        task.cancel(WebhookFlushThread)
        WebhookFlushThread = nil
    end
    WebhookFlushThread = task.delay(5, function()
        WebhookFlushThread = nil
        FlushWebhookQueue()
    end)
end

