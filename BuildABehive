local function AutoPlantGrid(itemName, plotNumber, mode, isFlower, flowerIds)
    local corners = GetPlotCorners(plotNumber)
    if not corners.p1 then Log("Plot " .. plotNumber .. " tidak ditemukan") return 0 end

    local A, B, C, D = SortCornersForGrid(corners.p1, corners.p2, corners.p3, corners.p4)
    local positions  = ComputeGridPositions(A, B, C, D)

    local filtered = {}
    for _, pos in ipairs(positions) do
        local pass = true
        if PlotLineFilterType == "Blue" then
            pass = (PlotLineFilterNum == "All") or (pos.blue_line == PlotLineFilterNum)
        elseif PlotLineFilterType == "Red" then
            pass = (PlotLineFilterNum == "All") or (pos.red_line == PlotLineFilterNum)
        end
        if pass then table.insert(filtered, pos) end
    end

    local planted   = 0
    local flowerIdx = 1

    for _, pos in ipairs(filtered) do
        if isFlower then
            if not AutoFlowerEnabled then break end
        else
            if not AutoSeedEnabled then break end
        end
        if isFlower then
            if not flowerIds or flowerIdx > #flowerIds then break end
            local ok = PlantFlowerAt(flowerIds[flowerIdx], pos.x, pos.y, pos.z, mode)
            if ok then
                flowerIdx = flowerIdx + 1
                planted   = planted + 1
            end
        else
            if GetSeedCount(itemName) <= 0 then Log("Seed " .. itemName .. " habis") break end
            if PlantSeedAt(itemName, pos.x, pos.y, pos.z, mode, plotNumber) then
                planted = planted + 1
            end
        end
    end
    return planted
end

-- Bangun daftar seed yang mau ditanam.
-- Cek keberadaan seed dari tabel seeds (GetAllSeeds), bukan GetSeedCount.
-- Scan BP + Seed Shop INDEPENDEN dan digabung.
-- Kalau keduanya kosong/nil → return list kosong (tidak nanam apapun).
local function BuildSeedsToPlant(seeds)
    local list     = {}
    local addedMap = {}

    -- Seed dari Scan BP (SelectedSeed = display name, e.g. "Cactus")
    if SelectedSeed then
        for _, s in ipairs(seeds) do
            if s.Name == SelectedSeed and not addedMap[s.Name] then
                table.insert(list, s.Name)
                addedMap[s.Name] = true
                break
            end
        end
        -- kalau seed sudah habis (tidak ada di seeds) → tidak ditambah, tidak fallback
    end

    -- Seed dari Seed Shop (SelectedPlantFlowers = internal name, e.g. "RedRose", "Cactus")
    if #SelectedPlantFlowers > 0 then
        for _, s in ipairs(seeds) do
            local internalName = GetPlantSeedName(s.Name)
            for _, chosen in ipairs(SelectedPlantFlowers) do
                if internalName == chosen and not addedMap[s.Name] then
                    table.insert(list, s.Name)
                    addedMap[s.Name] = true
                    break
                end
            end
        end
    end

    -- Tidak ada fallback ke semua seed
    -- Scan nil + Shop kosong = list kosong = tidak nanam apapun
    return list
end

local function ContinuousSeedPlant()
    IsAutoSeedRunning = true
    while IsAutoSeedRunning do
        local seeds = GetAllSeeds()
        if #seeds == 0 then
            Log("[SeedLoop] Tidak ada seed di backpack, menunggu...")
            wait(5)
        else
            local seedsToPlant = BuildSeedsToPlant(seeds)
            if #seedsToPlant == 0 then
                Log("[SeedLoop] Tidak ada seed sesuai pilihan, menunggu...")
                wait(5)
            else
                AutoSeedEnabled = true
                ClearPlantedPositions()   -- reset tiap iterasi (seperti referensi v0.2.0)

                local plotsToPlant = {}
                if PlantAllPlots then for i = 1, 6 do table.insert(plotsToPlant, i) end
                elseif SelectedPlot then table.insert(plotsToPlant, SelectedPlot) end

                for _, plotNum in ipairs(plotsToPlant) do
                    if not IsAutoSeedRunning then break end
                    for _, seedName in ipairs(seedsToPlant) do
                        if not IsAutoSeedRunning then break end
                        if GetSeedCount(seedName) > 0 then
                            AutoPlantGrid(seedName, plotNum, PlantMode, false, nil)
                            wait(1)
                        end
                    end
                end
                AutoSeedEnabled = false
                wait(2)
            end
        end
    end
    IsAutoSeedRunning = false
end

local function ContinuousFlowerPlant()
    IsAutoFlowerRunning = true
    while IsAutoFlowerRunning do
        local entry = SelectedPlantFlowerName and ScannedPlantFlowers[SelectedPlantFlowerName]
        local ids   = entry and entry.ids
        if not ids or #ids == 0 then
            Log("[FlowerLoop] Tidak ada flower dipilih/scan, menunggu...")
            wait(5)
        else
            AutoFlowerEnabled = true
            ClearPlantedPositions()   -- reset tiap iterasi

            local plotsToPlant = {}
            if PlantAllPlots then for i = 1, 6 do table.insert(plotsToPlant, i) end
            elseif SelectedPlot then table.insert(plotsToPlant, SelectedPlot) end

            for _, plotNum in ipairs(plotsToPlant) do
                if not IsAutoFlowerRunning then break end
                AutoPlantGrid(SelectedPlantFlowerName, plotNum, PlantMode, true, ids)
                wait(1)
            end
            AutoFlowerEnabled = false
            wait(2)
        end
    end
    IsAutoFlowerRunning = false
end

