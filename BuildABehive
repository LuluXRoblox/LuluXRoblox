-- HEARTBEAT
-- > 1 jam  : sleep 1 jam → re-verify
-- < 1 jam  : countdown per detik (update expireText)
-- = 0      : tunggu 3s → cek apakah admin extend waktu
-- ══════════════════════════════════════════════════════════════
local function startHeartbeat()
    task.spawn(function()
        while true do
            local rem = expireUnix == 0 and math.huge
                        or (expireUnix - (math.floor(tick()) + tickOffset))

            if rem > 21600 then
                -- Normal: tidur 6 jam lalu verify
                task.wait(21600)
                local key = readSavedKey()
                if not key then break end
                local d, e = verifyKey(key)
                if e then
                    -- network error → skip, coba lagi jam berikutnya
                elseif not d.valid then
                    deleteKeyFile()
                    player:Kick("Your licence has been revoked by an administrator.")
                    break
                else
                    expireUnix = d.expireAt or 0
                    refreshExpireText()
                end

            elseif rem > 0 then
                -- Countdown < 6 jam: update teks tiap detik
                refreshExpireText()
                task.wait(1)

            else
                -- Zero! tunggu 3s → cek apakah admin extend
                expireText = "Expired"
                task.wait(3)
                local key = readSavedKey()
                if not key then
                    player:Kick("Licence expired.")
                    break
                end
                local d, e = verifyKey(key)
                if e or not d or not d.valid then
                    deleteKeyFile()
                    player:Kick("Your licence has expired.")
                    break
                else
                    -- Admin extend waktu → lanjut normal
                    expireUnix = d.expireAt or 0
                    refreshExpireText()
                    task.wait(60)
                end
            end
        end
    end)
end

