local function LoadExistingFlowerPositions()
    PlantedPositions = {}
    local myModel = GetMyPlotModel()
    if not myModel then return end
    local flowersFolder = myModel:FindFirstChild("Flowers")
    if not flowersFolder then return end
    for _, flower in ipairs(flowersFolder:GetChildren()) do
        local pos
        local hitbox = flower:FindFirstChild("Hitbox") or (flower.Name == "Hitbox" and flower)
        if hitbox and hitbox:IsA("BasePart") then
            pos = hitbox.Position
        elseif flower.PrimaryPart then
            pos = flower.PrimaryPart.Position
        else
            for _, part in ipairs(flower:GetDescendants()) do
                if part:IsA("BasePart") then pos = part.Position; break end
            end
        end
        if pos then
            table.insert(PlantedPositions, {x = pos.X, z = pos.Z})
        end
    end
    Log("[Plant] Loaded " .. #PlantedPositions .. " posisi bunga yang sudah ada")
end

