-- HTTP wrapper (kompatibel Delta / Fluxus / Synapse)
local function httpPost(url, body)
    local reqFn = (syn and syn.request)
               or http_request
               or request
               or HttpRequest
    if not reqFn then return nil, "No HTTP function" end
    local ok, res = pcall(reqFn, {
        Url     = url,
        Method  = "POST",
        Headers = { ["Content-Type"] = "application/json" },
        Body    = HS:JSONEncode(body),
    })
    if not ok then return nil, tostring(res) end
    return res, nil
end

-- HWID
local function getHWID()
    if getmachineidentity then
        local ok, v = pcall(getmachineidentity)
        if ok and v and #v > 0 then return v end
    end
    if gethwid then
        local ok, v = pcall(gethwid)
        if ok and v and #v > 0 then return v end
    end
    return tostring(player.UserId)
end

-- File helpers
local function ensureFolder()
    pcall(function()
        if not isfolder(KEY_FOLDER) then makefolder(KEY_FOLDER) end
    end)
end

local function readSavedKey()
    local ok, v = pcall(isfile, KEY_FILE)
    if not ok or not v then return nil end
    local ok2, data = pcall(readfile, KEY_FILE)
    if not ok2 then return nil end
    return (data or ""):match("^%s*(.-)%s*$")
end

local function saveKeyFile(key)
    ensureFolder()
    pcall(writefile, KEY_FILE, key)
end

local function deleteKeyFile()
    pcall(function()
        if isfile(KEY_FILE) then
            if delfile then delfile(KEY_FILE)
            elseif removefile then removefile(KEY_FILE)
            end
        end
    end)
end

-- Verify key against API
local function verifyKey(key)
    local hwid = getHWID()
    local res, err = httpPost(API_BASE .. "/api/verify", { key = key, hwid = hwid })
    if not res then return nil, "Network error: " .. (err or "?") end
    if res.StatusCode ~= 200 then return nil, "Server error " .. res.StatusCode end
    local ok, data = pcall(HS.JSONDecode, HS, res.Body)
    if not ok then return nil, "Parse error" end
    return data, nil
end

-- Format remaining time
local function formatRemaining(unixTs)
    if not unixTs or unixTs == 0 then return "Permanent" end
    local rem = unixTs - (math.floor(tick()) + tickOffset)
    if rem <= 0 then return "Expired" end
    local parts = {}
    local mo = math.floor(rem/2592000); rem = rem % 2592000
    local w  = math.floor(rem/604800);  rem = rem % 604800
    local d  = math.floor(rem/86400);   rem = rem % 86400
    local h  = math.floor(rem/3600);    rem = rem % 3600
    local m  = math.floor(rem/60)
    local s  = rem % 60
    if mo>0 then table.insert(parts, mo.."M") end
    if w>0  then table.insert(parts, w.."W")  end
    if d>0  then table.insert(parts, d.."D")  end
    if h>0  then table.insert(parts, h.."H")  end
    if m>0  then table.insert(parts, m.."min") end
    -- Saat countdown (< 1 jam) tampilkan detik juga
    if mo==0 and w==0 and d==0 and h==0 then
        table.insert(parts, s.."s")
    end
    return (#parts>0 and table.concat(parts," ") or "< 1s") .. " remaining"
end

