-- State incremental scan
local FilterScannedUIDs = {}
local FilterFlowerOpts  = {}
local FilterMutOpts     = {}
local FilterBeeOpts     = {}
local seenFilterF, seenFilterM, seenFilterB = {}, {}, {}

-- Callback: dipanggil saat opsi baru ditemukan
local FilterDropCallbacks = {}

local function FireFilterUpdate()
    for _, cb in ipairs(FilterDropCallbacks) do
        pcall(cb, FilterFlowerOpts, FilterMutOpts, FilterBeeOpts)
    end
end

-- Proses satu flower, return true kalau ada opsi baru
local function ProcessFilterFlower(flower)
    if not flower or not flower.Parent then return false end
    local hb = flower:FindFirstChild("Hitbox") or (flower.Name == "Hitbox" and flower)
    if not hb then return false end
    local uid = hb:GetAttribute("UniqueId")
    if not uid then return false end
    local key = tostring(uid)
    if FilterScannedUIDs[key] then return false end
    FilterScannedUIDs[key] = true
    local newFound = false
    local fid = hb:GetAttribute("FlowerId")
    local mid = hb:GetAttribute("ModelAltId")
    local bid = hb:GetAttribute("BeeId")
    if fid and fid ~= "" and not seenFilterF[fid] then
        seenFilterF[fid] = true; table.insert(FilterFlowerOpts, fid); newFound = true
    end
    if mid and mid ~= "" and not seenFilterM[mid] then
        seenFilterM[mid] = true; table.insert(FilterMutOpts, mid); newFound = true
    end
    if bid and bid ~= "" and not seenFilterB[bid] then
        seenFilterB[bid] = true; table.insert(FilterBeeOpts, bid); newFound = true
    end
    return newFound
end

-- Incremental scan: cek UID baru saja, tidak rescan semua
local function IncrementalFilterScan()
    local myModel = GetMyPlotModel()
    if not myModel then return end
    local flowersFolder = myModel:FindFirstChild("Flowers")
    if not flowersFolder then return end
    local newFound = false
    for _, flower in ipairs(flowersFolder:GetChildren()) do
        if ProcessFilterFlower(flower) then newFound = true end
    end
    if newFound then
        table.sort(FilterFlowerOpts)
        table.sort(FilterMutOpts)
        table.sort(FilterBeeOpts)
        FireFilterUpdate()
    end
end

-- Setup ChildAdded: bunga baru muncul -> langsung update dropdown
local FilterChildConn = nil
local function SetupFilterChildListener()
    if FilterChildConn then FilterChildConn:Disconnect(); FilterChildConn = nil end
    local myModel = GetMyPlotModel()
    if not myModel then return end
    local flowersFolder = myModel:FindFirstChild("Flowers")
    if not flowersFolder then return end
    FilterChildConn = flowersFolder.ChildAdded:Connect(function(flower)
        task.wait(0.3)
        if ProcessFilterFlower(flower) then
            table.sort(FilterFlowerOpts)
            table.sort(FilterMutOpts)
            table.sort(FilterBeeOpts)
            FireFilterUpdate()
            Log("[FilterScan] Bunga baru -> dropdown diupdate")
        end
    end)
    Log("[FilterScan] ChildAdded listener aktif")
end

-- Reset penuh (rescan dari nol)
local function ResetFilterScan()
    FilterScannedUIDs = {}
    FilterFlowerOpts  = {}
    FilterMutOpts     = {}
    FilterBeeOpts     = {}
    seenFilterF, seenFilterM, seenFilterB = {}, {}, {}
    FireFilterUpdate()
end

-- Compat: return cached opts + trigger incremental
local function ScanPlotFlowerOptions()
    IncrementalFilterScan()
    return FilterFlowerOpts, FilterMutOpts, FilterBeeOpts
end

-- Cek apakah flower cocok dengan filter criteria (multi-select)
-- sel* = table pilihan; attrFid/attrMid/attrBid = attribute bunga
local function FilterMatchMulti(selFlowers, selMuts, selBees, attrFid, attrMid, attrBid)
    -- Kalau semua tabel kosong = tidak ada filter aktif
    if #selFlowers == 0 and #selMuts == 0 and #selBees == 0 then
        return false
    end
    local mF = (#selFlowers == 0) or (table.find(selFlowers, attrFid) ~= nil)
    local mM = (#selMuts    == 0) or (table.find(selMuts, attrMid)    ~= nil)
    local mB = (#selBees    == 0) or (table.find(selBees, attrBid)    ~= nil)
    return mF and mM and mB
end

-- Hide visual parts bunga (kecuali Hitbox)
local function HideFlowerVisuals(flower)
    for _, part in ipairs(flower:GetDescendants()) do
        if (part:IsA("BasePart") or part:IsA("MeshPart")) and part.Name ~= "Hitbox" then
            part.Transparency = 1
        end
    end
end

-- Show visual parts bunga
local function ShowFlowerVisuals(flower)
    for _, part in ipairs(flower:GetDescendants()) do
        if (part:IsA("BasePart") or part:IsA("MeshPart")) and part.Name ~= "Hitbox" then
            part.Transparency = 0
        end
    end
end

-- EXCLUDE: Sembunyikan bunga yang MATCH pilihan (yang dipilih = tidak diproses)
-- visibleStorage: tempat simpan bunga yang TIDAK match (visible, hitbox dipindah tapi tidak disembunyikan)
local function ApplyFlowerFilterMulti(storage, visibleStorage, selFlowers, selMuts, selBees)
    local myModel = GetMyPlotModel()
    if not myModel then return 0 end
    local flowersFolder = myModel:FindFirstChild("Flowers")
    if not flowersFolder then return 0 end
    local count = 0
    for _, flower in ipairs(flowersFolder:GetChildren()) do
        if flower and flower.Parent then
            local hb = flower:FindFirstChild("Hitbox") or (flower.Name == "Hitbox" and flower)
            if hb then
                local uid = hb:GetAttribute("UniqueId")
                local fid = hb:GetAttribute("FlowerId")
                local mid = hb:GetAttribute("ModelAltId")
                local bid = hb:GetAttribute("BeeId")
                if uid then
                    local key = tostring(uid)
                    if FilterMatchMulti(selFlowers, selMuts, selBees, fid, mid, bid) then
                        -- MATCH = disembunyikan (hitbox pindah + transparansi 1)
                        if not storage[key] then
                            storage[key] = { hitbox = hb, origCF = hb.CFrame, flower = flower }
                            pcall(function() hb.CFrame = CFrame.new(FILTER_DEST_POS) end)
                            HideFlowerVisuals(flower)
                            count = count + 1
                        end
                    else
                        -- TIDAK match = tetap visible, tapi hitbox tetap dipindah ke posisi player
                        if not visibleStorage[key] and not storage[key] then
                            local destPos = FilterVisibleDestPos or FILTER_DEST_POS
                            visibleStorage[key] = { hitbox = hb, origCF = hb.CFrame, flower = flower }
                            pcall(function() hb.CFrame = CFrame.new(destPos) end)
                        end
                    end
                end
            end
        end
    end
    return count
end

-- INCLUDE: Sembunyikan bunga yang TIDAK match pilihan (yang dipilih = yang diproses)
-- visibleStorage: tempat simpan bunga yang MATCH (visible/diproses, hitbox dipindah tapi tidak disembunyikan)
local function ApplyFlowerFilterInverse(storage, visibleStorage, selFlowers, selMuts, selBees)
    local myModel = GetMyPlotModel()
    if not myModel then return 0 end
    local flowersFolder = myModel:FindFirstChild("Flowers")
    if not flowersFolder then return 0 end
    local count = 0
    for _, flower in ipairs(flowersFolder:GetChildren()) do
        if flower and flower.Parent then
            local hb = flower:FindFirstChild("Hitbox") or (flower.Name == "Hitbox" and flower)
            if hb then
                local uid = hb:GetAttribute("UniqueId")
                local fid = hb:GetAttribute("FlowerId")
                local mid = hb:GetAttribute("ModelAltId")
                local bid = hb:GetAttribute("BeeId")
                if uid then
                    local key = tostring(uid)
                    -- Sembunyikan yang TIDAK match (bukan yang dipilih)
                    if not FilterMatchMulti(selFlowers, selMuts, selBees, fid, mid, bid) then
                        if not storage[key] then
                            storage[key] = { hitbox = hb, origCF = hb.CFrame, flower = flower }
                            pcall(function() hb.CFrame = CFrame.new(FILTER_DEST_POS) end)
                            HideFlowerVisuals(flower)
                            count = count + 1
                        end
                    else
                        -- MATCH = tetap visible (yang diproses), tapi hitbox tetap dipindah ke posisi player
                        if not visibleStorage[key] and not storage[key] then
                            local destPos = FilterVisibleDestPos or FILTER_DEST_POS
                            visibleStorage[key] = { hitbox = hb, origCF = hb.CFrame, flower = flower }
                            pcall(function() hb.CFrame = CFrame.new(destPos) end)
                        end
                    end
                end
            end
        end
    end
    return count
end

-- Kembalikan hitbox & visual ke posisi asal (untuk bunga yang disembunyikan)
local function RestoreFlowerFilter(storage)
    for key, data in pairs(storage) do
        local hb  = data.hitbox
        local fl  = data.flower
        if hb and hb.Parent then
            pcall(function()
                hb.CFrame = data.origCF
            end)
        end
        if fl and fl.Parent then
            ShowFlowerVisuals(fl)
        end
    end
    for k in pairs(storage) do storage[k] = nil end
end

-- Kembalikan hitbox ke posisi asal (untuk bunga yang TIDAK disembunyikan, hanya hitbox yang dipindah)
-- Tidak mengubah transparansi karena visual bunga tidak pernah disembunyikan
local function RestoreVisibleHitboxes(storage)
    for key, data in pairs(storage) do
        local hb = data.hitbox
        if hb and hb.Parent then
            pcall(function()
                hb.CFrame = data.origCF
            end)
        end
    end
    for k in pairs(storage) do storage[k] = nil end
end

