local function ClearCustomPlantESP()
    if CustomPlantESPFolder and CustomPlantESPFolder.Parent then
        CustomPlantESPFolder:Destroy()
    end
    CustomPlantESPFolder = nil
end

-- Hitung jumlah slot dari stud / GRID_STEP
local function GetCustomPlantSlotCount()
    return math.max(1, math.floor(CustomPlantStud / GRID_STEP))
end

-- Buat ESP line custom (warna putih, tinggi 2x dari line lain)
local function ShowCustomPlantESP()
    ClearCustomPlantESP()
    if not CustomPlantStartPos then return end

    CustomPlantESPFolder = Instance.new("Folder")
    CustomPlantESPFolder.Name   = "LuluCustomPlantESP"
    CustomPlantESPFolder.Parent = workspace

    local slots    = GetCustomPlantSlotCount()
    local radRot   = math.rad(CustomPlantRotLine)
    -- 0° = utara (Z-), searah jarum jam
    local dirX     = math.sin(radRot)
    local dirZ     = -math.cos(radRot)

    for i = 0, slots - 1 do
        local dist = i * GRID_STEP
        local wx   = CustomPlantStartPos.X + dirX * dist
        local wy   = CustomPlantStartPos.Y
        local wz   = CustomPlantStartPos.Z + dirZ * dist

        local marker = Instance.new("Part")
        marker.Anchored     = true
        marker.CanCollide   = false
        marker.CastShadow   = false
        marker.Size         = Vector3.new(0.4, 0.8, 0.4)  -- 2x tinggi dari line lain (0.4)
        marker.CFrame       = CFrame.new(wx, wy + 0.4, wz)
        marker.Color        = Color3.fromRGB(255, 255, 255)
        marker.Material     = Enum.Material.Neon
        marker.Transparency = 0.15
        marker.Parent       = CustomPlantESPFolder
    end

    -- Garis penghubung antar marker
    if slots > 1 then
        local p1 = CustomPlantStartPos
        local p2 = Vector3.new(
            CustomPlantStartPos.X + dirX * ((slots - 1) * GRID_STEP),
            CustomPlantStartPos.Y,
            CustomPlantStartPos.Z + dirZ * ((slots - 1) * GRID_STEP)
        )
        local diff = p2 - p1
        local dist = diff.Magnitude
        if dist > 0.05 then
            local mid  = (p1 + p2) / 2
            local beam = Instance.new("Part")
            beam.Anchored     = true
            beam.CanCollide   = false
            beam.CastShadow   = false
            beam.Size         = Vector3.new(0.15, 0.15, dist)
            beam.CFrame       = CFrame.new(mid + Vector3.new(0, 0.4, 0), mid + Vector3.new(0, 0.4, 0) + diff.Unit)
            beam.Color        = Color3.fromRGB(255, 255, 255)
            beam.Material     = Enum.Material.Neon
            beam.Transparency = 0.4
            beam.Parent       = CustomPlantESPFolder
        end
    end

    Log(string.format("[CustomPlant] ESP: %d slots, rot=%.0f°, stud=%.0f", slots, CustomPlantRotLine, CustomPlantStud))
end

