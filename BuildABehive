local function GetSeedCount(seedType)
    local backpack = player:WaitForChild("Backpack")
    for _, item in ipairs(backpack:GetChildren()) do
        local itemLower = item.Name:lower()
        if itemLower:match(seedType:lower()) and itemLower:match("seed") then
            return tonumber(item.Name:match("%[x(%d+)%]")) or 1
        end
    end
    return 0
end

local function GetAllSeeds()
    local backpack = player:WaitForChild("Backpack")
    local seeds, seen = {}, {}
    for _, item in ipairs(backpack:GetChildren()) do
        if item.Name:match("Seed") then
            local seedType = item.Name:match("(.-)%s+Seed")
            if seedType and not seen[seedType] then
                seen[seedType] = true
                GetPlantSeedName(seedType)
                table.insert(seeds, {
                    Name  = seedType,
                    Count = tonumber(item.Name:match("%[x(%d+)%]")) or 1
                })
            end
        end
    end
    return seeds
end

