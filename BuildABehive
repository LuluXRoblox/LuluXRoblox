            if seedType and not seenSeed[seedType] then
                seenSeed[seedType] = true
                local count = tonumber(item.Name:match("%[x(%d+)%]")) or 1
                table.insert(CustomPlantScannedSeeds, {Name = seedType, Count = count})
            end
        end
    end

    -- Scan Flowers (by UniqueId)
    local seenFlower = {}
    for _, item in ipairs(backpack:GetChildren()) do
        if not IsExcluded(item.Name) then
            local uid = item:GetAttribute("UniqueId")
            if uid then
                local idNum = tonumber(uid)
                if idNum then
                    if not seenFlower[item.Name] then
                        seenFlower[item.Name] = {ids = {}, baseName = GetBaseFlowerName(item.Name)}
                    end
                    table.insert(seenFlower[item.Name].ids, idNum)
                end
            end
        end
    end
    for name, data in pairs(seenFlower) do
        table.insert(CustomPlantScannedFlower, {Name = name, ids = data.ids, baseName = data.baseName})
    end

    Log(string.format("[CustomPlant] Scan: %d seed type(s), %d flower type(s)",
        #CustomPlantScannedSeeds, #CustomPlantScannedFlower))
    return CustomPlantScannedSeeds, CustomPlantScannedFlower
end

-- Tanam Custom Plant (once)
local function RunCustomPlant()
    if not CustomPlantStartPos then
        return false, "Set Start dulu!"
    end

    local slots   = GetCustomPlantSlotCount()
    local radRot  = math.rad(CustomPlantRotLine)
    local dirX    = math.sin(radRot)
    local dirZ    = -math.cos(radRot)
    local radFlower = math.rad(CustomPlantRotFlower)

    local planted = 0

    if CustomPlantType == "Seed" then
        -- Kumpulkan seed yang dipilih dan ada di backpack
        local seedsToUse = {}
        for _, chosen in ipairs(CustomPlantSelected) do
            -- chosen format: "SeedName [xN]"
            local seedName = chosen:match("(.-)%s+%[x") or chosen
            if GetSeedCount(seedName) > 0 then
                table.insert(seedsToUse, seedName)
            end
        end
        if #seedsToUse == 0 then return false, "Tidak ada seed yang dipilih / habis!" end

        local seedIdx = 1
        for i = 0, slots - 1 do
            if seedIdx > #seedsToUse then seedIdx = 1 end
            local seedName = seedsToUse[seedIdx]
            if GetSeedCount(seedName) <= 0 then
                -- coba seed berikutnya
                local found = false
                for _, sn in ipairs(seedsToUse) do
                    if GetSeedCount(sn) > 0 then seedName = sn; found = true; break end
                end
                if not found then Log("[CustomPlant] Semua seed habis"); break end
            end

            local dist = i * GRID_STEP
            local wx   = CustomPlantStartPos.X + dirX * dist
            local wy   = CustomPlantStartPos.Y
            local wz   = CustomPlantStartPos.Z + dirZ * dist
            local plantSeedName = GetPlantSeedName(seedName)

            local countBefore = GetSeedCount(seedName)
            pcall(function()
                ReplicatedStorage.Framework.Features.HoneySystem.FlowerUtil.RemoteFunction:InvokeServer(
                    "PlaceFlower", plantSeedName,
                    CFrame.new(wx, PlantY, wz) * CFrame.Angles(math.pi, radFlower, math.pi)
                )
            end)
            wait(0.8)
            if GetSeedCount(seedName) < countBefore then
                planted = planted + 1
                Log(string.format("[CustomPlant] Slot %d: %s sukses", i+1, seedName))
            else
                Log(string.format("[CustomPlant] Slot %d: gagal (mungkin sudah ada tanaman)", i+1))
            end
            seedIdx = seedIdx + 1
        end

    else
        -- Flower mode
        -- Kumpulkan IDs dari pilihan
        local flowerIds = {}
        for _, chosen in ipairs(CustomPlantSelected) do
            -- chosen format: "FlowerName XN"
            local fname = chosen:match("(.-)%s+X%d+") or chosen
            for _, data in ipairs(CustomPlantScannedFlower) do
                if data.Name == fname then
                    for _, id in ipairs(data.ids) do
                        table.insert(flowerIds, id)
                    end
                    break
                end
            end
        end
        if #flowerIds == 0 then return false, "Tidak ada flower yang dipilih / kosong!" end

        local idIdx = 1
        for i = 0, slots - 1 do
            if idIdx > #flowerIds then
                Log("[CustomPlant] Flower IDs habis")
                break
            end
            local flowerId = flowerIds[idIdx]
            if not IsFlowerInBackpack(flowerId) then
                idIdx = idIdx + 1
            else
                local dist = i * GRID_STEP
                local wx   = CustomPlantStartPos.X + dirX * dist
                local wy   = CustomPlantStartPos.Y
                local wz   = CustomPlantStartPos.Z + dirZ * dist

                pcall(function()
                    ReplicatedStorage.Framework.Features.HoneySystem.FlowerUtil.RemoteFunction:InvokeServer(
                        "MoveFlower", flowerId,
                        CFrame.new(wx, PlantY, wz) * CFrame.Angles(0, radFlower, 0)
                    )
                end)
                wait(0.8)

                if IsFlowerInBackpack(flowerId) then
                    Log(string.format("[CustomPlant] Slot %d: ID %d gagal, skip", i+1, flowerId))
                else
                    planted = planted + 1
                    Log(string.format("[CustomPlant] Slot %d: ID %d sukses", i+1, flowerId))
                end
                idIdx = idIdx + 1
            end  -- end else IsFlowerInBackpack
        end  -- end for slots
    end  -- end if CustomPlantType == "Seed"

    ClearCustomPlantESP()
    return true, planted .. " tanaman berhasil ditanam!"
end
