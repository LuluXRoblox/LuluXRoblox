local function GetItemsStock(itemsName)
    local success, stock = pcall(function()
        local screen = player:WaitForChild("PlayerGui"):FindFirstChild("ScreenItemsShop")
        if not screen then return 0 end
        local shopWindow = screen:FindFirstChild("TreeToolShop")
        if not shopWindow then return 0 end
        local sf = shopWindow:FindFirstChild("ScrollingFrame", true)
        if not sf then return 0 end
        local frame = sf:FindFirstChild(itemsName)
        if not frame then return 0 end
        local btn = frame:FindFirstChild("ItemButton")
        if not btn then return 0 end
        local lbl = btn:FindFirstChild("StockLabel")
        if not lbl then return 0 end
        local num = lbl.Text:match("%d+")
        return tonumber(num) or 0
    end)
    return success and stock or 0
end

local function BuyAllItemsStock(itemsName)
    local totalBought  = 0
    local initialStock = GetItemsStock(itemsName)
    if initialStock <= 0 then return 0 end
    while totalBought < initialStock do
        if GetItemsStock(itemsName) <= 0 then break end
        BuyItems(itemsName)
        totalBought = totalBought + 1
        wait(0.4)
        if totalBought >= 100 then break end
    end
    if totalBought > 0 then Log("Bought " .. totalBought .. "x " .. itemsName) end
    return totalBought
end

local function AutoBuyItems(list)
    if not list or #list == 0 then return false end
    local bought = false
    for _, itemsName in ipairs(list) do
        if GetItemsStock(itemsName) > 0 then
            BuyAllItemsStock(itemsName)
            task.wait(0.5)
            bought = true
        end
    end
    return bought
end

