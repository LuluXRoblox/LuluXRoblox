-- ================================================================
-- GRID FUNCTIONS (Setting Plot system)
-- Sort 4 corners -> TL(A), TR(B), BL(C), BR(D)
-- ================================================================
local function SortCornersForGrid(c1, c2, c3, c4)
    local pts = {c1, c2, c3, c4}
    local cx, cz = 0, 0
    for _, p in ipairs(pts) do cx = cx + p.x; cz = cz + p.z end
    cx = cx / 4; cz = cz / 4
    local top, bot = {}, {}
    for _, p in ipairs(pts) do
        if p.z < cz then table.insert(top, p) else table.insert(bot, p) end
    end
    if #top < 2 or #bot < 2 then
        local all = {}
        for _, p in ipairs(pts) do
            table.insert(all, {p = p, ang = math.atan2(p.z - cz, p.x - cx)})
        end
        table.sort(all, function(a, b) return a.ang < b.ang end)
        return all[1].p, all[2].p, all[4].p, all[3].p
    end
    table.sort(top, function(a, b) return a.x < b.x end)
    table.sort(bot, function(a, b) return a.x < b.x end)
    return top[1], top[2], bot[1], bot[2]
end

local function ComputeGridPositions(A, B, C, D)
    local aV = Vector3.new(A.x, A.y, A.z)
    local bV = Vector3.new(B.x, B.y, B.z)
    local cV = Vector3.new(C.x, C.y, C.z)
    local dV = Vector3.new(D.x, D.y, D.z)

    local countAB = math.floor((bV - aV).Magnitude / GRID_STEP)
    local countAC = math.floor((cV - aV).Magnitude / GRID_STEP)

    local positions = {}
    for col = 0, countAB do
        local t1      = countAB > 0 and (col / countAB) or 0
        local pTop    = aV:Lerp(bV, t1)
        local pBot    = cV:Lerp(dV, t1)
        local blueName = "Blue" .. (col + 1)
        for row = 0, countAC do
            local t2     = countAC > 0 and (row / countAC) or 0
            local pos    = pTop:Lerp(pBot, t2)
            local redName = "Red" .. (row + 1)
            table.insert(positions, {
                name      = blueName .. "x" .. redName,
                blue_line = blueName,
                red_line  = redName,
                col = col + 1,
                row = row + 1,
                x   = pos.X,
                y   = pos.Y,
                z   = pos.Z,
            })
        end
    end
    return positions, countAB + 1, countAC + 1
end

local function GetLineNumbers(lineType)
    local opts = {"All Number"}
    if lineType == "All" then return opts end
    local plotNum = PlantAllPlots and 1 or (SelectedPlot or 1)
    local corners = GetPlotCorners(plotNum)
    if not corners.p1 then
        for i = 1, 20 do table.insert(opts, lineType .. i) end
        return opts
    end
    local A, B, C, D = SortCornersForGrid(corners.p1, corners.p2, corners.p3, corners.p4)
    local _, colCount, rowCount = ComputeGridPositions(A, B, C, D)
    local count = lineType == "Blue" and colCount or rowCount
    for i = 1, count do table.insert(opts, lineType .. i) end
    return opts
end

-- ================================================================
-- ESP LINE HIGHLIGHT
-- ================================================================
local function ClearLineESP()
    if LineESPFolder and LineESPFolder.Parent then
        LineESPFolder:Destroy()
    end
    LineESPFolder = nil
end

local function MakeESPBeam(v1, v2, color)
    local diff = v2 - v1
    local dist = diff.Magnitude
    if dist < 0.05 then return nil end
    local mid  = (v1 + v2) / 2
    local beam = Instance.new("Part")
    beam.Anchored      = true
    beam.CanCollide    = false
    beam.CastShadow    = false
    beam.Size          = Vector3.new(0.4, 0.4, dist)
    beam.CFrame        = CFrame.new(mid, mid + diff.Unit)
    beam.Color         = color
    beam.Material      = Enum.Material.Neon
    beam.Transparency  = 0.15
    beam.Parent        = LineESPFolder
    return beam
end

local function ShowSelectedLineESP()
    ClearLineESP()
    if PlotLineFilterType == "All" or PlotLineFilterNum == "All" then return end

    local plotNum = PlantAllPlots and 1 or (SelectedPlot or 1)
    local corners = GetPlotCorners(plotNum)
    if not corners.p1 then return end

    local A, B, C, D = SortCornersForGrid(corners.p1, corners.p2, corners.p3, corners.p4)
    local aV = Vector3.new(A.x, A.y, A.z)
    local bV = Vector3.new(B.x, B.y, B.z)
    local cV = Vector3.new(C.x, C.y, C.z)
    local dV = Vector3.new(D.x, D.y, D.z)

    local countAB = math.floor((bV - aV).Magnitude / GRID_STEP)
    local countAC = math.floor((cV - aV).Magnitude / GRID_STEP)

    local lineIdx = tonumber(PlotLineFilterNum:match("%d+"))
    if not lineIdx then return end
    local zeroIdx = lineIdx - 1

    LineESPFolder = Instance.new("Folder")
    LineESPFolder.Name   = "LuluLineESP"
    LineESPFolder.Parent = workspace

    local COLOR_BLUE = Color3.fromRGB(80, 160, 255)
    local COLOR_RED  = Color3.fromRGB(255, 80,  80)

    if PlotLineFilterType == "Blue" then
        if zeroIdx > countAB then ClearLineESP() return end
        local t  = (countAB > 0) and (zeroIdx / countAB) or 0
        local p1 = aV:Lerp(bV, t)
        local p2 = cV:Lerp(dV, t)
        MakeESPBeam(p1, p2, COLOR_BLUE)

    elseif PlotLineFilterType == "Red" then
        if zeroIdx > countAC then ClearLineESP() return end
        local t  = (countAC > 0) and (zeroIdx / countAC) or 0
        local p1 = aV:Lerp(cV, t)
        local p2 = bV:Lerp(dV, t)
        MakeESPBeam(p1, p2, COLOR_RED)
    end
end

