local EXCLUDED_KEYWORDS = {"seed","fertilizer","deletetols","movetols","delete","move"}

local function IsExcluded(itemName)
    local lower = itemName:lower()
    for _, kw in ipairs(EXCLUDED_KEYWORDS) do
        if lower:find(kw) then return true end
    end
    return false
end

local function GetBaseFlowerName(itemName)
    return itemName:match("^(.-)%s*%[") or itemName
end

local function ScanBackpackFlowers()
    ScannedBackpackFlowers = {}
    local backpack = player:WaitForChild("Backpack")
    for _, item in ipairs(backpack:GetChildren()) do
        if not IsExcluded(item.Name) then
            local uid = item:GetAttribute("UniqueId")
            if uid then
                local idNum = tonumber(uid)
                if idNum then
                    if not ScannedBackpackFlowers[item.Name] then
                        ScannedBackpackFlowers[item.Name] = {
                            ids      = {},
                            baseName = GetBaseFlowerName(item.Name),
                        }
                    end
                    table.insert(ScannedBackpackFlowers[item.Name].ids, idNum)
                end
            end
        end
    end
    local count = 0
    for name, data in pairs(ScannedBackpackFlowers) do
        count = count + #data.ids
        Log("Found: " .. name .. " x" .. #data.ids .. " (base: " .. data.baseName .. ")")
    end
    Log("Scan selesai: " .. count .. " items")
    return ScannedBackpackFlowers
end

