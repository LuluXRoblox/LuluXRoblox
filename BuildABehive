                local Terrain  = workspace:FindFirstChildOfClass("Terrain")

                -- Quality: coba enum dulu, fallback ke angka
                pcall(function()
                    settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
                end)
                pcall(function()
                    settings().Rendering.QualityLevel = 1
                end)

                -- Lighting settings
                pcall(function()
                    Lighting.GlobalShadows = false
                    Lighting.FogEnd        = 100000
                    Lighting.Brightness    = 1
                    Lighting.ClockTime     = 14
                end)

                -- Hapus PostEffect & Sky, pasang Sky bersih
                pcall(function()
                    for _, v in ipairs(Lighting:GetChildren()) do
                        if v:IsA("PostEffect") or v:IsA("Sky") then
                            v:Destroy()
                        end
                    end
                    Instance.new("Sky").Parent = Lighting
                end)

                -- Hapus fx: yield tiap 200 item agar tidak freeze
                local fxCount = 0
                local i = 0
                for _, v in ipairs(game:GetDescendants()) do
                    i = i + 1
                    if i % 200 == 0 then task.wait() end
                    pcall(function()
                        if v:IsA("ParticleEmitter") or v:IsA("Trail")
                        or v:IsA("Beam")           or v:IsA("Explosion")
                        or v:IsA("Fire")           or v:IsA("Smoke")
                        or v:IsA("Sparkles") then
                            v:Destroy()
                            fxCount = fxCount + 1
                        end
                    end)
                end

                -- BasePart: SmoothPlastic + Reflectance 0
                local partCount = 0
                i = 0
                for _, v in ipairs(workspace:GetDescendants()) do
                    i = i + 1
                    if i % 200 == 0 then task.wait() end
                    pcall(function()
                        if v:IsA("BasePart") then
                            v.Material    = Enum.Material.SmoothPlastic
                            v.Reflectance = 0
                            partCount = partCount + 1
                        end
                    end)
                end

                -- Decal & Texture
                local decalCount = 0
                i = 0
                for _, v in ipairs(workspace:GetDescendants()) do
                    i = i + 1
                    if i % 200 == 0 then task.wait() end
                    pcall(function()
                        if v:IsA("Decal") or v:IsA("Texture") then
                            v.Transparency = 0.5
                            decalCount = decalCount + 1
                        end
                    end)
                end

                -- MaterialService (pcall penuh, bisa silent fail di beberapa executor)
                pcall(function()
                    local ms = game:GetService("MaterialService")
                    for _, v in ipairs(ms:GetChildren()) do
                        v:Destroy()
                    end
                end)

                -- Terrain water
                if Terrain then
                    pcall(function()
                        Terrain.WaterWaveSize     = 0
                        Terrain.WaterWaveSpeed    = 0
                        Terrain.WaterReflectance  = 0
                        Terrain.WaterTransparency = 1
                    end)
                end

                win:luluNotify(
                    fxCount .. " fx | " .. partCount .. " parts | " .. decalCount .. " decals",
                    Color3.fromRGB(40, 160, 60)
                )
                done()
            end)
        end, {color = Color3.fromRGB(200, 50, 50), loading = "Optimizing..."})
