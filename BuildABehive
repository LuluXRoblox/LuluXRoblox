local function PlantSeedAt(seedType, x, y, z, mode, plotNum)
    if not IsPositionAvailable(x, z) then return false end
    local plantSeedName = GetPlantSeedName(seedType)
    Log("Tanam [".. plantSeedName .. "] Plot " .. (plotNum or "?"))

    local countBefore = GetSeedCount(seedType)

    if mode == "follow_player" then
        TeleportPlayer(x, y, z)
        local playerPos = player.Character.HumanoidRootPart.Position
        local args = {
            "PlaceFlower", plantSeedName,
            CFrame.new(playerPos.X, PlantY, playerPos.Z)
                * CFrame.Angles(math.pi, (math.random()*2-1)*0.4, math.random()>0.5 and math.pi or -math.pi)
        }
        pcall(function()
            ReplicatedStorage.Framework.Features.HoneySystem.FlowerUtil.RemoteFunction:InvokeServer(unpack(args))
        end)
    else
        local args = {
            "PlaceFlower", plantSeedName,
            CFrame.new(x, PlantY, z)
                * CFrame.Angles(math.pi, (math.random()*2-1)*0.4, math.random()>0.5 and math.pi or -math.pi)
        }
        pcall(function()
            ReplicatedStorage.Framework.Features.HoneySystem.FlowerUtil.RemoteFunction:InvokeServer(unpack(args))
        end)
    end
    wait(0.8)

    local countAfter = GetSeedCount(seedType)
    if countAfter < countBefore then
        if mode == "follow_player" then
            local playerPos = player.Character and player.Character.HumanoidRootPart
            if playerPos then AddPlantedPosition(playerPos.Position.X, playerPos.Position.Z) end
        else
            AddPlantedPosition(x, z)
        end
        Log("[Seed] Sukses: " .. plantSeedName .. " (" .. countBefore .. "->" .. countAfter .. ")")
        return true
    else
        Log("[Seed] Gagal tanam di posisi ini (mungkin sudah ada tanaman), skip...")
        return false
    end
end

