local BuyAllEnabled  = { seed = false, gear = false, egg = false }
local AutoBuyEnabled = { seed = false, gear = false, egg = false }
local BuyAllDelay    = 10
local AutoBuyDelay   = 1
local buyAllThreads  = {}
local autoBuyThreads = {}

-- Stats for info panel
local ABStats = { seed = 0, gear = 0, egg = 0 }

local function sendABWebhook(label, itemName, count)
