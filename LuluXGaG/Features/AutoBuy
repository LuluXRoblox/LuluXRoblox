end

local function StartBuyAll(key)
    if buyAllThreads[key] then return end
    BuyAllEnabled[key] = true
    buyAllThreads[key] = task.spawn(function()
        while BuyAllEnabled[key] do
            local total = 0
            for itemName in pairs(ShopConfig[key].data) do
                if not BuyAllEnabled[key] then break end
                local n = BuyByStock(key, itemName)
                total = total + n
                ABStats[key] = ABStats[key] + n
                task.wait(0.5)
            end
            if total > 0 then
                win:luluNotify("Buy All " .. key .. ": bought " .. total, "success")
            end
            local t = 0
            while t < BuyAllDelay and BuyAllEnabled[key] do task.wait(1); t=t+1 end
        end
        buyAllThreads[key] = nil
    end)
end

local function StopBuyAll(key)
    BuyAllEnabled[key] = false
    buyAllThreads[key] = nil
end

local function StartAutoBuy(key)
    if autoBuyThreads[key] then return end
    AutoBuyEnabled[key] = true
    autoBuyThreads[key] = task.spawn(function()
        while AutoBuyEnabled[key] do
            local list = SelectedItems[key]
            if #list == 0 then task.wait(1); continue end
            for _, name in ipairs(list) do
                if not AutoBuyEnabled[key] then break end
                local n = BuyByStock(key, name)
                ABStats[key] = ABStats[key] + n
                task.wait(AutoBuyDelay)
            end
        end
        autoBuyThreads[key] = nil
    end)
end

local function StopAutoBuy(key)
    AutoBuyEnabled[key] = false
    autoBuyThreads[key] = nil
end

