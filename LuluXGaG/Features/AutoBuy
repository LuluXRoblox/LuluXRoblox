local tabAB = win:Tab("Auto Buy")

local function BuildShop(sec, key, label)
    local keys = {}
    for k in pairs(ShopConfig[key].data) do table.insert(keys, k) end
    table.sort(keys)

    sec:MultiDropdown("Select " .. label, keys, {}, function(selected)
        SelectedItems[key] = selected
    end)

    sec:Divider()

    -- Stock info (live)
    local stockLabel = sec:Label("Stock: —")
    task.spawn(function()
        while true do
            task.wait(2)
            pcall(function()
                stockLabel.Text = "Stock: " .. GetTotalStock(key) .. " | Timer: " .. GetTimer(key)
            end)
        end
    end)

    sec:Toggle("Buy All " .. label, false, function(on)
        if on then
            StartBuyAll(key)
            win:luluNotify("Buy All " .. label .. " ON", "success")
        else
            StopBuyAll(key)
            win:luluNotify("Buy All " .. label .. " OFF", "warning")
        end
    end)

    sec:Button("Buy Now", function()
        local list = SelectedItems[key]
        if #list == 0 then win:luluNotify("Select items first!", "warning"); return end
        task.spawn(function()
            local total = 0
            for _, name in ipairs(list) do
                local n = BuyByStock(key, name)
                total = total + n
                ABStats[key] = ABStats[key] + n
            end
            win:luluNotify("Bought total x" .. total, "success")
        end)
    end)

    sec:Toggle("Auto Buy " .. label, false, function(on)
        if on then
            if #SelectedItems[key] == 0 then
                win:luluNotify("Select items first!", "warning"); return
            end
            StartAutoBuy(key)
            win:luluNotify("Auto Buy " .. label .. " ON", "success")
        else
            StopAutoBuy(key)
            win:luluNotify("Auto Buy " .. label .. " OFF", "warning")
        end
    end)
end

tabAB:Accordion("Seed Shop", function(sec)  BuildShop(sec, "seed", "Seed") end)
tabAB:Accordion("Gear Shop", function(sec)  BuildShop(sec, "gear", "Gear") end)
tabAB:Accordion("Egg Shop",  function(sec)  BuildShop(sec, "egg",  "Egg")  end)

