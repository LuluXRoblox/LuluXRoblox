-- HELPERS
-- ============================================================
local function GetStock(key, itemName)
    local cfg = ShopConfig[key]
    local ok, val = pcall(function()
        local cur = LP:WaitForChild("PlayerGui"):FindFirstChild(cfg.guiName)
        if not cur then return 0 end
        for _, p in ipairs(cfg.scrollPath) do
            cur = cur:FindFirstChild(p)
            if not cur then return 0 end
        end
        local frame = cur:FindFirstChild(itemName)
        if not frame then return 0 end
        local mf  = frame:FindFirstChild("Main_Frame")
        if not mf  then return 0 end
        local lbl = mf:FindFirstChild("Stock_Text")
        if not lbl then return 0 end
        return tonumber(lbl.Text:match("[Xx]%s*(%d+)")) or tonumber(lbl.Text:match("%d+")) or 0
    end)
    return (ok and val) or 0
end

local function GetTotalStock(key)
    local total = 0
    for name in pairs(ShopConfig[key].data) do total = total + GetStock(key, name) end
    return total
end

local function GetTimer(key)
    local cfg = ShopConfig[key]
    local ok, val = pcall(function()
        local cur = LP:FindFirstChild("PlayerGui"):FindFirstChild(cfg.guiName)
        if not cur then return "?" end
        for _, p in ipairs(cfg.timerPath) do
            cur = cur:FindFirstChild(p)
            if not cur then return "?" end
        end
        if cur:IsA("TextLabel") or cur:IsA("TextButton") then return cur.Text end
        local lbl = cur:FindFirstChildWhichIsA("TextLabel", true)
        return lbl and lbl.Text or "?"
    end)
    return (ok and val) or "?"
end

local function BuyByStock(key, itemName)
    local count = GetStock(key, itemName)
    if count <= 0 then return 0 end
    local fireFn = ShopConfig[key].fireFn
    for i = 1, count do
        fireFn(itemName)
        task.wait(0.4)
    end
    return count
end

