-- ── INFO PANEL ───────────────────────────────────────────────
tabAM:Accordion("Mutation Pets", function(sec)

    -- On Progress
    local lblName    = sec:Label("Name    : -")
    local lblLevel   = sec:Label("Level   : -")
    local lblCurrent = sec:Label("Current : NOMUT")
    local lblTimer   = sec:Label("Mutation timer : -")

    sec:Separator()

    -- All Progress (dinamis, max 7 baris)
    local allLabels = {}
    for i = 1, 7 do
        allLabels[i] = sec:Label("-")
    end

    -- Background refresh thread
    task.spawn(function()
        while true do
            task.wait(1.5)
            pcall(function()
                -- Cari pet yang "on progress" (leveling atau wait_mutation)
                local active = nil
                for _, uuid in ipairs(amOrder) do
                    local p = amProgress[uuid]
                    if p and (p.status == "leveling" or p.status == "wait_mutation") then
                        active = p; break
                    end
                end

                if active then
                    pcall(function() lblName.Text    = "Name    : " .. active.name end)
                    pcall(function() lblLevel.Text   = "Level   : " .. active.age .. " / 50" end)
                    local curMut = (active.mutation ~= "") and active.mutation or "NOMUT"
                    pcall(function() lblCurrent.Text = "Current : " .. curMut end)
                    local timerStr = (active.timer ~= "-" and active.timer ~= "")
                        and active.timer or "-"
                    pcall(function()
                        lblTimer.Text = "Mutation timer : " .. timerStr
                    end)
                else
                    pcall(function() lblName.Text    = "Name    : -" end)
                    pcall(function() lblLevel.Text   = "Level   : -" end)
                    pcall(function() lblCurrent.Text = "Current : NOMUT" end)
                    pcall(function() lblTimer.Text   = "Mutation timer : -" end)
                end

                -- All Progress rows
                for i, uuid in ipairs(amOrder) do
                    local p   = amProgress[uuid]
                    local lbl = allLabels[i]
                    if lbl and p then
                        local statusStr = ({
                            waiting      = "waiting",
                            leveling     = "on progress",
                            wait_mutation = "wait mutation",
                            done         = "done ✓",
                        })[p.status] or p.status
                        pcall(function()
                            lbl.Text = p.name .. " : " .. statusStr
                        end)
                    elseif lbl then
                        pcall(function() lbl.Text = "-" end)
                    end
                end
            end)
        end
    end)
end)

-- Start
tabAM:Toggle("Start Auto Mutated", false, function(val)
    if val then
        if #AutoMutate.targetUUIDs == 0 then
            win:luluNotify("Pilih pet target dulu!", "error"); return
        end
        AutoMutate.running   = true
        AutoMutate.doneCount = 0
        AutoMutate.thread    = task.spawn(autoMutateLoop)
    else
        AutoMutate.running = false
        if AutoMutate.thread then
            task.cancel(AutoMutate.thread)
            AutoMutate.thread = nil
        end
        win:luluNotify("AutoMutate dihentikan.", "warn")
    end
end)
