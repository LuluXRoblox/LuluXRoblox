local tabAM = win:Tab("Auto Mutate")

-- ── Pet Target ──────────────────────────────────────────────
tabAM:Accordion("Pet Target", function(sec)
    -- Dropdown individual per UUID, kayak KG target
    -- Pakai State.DisplayKGTarget yang sudah di-populate dari scanAll
    local displays = State.DisplayKGTarget or {}

    local ddPet = sec:Dropdown("Chose Pets", displays, "", function(val)
        AutoMutate.targetDisplay = val
        local p = State.DisplayToPet and State.DisplayToPet[val]
        AutoMutate.targetUUID = p and p.uuid or ""
    end)

    sec:Button("Rescan Backpack", function()
        pet.scanAll()
        task.wait(0.5)
        local fresh = State.DisplayKGTarget or {}
        pcall(function() if ddPet then ddPet:SetOptions(fresh) end end)
        win:luluNotify("Rescanned!", "success")
    end)

    -- Helper Leveling — auto load dari config "mutate helper lv" (no refresh button)
    sec:Dropdown(
        "Helper Leveling",
        getConfigsByType("mutate helper lv"),
        AutoMutate.helperConfigName,
        function(val)
            AutoMutate.helperConfigName = val
            selNames.MutateHelper       = val
        end
    )
end)

-- ── Mutation Config ─────────────────────────────────────────
tabAM:Accordion("Mutation Config", function(sec)
    -- Target mutation dropdown
    sec:Dropdown("Target Mutation", MUTATIONS, MUTATIONS[1] or "", function(val)
        AutoMutate.targetMutation = val
    end)

    -- Reduce Mutation Config — auto load, tanpa toggle & tanpa refresh button
    sec:Dropdown(
        "Reduce Mutation Config",
        getConfigsByType("mutate reduce time"),
        AutoMutate.reduceConfigName,
        function(val)
            AutoMutate.reduceConfigName = val
            selNames.MutateReduce       = val
        end
    )

    -- Multi leveling 1–7
    sec:NumberInput("Multi Leveling", 1, 1, 1, 7, function(val)
        AutoMutate.multiCount = math.floor(val)
    end)
end)

-- ── Control ─────────────────────────────────────────────────
tabAM:Accordion("Control", function(sec)
    sec:Toggle("Start Auto Mutated", false, function(val)
        if val then
            if AutoMutate.targetUUID == "" then
                win:luluNotify("Pilih pet target dulu!", "error")
                return
            end
            AutoMutate.running    = true
            AutoMutate.doneCount  = 0
            AutoMutate.thread     = task.spawn(autoMutateLoop)
        else
            AutoMutate.running = false
            if AutoMutate.thread then
                task.cancel(AutoMutate.thread)
                AutoMutate.thread = nil
            end
            win:luluNotify("AutoMutate dihentikan.", "warn")
        end
    end)
end)
