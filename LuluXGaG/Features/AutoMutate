local MUTATIONS = {
    "Shocked",
    "Golden",
    "Rainbow",
    "Shiny",
    "Windy",
    "Frozen",
    "Inverted",
    "Mega",
    "Tiny",
    "Radiant",
    "Ascended",
    "Aurora",
}

-- ============================================================
-- STATE
-- ============================================================
local AutoMutate = {
    running          = false,
    thread           = nil,
    targetDisplay    = "",   -- display string yang dipilih (buat re-select)
    targetUUID       = "",   -- UUID spesifik pet target
    targetMutation   = "Rainbow",
    multiCount       = 1,
    doneCount        = 0,
    helperConfigName = selNames.MutateHelper or "",
    reduceConfigName = selNames.MutateReduce or "",
}

-- ============================================================
-- SERVICES (lokal, ga perlu dari _G)
-- ============================================================
local Players    = game:GetService("Players")
local GuiService = game:GetService("GuiService")
local VIM        = game:GetService("VirtualInputManager")
local LP         = Players.LocalPlayer
local Backpack   = LP.Backpack

-- ============================================================
-- MACHINE REFS
-- ============================================================
local proxPrompt, timerLabel

local function initRefs()
    local errMsg = ""

    -- 1. Proximity Prompt
    local okProx = pcall(function()
        local npcs    = workspace:WaitForChild("NPCS", 15)
        local machine = npcs:WaitForChild("PetMutationMachine", 15)
        local model   = machine:WaitForChild("Model", 15)
        local proxPart = model:WaitForChild("ProxPromptPart", 15)
        proxPrompt = proxPart:WaitForChild("PetMutationMachineProximityPrompt", 15)
    end)
    if not okProx then
        errMsg = errMsg .. "[AutoMutate] ProximityPrompt TIDAK DITEMUKAN!\n"
        errMsg = errMsg .. "  Path: workspace.NPCS.PetMutationMachine.Model.ProxPromptPart.PetMutationMachineProximityPrompt\n"
    end

    -- 2. Timer Label — parent dari BillboardPart tidak bernama "Part",
    --    jadi loop GetChildren() dari Model untuk cari BillboardPart
    local okTimer = pcall(function()
        local npcs    = workspace:WaitForChild("NPCS", 15)
        local machine = npcs:WaitForChild("PetMutationMachine", 15)
        local model   = machine:WaitForChild("Model", 15)
        -- Cari child mana pun di Model yang punya BillboardPart
        local billPart = nil
        for _, child in ipairs(model:GetChildren()) do
            local bp = child:FindFirstChild("BillboardPart")
            if bp then billPart = bp; break end
        end
        if not billPart then
            -- Fallback: coba recursive
            billPart = model:FindFirstChild("BillboardPart", true)
        end
        if not billPart then error("BillboardPart not found") end
        timerLabel = billPart
            :WaitForChild("BillboardGui", 15)
            :WaitForChild("TimerTextLabel", 15)
    end)
    if not okTimer then
        errMsg = errMsg .. "[AutoMutate] TimerTextLabel TIDAK DITEMUKAN!\n"
        errMsg = errMsg .. "  Pastikan ada BillboardPart di salah satu child dari:\n"
        errMsg = errMsg .. "  workspace.NPCS.PetMutationMachine.Model:GetChildren()\n"
    end

    if errMsg ~= "" then
        warn(errMsg)
    end

    return okProx and okTimer
end

-- ============================================================
-- HELPERS
-- ============================================================

-- Cari semua pet di backpack berdasarkan nama display
local function findAllPetsByName(displayName)
    local result = {}
    for _, p in ipairs(State.AllPets or {}) do
        if p.name == displayName then
            table.insert(result, p)
        end
    end
    return result
end

-- Ambil nama terbaru pet berdasarkan UUID (dari Backpack instance)
local function getPetNameByUUID(targetUUID)
    for _, item in ipairs(Backpack:GetChildren()) do
        local ok, name = pcall(function()
            local uuid = item:GetAttribute("PET_UUID") or item.Name
            if uuid == targetUUID then
                return item:GetAttribute("f") or ""
            end
        end)
        if ok and type(name) == "string" and name ~= "" then
            return name
        end
    end
    return nil
end

-- Ekstrak mutasi: "Rainbow Seal", base "Seal" → "Rainbow"
local function extractMutation(fullName, baseName)
    if fullName == baseName then return "" end
    local suffix = " " .. baseName
    if fullName:sub(-#suffix) == suffix then
        return fullName:sub(1, #fullName - #suffix):match("^%s*(.-)%s*$") or ""
    end
    return ""
end

-- Klik tombol konfirmasi di GenericConfirmationPrompt (retry max 5x)
local function clickConfirm()
    for _ = 1, 5 do
        local ok = pcall(function()
            local prompt = LP.PlayerGui:FindFirstChild("GenericConfirmationPrompt")
            if not prompt then error("no prompt") end
            local btn   = prompt.Main.Buttons.Confirm
            local inset = GuiService:GetGuiInset()
            local pos   = btn.AbsolutePosition + btn.AbsoluteSize / 2
            local cx    = pos.X + inset.X + 15
            local cy    = pos.Y + inset.Y
            VIM:SendMouseButtonEvent(cx, cy, 0, true,  game, 1)
            task.wait(0.1)
            VIM:SendMouseButtonEvent(cx, cy, 0, false, game, 1)
        end)
        if ok then return true end
        task.wait(0.5)
    end
    warn("[AutoMutate] clickConfirm: prompt tidak muncul setelah 5x retry")
    return false
end

-- Tunggu timer mesin selesai — dua fase:
--   Fase 1: tunggu timer punya isi (pet baru masuk mesin)
--   Fase 2: tunggu timer habis / ready (mutasi selesai)
local function waitTimerReady(timeout)
    timeout = timeout or 300

    -- Fase 1: tunggu sampai timer ada isinya (mesin mulai jalan)
    local t1 = 0
    local FILL_TIMEOUT = 15  -- maks 15 detik nunggu timer muncul
    while t1 < FILL_TIMEOUT and AutoMutate.running do
        local txt = timerLabel and timerLabel.Text or ""
        if txt ~= "" then break end  -- timer sudah ada isi → lanjut fase 2
        task.wait(0.5)
        t1 = t1 + 0.5
    end

    if not AutoMutate.running then return false end

    -- Fase 2: tunggu sampai timer kosong / 0 / ready (mutasi selesai)
    local t2 = 0
    while t2 < timeout and AutoMutate.running do
        local txt = timerLabel and timerLabel.Text or ""
        if txt == "" or txt == "0" or txt == "0s" or txt:lower() == "ready" then
            return true
        end
        task.wait(1)
        t2 = t2 + 1
    end

    return false
end

-- Load reduce-time loadout (config type: "mutate reduce time", file: selected by user)
local function loadReduceLoadout()
    local configName = AutoMutate.reduceConfigName
    if configName == "" then
        win:luluNotify("Reduce Time: belum pilih config di Mutation Config!", "warn")
        return
    end
    local uuids = getConfigUUIDs("mutate reduce time", configName)
    if #uuids > 0 then
        pet.equipList(uuids)
    else
        win:luluNotify("Reduce Time: config '" .. configName .. "' kosong!", "warn")
    end
end

-- Pegang pet di tangan karakter (bukan equip ke garden)
-- Sama seperti AutoEgg sell from hand: cari Tool di Backpack lalu hum:EquipTool
local function holdPetInHand(petUUID)
    local ch  = LP.Character
    local hum = ch and ch:FindFirstChildOfClass("Humanoid")
    if not ch or not hum then
        warn("[AutoMutate] holdPetInHand: Character/Humanoid tidak ditemukan!")
        return false
    end
    -- Cari Tool di Backpack berdasarkan UUID
    local tool = nil
    for _, item in ipairs(Backpack:GetChildren()) do
        if item:IsA("Tool") then
            local u = item:GetAttribute("PET_UUID") or item.Name
            if u == petUUID then tool = item; break end
        end
    end
    if not tool then
        warn("[AutoMutate] holdPetInHand: Tool UUID " .. petUUID .. " tidak ada di Backpack!")
        return false
    end
    pcall(function() hum:EquipTool(tool) end)
    return true
end


local function processMutation(petUUID)
    -- 1. Unequip semua dari garden
    pet.unequipAllActive()
    task.wait(0.5)

    -- 2. PEGANG pet target di tangan (bukan equip ke garden!)
    --    hum:EquipTool → sama seperti AutoEgg sell from hand
    local held = holdPetInHand(petUUID)
    if not held then
        win:luluNotify("AutoMutate: Gagal pegang pet!", "error")
        return false, ""
    end
    task.wait(1)

    -- 3. Prompt mesin → buka UI mesin mutasi
    fireproximityprompt(proxPrompt)
    task.wait(2)

    -- 4. Konfirmasi → pet masuk mesin
    clickConfirm()
    task.wait(0.5)

    -- 5. Prompt mesin kedua → tutup/submit UI
    fireproximityprompt(proxPrompt)
    task.wait(1)

    -- 6. Pet sudah di mesin → equip helper reduce time ke garden
    if AutoMutate.reduceConfigName ~= "" then
        loadReduceLoadout()
    end

    -- 7. Tunggu timer selesai
    local ready = waitTimerReady(300)
    if not ready then
        win:luluNotify("AutoMutate: Timer timeout!", "error")
        return false, ""
    end

    -- 8. Unequip reduce time helpers
    pet.unequipAllActive()
    task.wait(0.5)

    -- 9. Prompt mesin → ambil pet hasil mutasi (cukup fire, tanpa klik confirm)
    fireproximityprompt(proxPrompt)

    -- 10. Jeda sebelum cek hasil (atur dari sini)
    task.wait(5)

    -- 11. Lepas yang dipegang di tangan
    local ch  = LP.Character
    local hum = ch and ch:FindFirstChildOfClass("Humanoid")
    if hum then pcall(function() hum:UnequipTools() end) end
    task.wait(0.5)

    -- 12. Scan ulang untuk cek nama baru
    pet.scanAll()
    task.wait(0.5)

    local newName = getPetNameByUUID(petUUID)
    return true, newName or ""
end

-- ============================================================
-- MAIN LOOP
-- ============================================================
local function autoMutateLoop()
    if not initRefs() then
        win:luluNotify("AutoMutate: Mesin mutasi tidak ditemukan!", "error")
        AutoMutate.running = false
        return
    end

    win:luluNotify("AutoMutate dimulai...", "info")
    AutoMutate.doneCount = 0

    -- Ambil UUIDs helper leveling dari config "mutate helper lv"
    local helperUUIDs = {}
    if AutoMutate.helperConfigName ~= "" then
        helperUUIDs = getConfigUUIDs("mutate helper lv", AutoMutate.helperConfigName)
    end
    if #helperUUIDs == 0 then
        win:luluNotify("AutoMutate: Helper kosong, leveling tanpa helper!", "warn")
    end

    local needed = AutoMutate.multiCount

    while AutoMutate.running and AutoMutate.doneCount < needed do
        -- Refresh scan
        pet.scanAll()
        task.wait(0.3)

        -- Ambil pet target langsung dari UUID (bukan cari by name → ga miss)
        local targetUUID = AutoMutate.targetUUID
        if not targetUUID or targetUUID == "" then
            win:luluNotify("AutoMutate: Belum pilih pet target!", "warn")
            break
        end

        local target = nil
        for _, p in ipairs(State.AllPets or {}) do
            if p.uuid == targetUUID then target = p; break end
        end

        if not target then
            win:luluNotify("AutoMutate: Pet target ga ditemukan di backpack!", "warn")
            break
        end

        local baseName = target.name

        -- === LEVELING PHASE ===
        pet.unequipAllActive()
        task.wait(0.5)

        local toEquip = { target.uuid }
        for _, uid in ipairs(helperUUIDs) do
            table.insert(toEquip, uid)
        end
        pet.equipList(toEquip)
        task.wait(1)

        win:luluNotify("Leveling " .. baseName .. " → target 50...", "info")

        local levelTimeout = 300
        local elapsed = 0
        while elapsed < levelTimeout and AutoMutate.running do
            local age = pet.getAge(target.uuid)
            if age >= 50 then break end
            task.wait(2)
            elapsed = elapsed + 2
        end

        if not AutoMutate.running then break end

        -- === MUTATION PHASE ===
        win:luluNotify("Age 50! Masuk mesin mutasi...", "info")

        local ok, newName = processMutation(target.uuid)
        if not ok then break end

        local mutation = extractMutation(newName, baseName)
        local mutLabel = mutation ~= "" and mutation or "None"

        win:luluNotify("Hasil: " .. mutLabel .. " (" .. newName .. ")", "info")

        if mutation == AutoMutate.targetMutation then
            AutoMutate.doneCount = AutoMutate.doneCount + 1
            win:luluNotify("✓ " .. baseName .. " → " .. newName
                .. " [" .. AutoMutate.doneCount .. "/" .. needed .. "]", "success")
        else
            win:luluNotify("Bukan target (" .. AutoMutate.targetMutation
                .. "), lanjut ke pet berikutnya...", "warn")
        end

        task.wait(2)
    end

    AutoMutate.running = false
    win:luluNotify(
        "AutoMutate selesai! Done: "
        .. AutoMutate.doneCount .. "/" .. needed,
        "success"
    )
end

