-- Mutation result from Notification event
-- Pattern: "<font...>PetName</font> mutated into <font...>MutationType</font>"
local mutResult = { pending = false, petName = "", mutation = "" }
local mutNotifConn = nil

local function connectMutNotif()
    if mutNotifConn then return end
    local GE = RS:FindFirstChild("GameEvents")
    if not GE then return end
    local notif = GE:FindFirstChild("Notification")
    if not notif then return end
    mutNotifConn = notif.OnClientEvent:Connect(function(msg)
        if type(msg) ~= "string" then return end
        -- Strip HTML tags
        local stripped = msg:gsub("<[^>]+>", ""):match("^%s*(.-)%s*$")
        -- Match "PetName mutated into MutationType"
        local petName, mutType = stripped:match("^(.+) mutated into (.+)$")
        if petName and mutType then
            mutResult.pending  = true
            mutResult.petName  = petName:match("^%s*(.-)%s*$")
            mutResult.mutation = mutType:match("^%s*(.-)%s*$")
        end
    end)
end

