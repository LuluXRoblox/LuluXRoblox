ShopSection("seed", "Seed Shop")
ShopSection("gear", "Gear Shop")
ShopSection("egg",  "Egg Shop")

tabShop:Label("-- Settings --")
tabShop:NumberInput("Buy All Delay (s)",  10,  1, 1,  60, function(v) BuyAllDelay  = v end)
