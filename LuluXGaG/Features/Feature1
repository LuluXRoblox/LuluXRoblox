            for name in pairs(ShopData[key]) do
                if not BuyAllEnabled[key] then break end
                total = total + BuyItem(key, name); task.wait(0.5)
            end
            if total > 0 then win:luluNotify("Bought "..total.."x from "..key, "success") end
            local t=0; while t<BuyAllDelay and BuyAllEnabled[key] do task.wait(1); t=t+1 end
        end
        buyAllThreads[key]=nil
    end)
end

local function StartAutoBuy(key)
    if autoBuyThreads[key] then return end
    AutoBuyEnabled[key] = true
    autoBuyThreads[key] = task.spawn(function()
        while AutoBuyEnabled[key] do
            for _, name in ipairs(SelectedItems[key]) do
                if not AutoBuyEnabled[key] then break end
                BuyItem(key, name); task.wait(AutoBuyDelay)
            end
            if #SelectedItems[key] == 0 then task.wait(1) end
        end
        autoBuyThreads[key]=nil
    end)
end

-- ── UI helpers ───────────────────────────────────────────────
local function ShopSection(key, label)
    local keys = {}
    for k in pairs(ShopData[key]) do table.insert(keys, k) end
    table.sort(keys)

    tabShop:Label("-- " .. label .. " --")

    tabShop:MultiDropdown("Select "..label, keys, {}, function(sel)
        SelectedItems[key] = sel
    end)

    tabShop:Toggle("Buy All "..label, false, function(on)
        if on then StartBuyAll(key) else StopBuyAll(key) end
    end)

    tabShop:Toggle("Auto Buy "..label, false, function(on)
        if on then
            if #SelectedItems[key]==0 then win:luluNotify("Select items first!","warning"); return end
            StartAutoBuy(key)
        else StopAutoBuy(key) end
    end)

    tabShop:Button("Buy Selected Now", function()
        if #SelectedItems[key]==0 then win:luluNotify("Select items first!","warning"); return end
        task.spawn(function()
            local total=0
            for _, name in ipairs(SelectedItems[key]) do total=total+BuyItem(key,name) end
            win:luluNotify("Bought total x"..total, "success")
        end)
    end)
end

