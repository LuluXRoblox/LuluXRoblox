local LP_AB = game:GetService("Players").LocalPlayer

local function GetStock(key, itemName)
    local count = 0
    pcall(function()
        local guiNames = {seed="Seed_Shop", gear="Gear_Shop", egg="PetShop_UI"}
        local gui = LP_AB:WaitForChild("PlayerGui"):FindFirstChild(guiNames[key])
        if not gui then return end
        local sf = gui:FindFirstChild("Frame") and gui.Frame:FindFirstChild("ScrollingFrame")
        if not sf then return end
        local frame = sf:FindFirstChild(itemName)
        if not frame then return end
        local lbl = frame:FindFirstChild("Main_Frame") and frame.Main_Frame:FindFirstChild("Stock_Text")
        if not lbl then return end
        count = tonumber(lbl.Text:match("[Xx]%s*(%d+)")) or tonumber(lbl.Text:match("%d+")) or 0
    end)
    return count
end

local function BuyItem(key, itemName)
    local n = GetStock(key, itemName)
    if n <= 0 then return 0 end
    local fire = ShopFire[key]
    for _ = 1, n do fire(itemName); task.wait(0.4) end
    if n > 0 and G.sendWebhook and G.Webhook and G.Webhook.AB then
        G.sendWebhook({
            title="Auto Buy",
            description="Bought **"..n.."x "..itemName.."**",
            color=0x5865F2,
        })
    end
    return n
end

