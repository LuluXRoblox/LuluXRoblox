local function clickConfirm()
    for _ = 1, 5 do
        local ok = pcall(function()
            local prompt = LP.PlayerGui:FindFirstChild("GenericConfirmationPrompt")
            if not prompt then error("no prompt") end
            local btn   = prompt.Main.Buttons.Confirm
            local inset = GuiService:GetGuiInset()
            local pos   = btn.AbsolutePosition + btn.AbsoluteSize/2
            VIM:SendMouseButtonEvent(pos.X+inset.X+15,pos.Y+inset.Y,0,true,game,1)
            task.wait(0.1)
            VIM:SendMouseButtonEvent(pos.X+inset.X+15,pos.Y+inset.Y,0,false,game,1)
        end)
        if ok then return true end
        task.wait(0.5)
    end
    return false
end

local function waitTimerReady(uuid, timeout)
    timeout = timeout or 300
    -- Tunggu timer muncul dulu
    local t1 = 0
    while t1 < 15 and AutoMutate.running do
        if (timerLabel and timerLabel.Text or "") ~= "" then break end
        task.wait(0.5); t1 += 0.5
    end
    if not AutoMutate.running then return false end
    local t2 = 0
    while t2 < timeout and AutoMutate.running do
        local txt = timerLabel and timerLabel.Text or ""
        if txt == "" or txt == "0" or txt == "0s" or txt:lower() == "ready" then return true end
        -- Update timer di info panel
        if amProgress[uuid] then amProgress[uuid].timer = txt end
        task.wait(1); t2 += 1
    end
    return false
end

local function loadReduceLoadout()
    local name = AutoMutate.reduceConfigName
    if name == "" then return end
    local uuids = getConfigUUIDs("mutate reduce time", name)
    if #uuids > 0 then pet.safeEquipLoad(uuids)
    else win:luluNotify("Reduce: config '" .. name .. "' kosong!", "warn") end
end

-- ============================================================
-- PROSES MUTASI
-- "Pegang" pet = safeEquipLoad hanya UUID itu (equip as active)
-- ============================================================
local function holdPet(petUUID)
    -- Unequip semua dulu, tunggu pet balik ke Backpack
    pet.safeEquipLoad({}); task.wait(0.8)
    local ch  = LP.Character
    local hum = ch and ch:FindFirstChildOfClass("Humanoid")
    if not ch or not hum then return false end
    -- Cari Tool pet di Backpack
    local tool = nil
    for i = 1, 5 do   -- retry sampai 5x (mungkin belum sync)
        for _, item in ipairs(Backpack:GetChildren()) do
            if item:IsA("Tool") and item:GetAttribute("PET_UUID") == petUUID then
                tool = item; break
            end
        end
        if tool then break end
        task.wait(0.4)
    end
    if not tool then
        warn("[AutoMutate] holdPet: tool UUID " .. petUUID .. " tidak ditemukan di Backpack")
        return false
    end
    pcall(function() hum:EquipTool(tool) end)
    task.wait(0.5)
    return true
end

local function processMutation(petUUID)
    -- 1. Hold target pet in hand
    if not holdPet(petUUID) then
        win:luluNotify("AutoMutate: Failed to hold pet!", "error")
        return false, ""
    end

    -- 2. Open machine -> confirm -> submit
    fireproximityprompt(proxPrompt); task.wait(3)
    clickConfirm();                   task.wait(0.5)
    fireproximityprompt(proxPrompt); task.wait(1)

    -- 3. Machine running -> equip reduce helpers
    if AutoMutate.reduceConfigName ~= "" then loadReduceLoadout() end

    -- 4. Wait for timer
    if not waitTimerReady(petUUID, 300) then
        win:luluNotify("AutoMutate: Timer timeout!", "error")
        return false, ""
    end

    -- 5. Release held pet after 10s
    task.wait(10)
    local ch  = LP.Character
    local hum = ch and ch:FindFirstChildOfClass("Humanoid")
    if hum then pcall(function() hum:UnequipTools() end) end
    pet.safeEquipLoad({}); task.wait(0.5)

    -- 6. Claim mutation result via FireServer
    mutResult.pending = false
    local GE = RS:FindFirstChild("GameEvents")
    local mutSvc = GE and GE:FindFirstChild("PetMutationMachineService_RE")
    if mutSvc then
        pcall(function() mutSvc:FireServer("ClaimMutatedPet") end)
    else
        fireproximityprompt(proxPrompt)  -- fallback
    end

    -- 7. Wait for mutation notification (max 8s)
    local t = 0
    while t < 8 and not mutResult.pending and AutoMutate.running do
        task.wait(0.5); t = t + 0.5
    end

    local mutation = mutResult.pending and mutResult.mutation or ""
    mutResult.pending = false
    task.wait(0.5)
    return true, mutation
end

-- ============================================================
-- INFO PANEL UPDATE
-- ============================================================
local function updateInfoPanel()
    -- On Progress: pet yang sedang diproses
    local active = nil
    for _, uuid in ipairs(amOrder) do
        local p = amProgress[uuid]
        if p and (p.status == "leveling" or p.status == "wait_mutation") then
            active = p; break
        end
    end

    grp.AMInfo:Clear()
    if active then
        grp.AMInfo:Show()
        grp.AMInfo:Header("On Progress")
        grp.AMInfo:QuestLine("Name",    active.name)
        grp.AMInfo:QuestLine("Level",   active.age .. " / 50")
        local curMut = (active.mutation ~= "") and active.mutation or "NOMUT"
        grp.AMInfo:QuestLine("Current", curMut)
        local timerStr = (active.status == "wait_mutation" and active.timer ~= "-")
            and active.timer or "-"
        grp.AMInfo:QuestLine("Timer",   timerStr)
    else
        grp.AMInfo:Hide()
    end

    -- All Progress
    grp.AMAll:Clear()
    if #amOrder > 0 then
        grp.AMAll:Show()
        grp.AMAll:Header("All Progress")
        for _, uuid in ipairs(amOrder) do
            local p = amProgress[uuid]
            if p then
                local s = ({
                    waiting      = "waiting",
                    leveling     = "on progress",
                    wait_mutation = "wait mutation",
                    done         = "done",
                })[p.status] or p.status
                grp.AMAll:QuestLine(p.name, s)
            end
        end
    else
        grp.AMAll:Hide()
    end
end

-- ============================================================
-- MAIN LOOP
-- ============================================================
local function autoMutateLoop()
    if not initRefs() then
        win:luluNotify("AutoMutate: Machine not found!", "error")
        AutoMutate.running = false; return
    end

    win:luluNotify("AutoMutate started...", "info")
    AutoMutate.doneCount = 0

    local helperUUIDs = {}
    if AutoMutate.helperConfigName ~= "" then
        helperUUIDs = getConfigUUIDs("mutate helper lv", AutoMutate.helperConfigName)
    end

    -- Init progress
    amProgress = {}; amOrder = {}
    for _, uuid in ipairs(AutoMutate.targetUUIDs) do
        local info = nil
        for _, p in ipairs(amPetList) do if p.uuid == uuid then info = p; break end end
        amProgress[uuid] = {
            name=info and info.baseName or uuid,
            status="waiting", age=0, mutation="", timer="-",
        }
        table.insert(amOrder, uuid)
    end
    updateInfoPanel()

    local needed = AutoMutate.multiCount
    local petIdx = 1

    while AutoMutate.running and AutoMutate.doneCount < needed do
        if #AutoMutate.targetUUIDs == 0 then
            win:luluNotify("No target pet selected!", "warn"); break
        end

        local uuid = AutoMutate.targetUUIDs[petIdx]
        petIdx = (petIdx % #AutoMutate.targetUUIDs) + 1

        -- Skip yang sudah done
        if amProgress[uuid] and amProgress[uuid].status == "done" then
            task.wait(0.3); continue
        end

        -- Ambil info pet
        local petInfo = nil
        for _, p in ipairs(amPetList) do if p.uuid == uuid then petInfo = p; break end end
        if not petInfo then
            amScanPets(); task.wait(0.3)
            for _, p in ipairs(amPetList) do if p.uuid == uuid then petInfo = p; break end end
        end
        if not petInfo then
            win:luluNotify("Pet not found in backpack, skipping!", "warn")
            task.wait(1); continue
        end

        local baseName = petInfo.baseName
        local baseAttr = petInfo.baseAttr
        local petType  = (State.UUIDToType and State.UUIDToType[uuid]) or ""

        -- Inner retry loop: ulangi leveling → mutasi sampai done
        local petDone = false
        while AutoMutate.running and not petDone do

            -- === LEVELING ===
            amProgress[uuid].status = "leveling"
            amProgress[uuid].age    = 0
            updateInfoPanel()

            -- Equip target + helpers (kalau retry, pet sudah di garden, helpers ditambah)
            local toEquip = { uuid }
            for _, uid in ipairs(helperUUIDs) do table.insert(toEquip, uid) end
            pet.safeEquipLoad(toEquip); task.wait(1)
            win:luluNotify("Leveling " .. baseName .. " → 50...", "info")

            local elapsed = 0
            while elapsed < 300 and AutoMutate.running do
                local age = amGetAge(uuid, baseAttr, petType)
                amProgress[uuid].age = age
                updateInfoPanel()
                if age >= 50 then break end
                task.wait(2); elapsed += 2
            end

            if not AutoMutate.running then break end

            -- === MUTASI ===
            amProgress[uuid].status = "wait_mutation"
            amProgress[uuid].timer  = "..."
            updateInfoPanel()

            win:luluNotify("Age 50! Entering machine...", "info")
            local ok, mutation = processMutation(uuid)
            if not ok then break end

            -- Mutation result from Notification event (no backpack/garden scan needed)
            local mutLabel = (mutation ~= "") and mutation or "NOMUT"
            amProgress[uuid].mutation = mutLabel
            amProgress[uuid].timer    = "-"

            win:luluNotify("Result: " .. mutLabel .. " (" .. baseName .. ")", "info")

            -- Check if any target mutation is contained in the result
            -- e.g. target = "Rainbow", result = "Rainbow" -> hit
            local targetHit = false
            if #AutoMutate.targetMutations == 0 then
                targetHit = (mutation ~= "")
            else
                for _, tm in ipairs(AutoMutate.targetMutations) do
                    if mutation:lower():find(tm:lower(), 1, true) then
                        targetHit = true; break
                    end
                end
            end

            if targetHit then
                petDone = true
                AutoMutate.doneCount += 1
                amProgress[uuid].status = "done"
                updateInfoPanel()
                pet.safeEquipLoad({})
                win:luluNotify("[done] " .. baseName .. " -> " .. mutation
                    .. " [" .. AutoMutate.doneCount .. "/" .. needed .. "]", "success")
            else
                -- Not target -> equip helpers, retry leveling
                amProgress[uuid].status   = "leveling"
                amProgress[uuid].mutation = ""
                updateInfoPanel()
                local ts = #AutoMutate.targetMutations > 0
                    and table.concat(AutoMutate.targetMutations, "/") or "any"
                win:luluNotify("Not target (" .. ts .. "), retry leveling...", "warn")
            end
        end

        amScanPets(); task.wait(1)
    end

    AutoMutate.running = false
    grp.AMInfo:Hide(); grp.AMAll:Hide()
    win:luluNotify("Done: " .. AutoMutate.doneCount .. "/" .. needed, "success")
end

