-- AM PET SCAN (dari Backpack, format "Rainbow Hootsie Roll [0.95 KG]")
-- ============================================================
local amPetList     = {}
local amDisplayList = {}
local amDispToUUID  = {}

local function amScanPets()
    amPetList = {}; amDisplayList = {}; amDispToUUID = {}
    for _, item in ipairs(Backpack:GetChildren()) do
        local uuid = item:GetAttribute("PET_UUID")
        if not uuid then continue end
        local fullName    = item.Name
        local displayName = fullName:gsub("%s*%[Age %d+%]",""):match("^%s*(.-)%s*$")
        local baseName    = displayName:gsub("%s*%[%d+%.?%d* KG%]",""):match("^%s*(.-)%s*$")
        local baseAttr    = item:GetAttribute("f") or baseName
        if not amDispToUUID[displayName] then
            amDispToUUID[displayName] = uuid
            table.insert(amDisplayList, displayName)
        end
        table.insert(amPetList, {
            uuid=uuid, displayName=displayName,
            baseName=baseName, baseAttr=baseAttr, fullName=fullName,
        })
    end
end

-- ============================================================
-- AGE — scan ActivePetUI by PET_TYPE/PET_NAME (bukan UUID)
-- ============================================================
local function amReadAge(m)
    if not m then return 0 end
    local obj = m:FindFirstChild("PET_AGE")
    if obj then
        if obj:IsA("TextLabel") or obj:IsA("TextBox") then
            return tonumber(obj.Text) or tonumber(obj.Text:match("%d+")) or 0
        elseif obj:IsA("IntValue") or obj:IsA("NumberValue") then
            return tonumber(obj.Value) or 0
        elseif obj:IsA("Frame") then
            for _, c in ipairs(obj:GetChildren()) do
                if c:IsA("TextLabel") or c:IsA("TextBox") then
                    local v = tonumber(c.Text) or tonumber(c.Text:match("%d+"))
                    if v then return v end
                end
            end
        end
    end
    return tonumber(m:GetAttribute("Age")) or tonumber(m:GetAttribute("PET_AGE")) or 0
end

local function amGetAge(uuid, baseAttr, petType)
    local age = 0
    pcall(function()
        local display = pet.getPetDisplay()
        for _, child in ipairs(display:GetChildren()) do
            if not child:IsA("Frame") then continue end
            local m = child:FindFirstChild("Main")
            if not m then continue end
            -- 1. Frame name == UUID (kalau cocok)
            if child.Name == uuid then
                age = amReadAge(m); if age > 0 then return end
            end
            -- 2. PET_TYPE match
            local typeL = m:FindFirstChild("PET_TYPE")
            if petType ~= "" and typeL and typeL.Text == petType then
                age = amReadAge(m); if age > 0 then return end
            end
            -- 3. PET_NAME match (fallback)
            local nameL = m:FindFirstChild("PET_NAME")
            if nameL and nameL.Text == baseAttr then
                age = amReadAge(m); if age > 0 then return end
            end
        end
    end)
    return age
end

-- ============================================================
-- MUTATION DETECTION (dari Backpack item name setelah mutasi)
-- ============================================================
local function amGetMutation(uuid, baseAttr)
    for _, item in ipairs(Backpack:GetChildren()) do
        if item:GetAttribute("PET_UUID") == uuid then
            local stripped = item.Name
                :gsub("%s*%[Age %d+%]","")
                :gsub("%s*%[%d+%.?%d* KG%]","")
                :match("^%s*(.-)%s*$")
            if stripped == baseAttr then return "" end
            local suffix = " " .. baseAttr
            if stripped:sub(-#suffix) == suffix then
                return stripped:sub(1, #stripped-#suffix):match("^%s*(.-)%s*$") or ""
            end
            return ""
        end
    end
    return nil
end

