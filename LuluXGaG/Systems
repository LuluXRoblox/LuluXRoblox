local function removeOtherGarden()
    local farmRoot = workspace:FindFirstChild("Farm")
    if not farmRoot then return false end
    local removed = false
    for _, farm in ipairs(farmRoot:GetChildren()) do
        if farm.Name == "Farm" then
            local owner; pcall(function() owner = farm.Important.Data.Owner.Value end)
            if owner and owner ~= player.Name then farm:Destroy(); removed = true end
        end
    end
    return removed
end

