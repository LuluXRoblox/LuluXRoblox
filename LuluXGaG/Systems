end

local function espGetLabels(bill)
    local frame = bill:FindFirstChildOfClass("Frame")
    if not frame then return nil, nil end
    return frame:FindFirstChild("LblTop"), frame:FindFirstChild("LblBot")
end

local function espSetFrame(bill, bgColor, bgAlpha)
    local frame = bill:FindFirstChildOfClass("Frame")
