local function aeGetReadyEggObjects()
    local result = {}
    pcall(function()
        for _, farm in ipairs(workspace.Farm:GetChildren()) do
            local objPhys = farm:FindFirstChild("Objects_Physical", true)
            if not objPhys then continue end
            for _, obj in ipairs(objPhys:GetChildren()) do
                if obj:GetAttribute("OBJECT_TYPE") == "PetEgg"
                and aeIsMyEgg(obj:GetAttribute("OWNER")) then
                    local rawUUID = obj:GetAttribute("OBJECT_UUID")
                    if rawUUID then
                        local uuid = aeNormUUID(rawUUID)
                        local mon  = HatchMonitor[uuid]
                        if mon and (mon.readyNotified or mon.canHatch) then
                            table.insert(result, { obj = obj, uuid = uuid, mon = mon })
                        elseif not mon then
                            -- Egg placed before script started — no monitor data, treat as good hatch
                            table.insert(result, { obj = obj, uuid = uuid, mon = nil, noData = true })
                        end
                    end
                end
            end
        end
    end)
    return result
end

local function startAutoEgg()
    if AutoEgg.Running then return end
    AutoEgg.Running = true
    AutoEgg.Thread  = task.spawn(function()
        while AutoEgg.Running do
            -- STEP 1-2: Equip Reduce Time loadout
            unequipAllActive(); task.wait(0.5)
            if #AutoEgg.ReduceTimeUUIDs > 0 then
                safeEquipLoad(AutoEgg.ReduceTimeUUIDs)
            end
            -- STEP 3: Plant eggs up to MaxPlace
            local placed = aeCountMyEggs()
            if placed < AutoEgg.MaxPlace and #AutoEgg.ChosenEggs > 0 then
                task.wait(1)
                aePlantBatch(AutoEgg.MaxPlace - placed)
                -- Track eggs re-placed
                local newPlaced = aeCountMyEggs()
                AEStats.eggReturn = AEStats.eggReturn + math.max(0, newPlaced - placed)
            end

            -- STEP 4: Wait for all eggs to be ready (max 5 min timeout)
            -- Catatan: jangan break hanya karena curPlaced == 0 sekali saja
            -- (bisa false-negative saat farm belum sync). Double-check dulu.
            local waitStart4   = tick()
            local zeroStreak   = 0          -- hitung berapa kali berturut-turut dapat 0
            local ZERO_CONFIRM = 3          -- butuh 3x berturut-turut baru dianggap beneran kosong
            while AutoEgg.Running do
                local curPlaced = aeCountMyEggs()
                local readyNow  = aeGetReadyEggObjects()
                if curPlaced > 0 and #readyNow >= curPlaced then break end
                if curPlaced == 0 then
                    zeroStreak += 1
                    if zeroStreak >= ZERO_CONFIRM then break end  -- benar-benar kosong
                else
                    zeroStreak = 0  -- reset jika count kembali > 0
                end
                if tick() - waitStart4 > 300 then break end  -- 5 min max
                task.wait(2)
            end
            if not AutoEgg.Running then break end

            -- STEP 5: Unequip reduce-time pets
            unequipAllActive(); task.wait(0.5)

            local readyList = aeGetReadyEggObjects()
            if #readyList == 0 then task.wait(2); continue end

            -- Track total hatched this cycle
            AEStats.hatchTotal = AEStats.hatchTotal + #readyList

            -- Categorise eggs
            local normalEggs, goodEggs = {}, {}
            for _, entry in ipairs(readyList) do
                local baseWt     = (entry.mon and entry.mon.baseWeight) or 0
                local isUnknown  = entry.noData or (baseWt == 0)
                local petName    = (entry.mon and entry.mon.petName) or ""
                local inGoodList = false
                for _, gn in ipairs(AutoEgg.GoodHatchPets) do
                    if petName ~= "" and petName:lower():find(gn:lower(), 1, true) then
                        inGoodList = true; break
                    end
                end
                local isGood = inGoodList or isUnknown or ((AutoEgg.MinGoodHatch > 0) and (baseWt >= AutoEgg.MinGoodHatch))
                if isGood then table.insert(goodEggs, entry)
                else            table.insert(normalEggs, entry) end
            end

            -- Track good hatch count
            AEStats.goodHatch = AEStats.goodHatch + #goodEggs

            -- Snapshot Backpack SEBELUM semua hatch
            local snapshotUUIDs = {}
            for _, item in ipairs(LP.Backpack:GetChildren()) do
                snapshotUUIDs[item:GetAttribute("PET_UUID") or item.Name] = true
            end

            -- STEP 6-8: Hatch normal eggs
            if #normalEggs > 0 then
                if #AutoEgg.HatchEggUUIDs > 0 then
                    safeEquipLoad(AutoEgg.HatchEggUUIDs)
                end
                AutoEgg.LastLoadWasGoodHatch = false
                task.wait(1.5)  -- jeda sebelum mulai hatch normal
                for _, entry in ipairs(normalEggs) do
                    if not AutoEgg.Running then break end
                    aeHatchEgg(entry.obj); task.wait(0.1)
                    HatchMonitor[entry.uuid] = nil
                end
                unequipAllActive(); task.wait(0.5)
            end

            -- STEP 9-11: Hatch good eggs
            if #goodEggs > 0 then
                if not AutoEgg.LastLoadWasGoodHatch and #AutoEgg.GoodHatchUUIDs > 0 then
                    safeEquipLoad(AutoEgg.GoodHatchUUIDs)
                    AutoEgg.LastLoadWasGoodHatch = true
                end
                task.wait(1.5)
                -- Snapshot before good hatch for DC notification
                local preGoodSnap = {}
                for _, item in ipairs(LP.Backpack:GetChildren()) do
                    preGoodSnap[item:GetAttribute("PET_UUID") or item.Name] = true
                end
                for _, entry in ipairs(goodEggs) do
                    if not AutoEgg.Running then break end
                    aeHatchEgg(entry.obj); task.wait(0.1)
                    HatchMonitor[entry.uuid] = nil
                end
                unequipAllActive(); task.wait(1)
                AutoEgg.LastLoadWasGoodHatch = false
                -- DC: send each newly hatched good pet
                if Webhook.AE then
                    task.spawn(function()
                        task.wait(1)
                        for _, item in ipairs(LP.Backpack:GetChildren()) do
                            local uuid = item:GetAttribute("PET_UUID") or item.Name
                            if preGoodSnap[uuid] then continue end
                            if item:GetAttribute("PetType") ~= "Pet" then continue end
                            local petName = item:GetAttribute("f") or ""
                            local parsed  = parseName(item.Name)
                            local kg      = parsed.kg or "?"
                            sendWebhookEmbed({
                                title       = "Good Hatch",
                                description = "**You get " .. petName .. "**\nCurrent: " .. kg .. " KG",
                                color       = 0x57F287,
                                footer      = { text = "LuluXGAG " .. SCRIPT_VERSION },
                                timestamp   = os.date("!%Y-%m-%dT%H:%M:%S"),
                            })
                            task.wait(0.3)
                        end
                    end)
                end
            end

            -- STEP 12-14: Sell berdasarkan berat vs MinGoodHatch (berlaku untuk semua hatch)
            -- Tidak di-sell: tidak ada di dropdown, atau weight >= MinGoodHatch
            if #AutoEgg.SellingUUIDs > 0 and #AutoEgg.SellPets > 0 then
                local ch  = LP.Character
                local hum = ch and ch:FindFirstChildOfClass("Humanoid")
                if hum then hum:UnequipTools(); task.wait(0.3) end  -- pastikan pet masuk Backpack

                local newPets = {}
                for _, item in ipairs(LP.Backpack:GetChildren()) do
                    if item:GetAttribute("PetType") ~= "Pet" then continue end
                    local uuid = item:GetAttribute("PET_UUID") or item.Name
                    if snapshotUUIDs[uuid] then continue end
                    local parsed  = parseName(item.Name)
                    local petName = item:GetAttribute("f") or ""
                    local kg      = tonumber(parsed.kg) or 0
                    table.insert(newPets, { item = item, uuid = uuid, name = petName, kg = kg })
                end

                local toSell = {}
                for _, pet in ipairs(newPets) do
                    if not pet.item or not pet.item.Parent then continue end
                    -- Filter 1: harus ada di dropdown sell
                    local inList = false
                    for _, sn in ipairs(AutoEgg.SellPets) do
                        if pet.name:find(sn, 1, true) then inList = true; break end
                    end
                    if not inList then continue end
                    -- Filter 2: jangan jual kalau weight >= MinGoodHatch
                    if AutoEgg.MinGoodHatch > 0 and pet.kg >= AutoEgg.MinGoodHatch then continue end
                    table.insert(toSell, pet)
                end
                if #toSell > 0 then
                    AEStats.sellReturn = AEStats.sellReturn + #toSell
                    task.wait(1)
                    safeEquipLoad(AutoEgg.SellingUUIDs); task.wait(0.5)
                    local ch  = LP.Character
                    local hum = ch and ch:FindFirstChildOfClass("Humanoid")
                    if ch and hum then
                        for _, pet in ipairs(toSell) do
                            if not AutoEgg.Running then break end
                            if not pet.item or not pet.item.Parent then continue end
                            pcall(function()
                                -- Equip via Humanoid agar server recognize
                                hum:EquipTool(pet.item)
                                task.wait(0.2)
                                -- Cari tool spesifik berdasarkan UUID/nama, bukan FindFirstChildOfClass
                                local equipped = nil
                                for _, obj in ipairs(ch:GetChildren()) do
                                    if obj:IsA("Tool") then
                                        local u = obj:GetAttribute("PET_UUID") or obj.Name
                                        if u == pet.uuid or obj == pet.item then
                                            equipped = obj; break
                                        end
                                    end
                                end
                                if equipped then
                                    ReplicatedStorage.GameEvents.SellPet_RE:FireServer(equipped)
                                    task.wait(0.2)
                                else
                                    hum:UnequipTools(); task.wait(0.2)
                                end
                            end)
                        end
                    end
                    unequipAllActive(); task.wait(0.5)
                end
            end

            task.wait(1)
        end
    end)
end

local function stopAutoEgg()
    AutoEgg.Running = false
    if AutoEgg.Thread then pcall(function() task.cancel(AutoEgg.Thread) end); AutoEgg.Thread = nil end
    -- Save stats to file; clear session counters (eggReturn/goodHatch/sellReturn reset on OFF)
    AEStats.eggReturn  = 0
    AEStats.goodHatch  = 0
    AEStats.sellReturn = 0
    -- hatchTotal persists, never reset here
    saveSettings()
end

