        local prompt
        pcall(function() prompt = eggObj.PetEgg.ProximityPromptAtt.ProximityPrompt end)
        if not prompt then prompt = eggObj:FindFirstChildWhichIsA("ProximityPrompt", true) end
        if prompt and type(fireproximityprompt) == "function" then
            fireproximityprompt(prompt); return
        end
        local uuid = eggObj:GetAttribute("OBJECT_UUID")
        if uuid then ReplicatedStorage.GameEvents.HatchEgg_RE:FireServer(uuid) end
