local function findBoostTool(toyType)
    for _, item in ipairs(Backpack:GetChildren()) do
        if item:IsA("Tool")
        and string.find(item.Name, toyType .. " Pet Toy")
        and string.find(item.Name, "Passive Boost") then
            return item
        end
    end
    return nil
end

local function applyOneToy(uuid, toyType)
    local tool = findBoostTool(toyType)
    if not tool then return false end
    local char = LP.Character; if not char then return false end
    local hum  = char:FindFirstChildOfClass("Humanoid"); if not hum then return false end
    pcall(function()
        hum:EquipTool(tool); task.wait(0.3)
        ReplicatedStorage.GameEvents.PetBoostService:FireServer("ApplyBoost", uuid)
        task.wait(0.3); hum:UnequipTools(); task.wait(0.3)
    end)
    return true
end

local function applyBoostDirect(uuid)
    local useSmall  = (boost.ToyMode == "Small"  or boost.ToyMode == "Both")
    local useMedium = (boost.ToyMode == "Medium" or boost.ToyMode == "Both")
    if useSmall  and findBoostTool("Small")  then applyOneToy(uuid, "Small")  end
    if useMedium and findBoostTool("Medium") then applyOneToy(uuid, "Medium") end
end

doScanBoostPets = function()
    -- Scan dari Backpack (bukan ActivePetUI) — shared dengan PnP
    scanBPPets()
    -- boost.Displays & boost.DispMap sudah di-update oleh scanBPPets
    boost.UUIDs  = {}   -- reset selection A
    boost.UUIDsB = {}   -- reset selection B
    return #boost.Displays
end

local function boostIsUUIDActive(uuid)
    local found = false
    pcall(function()
        for _, child in ipairs(getPetDisplay():GetChildren()) do
            if child.Name == uuid and child:IsA("Frame") and child:FindFirstChild("Main") then
                found = true
            end
        end
    end)
    return found
end

local function startBoostLoop()
    local uuids = getBoostSelectedUUIDs()
    if #uuids == 0 then boost.Running = false; return end
    boost.MonitorUUID   = nil
    boost.SmallPending  = false
    boost.MediumPending = false
    boost.Thread        = nil
    -- Init Monitors per pet
    boost.Monitors = {}
    for _, uuid in ipairs(uuids) do
        boost.Monitors[uuid] = { small = nil, medium = nil }
    end
    -- Apply langsung ke semua UUID saat pertama kali start
    task.spawn(function()
        for _, uuid in ipairs(uuids) do
            if not boost.Running then return end
            pcall(function() applyBoostDirect(uuid) end)
        end
    end)
    -- Re-apply otomatis ditangani DataStream listener di bawah
end

