local char = LP.Character or LP.CharacterAdded:Wait()
local hrp  = char:WaitForChild("HumanoidRootPart")
local eggConnection = nil

local function tpToHitbox(hitbox)
    if hitbox and hitbox:IsA("BasePart") then
        hrp.AssemblyLinearVelocity  = Vector3.zero
        hrp.AssemblyAngularVelocity = Vector3.zero
        hrp.CFrame   = CFrame.new(hitbox.Position + Vector3.new(0, hitbox.Size.Y/2 + 4, 0))
        hrp.Anchored = true; task.wait(0.15); hrp.Anchored = false
    end
end

local function startEggTP()
    local folder = Workspace:FindFirstChild("EasterEggReward")
    if folder then
        for _, v in ipairs(folder:GetChildren()) do
            if v.Name == "HitBox" and v:IsA("BasePart") then tpToHitbox(v) end
        end
    end
    eggConnection = Workspace.DescendantAdded:Connect(function(obj)
        if obj.Name == "HitBox" and obj:IsA("BasePart")
        and obj.Parent and obj.Parent.Name == "EasterEggReward" then
            task.wait(0.5); tpToHitbox(obj)
        end
    end)
end

local function stopEggTP()
    if eggConnection then eggConnection:Disconnect(); eggConnection = nil end
end

