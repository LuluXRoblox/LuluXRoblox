-- ============================================================
-- MAIN LOADER
-- ============================================================

task.spawn(function()

    local BASE = "https://raw.githubusercontent.com/LuluXRoblox/LuluXRoblox/main/LuluXGaG/"

    local PARTS = {
        "TimeLicence",
        "ServiceState",
        "ConfigHelpers",
        "PetHelpers",
        "Systems",
        "Ui",
    }

    local combined = ""

    for _, name in ipairs(PARTS) do

        local ok, content = pcall(function()
            return game:HttpGet(BASE .. name, true)
        end)

        if ok and content and content ~= "" then
            combined = combined .. "\n" .. content
        else
            warn("[LuluXGAG] Fail fetch:", name)
        end
    end

    local fn, err = loadstring(combined)

    if not fn then
        warn(err)
        return
    end

    fn()

    print("Auto reexecute succes✓")

end)

