-- LICENCE SYSTEM
-- ============================================================
local CONN_CODE   = "Cdaaptnia"
local RAW_LICENCE = "https://raw.githubusercontent.com/LuluXRoblox/LuluXRoblox/refs/heads/main/GrowAGardenlcnc"

local licOk, licenceTable = pcall(function()
    return loadstring(game:HttpGet(RAW_LICENCE, true))()
end)
if not licOk or type(licenceTable) ~= "table" then
    player:Kick("Whitelist server error.\nPlease rejoin.")
    return
end

local entry = licenceTable[player.Name] or licenceTable["ALL"]
if not entry then
    player:Kick("You cannot access this script.\nPlease contact the script team.")
    return
end

local fields = {}
for f in entry:gmatch("([^,]+)") do
    table.insert(fields, f:match("^%s*(.-)%s*$"))
end

local entName, entKode, entDate, entDur, entTag
local fCount = #fields

if fCount == 4 then
    entName, entDate, entDur, entKode = fields[1], fields[2], fields[3], fields[4]
elseif fCount == 3 then
    entName, entTag, entKode = fields[1], fields[2], fields[3]
else
    player:Kick("Invalid licence format. Contact script team.")
    return
end

if not entName or entKode ~= CONN_CODE then
    player:Kick("You cannot access this script.\nPlease contact the script team.")
    return
end

isPromo     = (licenceTable[player.Name] == nil and licenceTable["ALL"] ~= nil)
displayName = entName

if fCount == 4 then
    local addedUnix = parseDateUnix(entDate)
    if not addedUnix then
        player:Kick("Invalid licence format. Contact script team.")
        return
    end
    expireUnix = addedUnix + parseDuration(entDur)
    if nowUnix >= expireUnix then
        player:Kick((isPromo and "Free" or "Your") .. " licence has expired.\nPlease contact the script team.")
        return
    end
elseif fCount == 3 then
    licenceTag = entTag          -- e.g. "Developer", "TimDev"
    expireUnix = math.huge
    expireText = entTag
end

