local doScanBoostPets

local function refreshTargets()
    scanAll()
    State.DisplayKGTarget = {}
    State.DisplayLVTarget = {}
    for _, p in ipairs(State.AllPets) do
        table.insert(State.DisplayKGTarget, p.display)
        table.insert(State.DisplayLVTarget, p.display)
    end
    local _savedKG = KG.Targets
    local _savedLV = LV.ManualTargets
    if ddKG.Target then ddKG.Target:SetOptions(State.DisplayKGTarget) end
    if ddLV.Target then ddLV.Target:SetOptions(State.Alldisplay)      end
    KG.Targets       = _savedKG
    LV.ManualTargets = _savedLV
end

local function refreshAll()
    scanAll()
    scanBPPets()   -- scan Backpack untuk PnP + Boost
    State.DisplayKGTarget = {}
    State.DisplayLVTarget = {}
    for _, p in ipairs(State.AllPets) do
        table.insert(State.DisplayKGTarget, p.display)
        table.insert(State.DisplayLVTarget, p.display)
    end
    local _savedKG = KG.Targets
    local _savedLV = LV.ManualTargets
    if ddKG.Target      then ddKG.Target:SetOptions(State.DisplayKGTarget) end
    if ddLV.Target      then ddLV.Target:SetOptions(State.Alldisplay)      end
    KG.Targets       = _savedKG
    LV.ManualTargets = _savedLV
    -- PnP dropdown sekarang pakai bpDisplays (backpack, bukan AllPetNames)
    if PnP.ddOnSkill    then PnP.ddOnSkill:SetOptions(bpDisplays)    end
    if PnP.ddAfterSkill then PnP.ddAfterSkill:SetOptions(bpDisplays) end
    -- Boost Slot A & B
    if ddMisc.BoostA then ddMisc.BoostA:SetOptions(bpDisplays) end
    if ddMisc.BoostB then ddMisc.BoostB:SetOptions(bpDisplays) end

    if #boost.SavedUUIDs > 0 then
        doScanBoostPets()
        if ddMisc.Boost then ddMisc.Boost:SetOptions(boost.Displays) end
        local uuidToDisp = {}
        for disp, uuid in pairs(boost.ScanMap) do uuidToDisp[uuid] = disp end
        local restoredSel = {}
        for _, savedUUID in ipairs(boost.SavedUUIDs) do
            local disp = uuidToDisp[savedUUID]
            if disp then table.insert(restoredSel, disp) end
        end
        if #restoredSel > 0 then
            boost.Selected = restoredSel
            pcall(function() if ddMisc.Boost then ddMisc.Boost:SetSelected(restoredSel) end end)
        end
    end

    rebuildConfigDropdowns()
end

local function rescanTargetsOnly()
    pcall(function()
        for _, child in ipairs(getPetDisplay():GetChildren()) do
            if child:IsA("Frame") and child:FindFirstChild("Main") then
                State.EquippedUUIDs[child.Name] = true
            end
        end
        for _, dn in ipairs(KG.Targets) do
            local p = petOf(dn)
            if p and KG.Status[p.uuid] ~= "done" then
                pcall(function() rescanPetTarget(p.uuid) end)
            end
        end
    end)
end

