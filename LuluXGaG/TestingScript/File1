local player  = game.Players.LocalPlayer
local UTC_OFFSET  = 7 * 3600
local MONTHS_LBL  = {"Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"}

local DAYS_IN_MONTH = {31,28,31,30,31,30,31,31,30,31,30,31}
local function isLeap(y) return (y%4==0 and y%100~=0) or y%400==0 end
local function toUnix(y, mo, d, h, m, s)
    local days = 0
    for yr = 1970, y - 1 do
        days = days + (isLeap(yr) and 366 or 365)
    end
    local dim = {table.unpack(DAYS_IN_MONTH)}
    if isLeap(y) then dim[2] = 29 end
    for i = 1, mo - 1 do days = days + dim[i] end
    days = days + d - 1
    return days * 86400 + h * 3600 + m * 60 + (s or 0)
end

local function getServerUnix()
    local ok, res = pcall(game.HttpGet, game,
        "https://timeapi.io/api/time/current/zone?timeZone=UTC")
    if not ok then return nil end
    local yr,mo,dy,h,m,s = res:match('"dateTime":"(%d+)-(%d+)-(%d+)T(%d+):(%d+):(%d+)')
    if not yr then return nil end
    return toUnix(tonumber(yr),tonumber(mo),tonumber(dy),
                  tonumber(h),tonumber(m),tonumber(s)) + UTC_OFFSET
end

local function parseDuration(str)
    local secs = 0
    for num, unit in str:gmatch("(%d+)([HhDdWwMm])") do
        num = tonumber(num); local u = unit:upper()
        if     u == "H" then secs = secs + num * 3600
        elseif u == "D" then secs = secs + num * 86400
        elseif u == "W" then secs = secs + num * 604800
        elseif u == "M" then secs = secs + num * 2592000
        end
    end
    return secs
end

local function parseDateUnix(dateStr)
    local h, m, d, mo, y = dateStr:match("(%d+):(%d+)%s+(%d+)/(%d+)/(%d+)")
    if not h then return nil end
    return toUnix(tonumber(y),tonumber(mo),tonumber(d),
                  tonumber(h),tonumber(m),0)
end

local function formatRemaining(secs)
    if secs == math.huge or secs >= 1e15 then return "Permanent" end
    if secs <= 0 then return "Expired" end
    if secs < 60 then return math.floor(secs) .. "s remaining" end
    local parts = {}
    local mo = math.floor(secs/2592000); secs = secs%2592000
    local w  = math.floor(secs/604800);  secs = secs%604800
    local d  = math.floor(secs/86400);   secs = secs%86400
    local h  = math.floor(secs/3600);    secs = secs%3600
    local m  = math.floor(secs/60)
    if mo>0 then table.insert(parts, mo.."M") end
    if w >0 then table.insert(parts, w .."W") end
    if d >0 then table.insert(parts, d .."D") end
    if h >0 then table.insert(parts, h .."H") end
    if m >0 then table.insert(parts, m .."min") end
    return table.concat(parts," ") .. " remaining"
end

