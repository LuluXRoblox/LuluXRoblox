    PnP.SyncPaused = false
end

local function unequipList(uuids)
    PnP.SyncPaused = true
    for _, uuid in ipairs(uuids) do unequipPet(uuid); task.wait(0.25) end
    PnP.SyncPaused = false
end

local function switchList(from, to)
    PnP.SyncPaused = true
    for _, uuid in ipairs(from) do unequipPet(uuid); task.wait(0.25) end
    for _, uuid in ipairs(to)   do equipPet(uuid);   task.wait(0.3)  end
    PnP.SyncPaused = false
end

local function waitUntilNoActivePets(timeout)
    timeout = timeout or 4

    local start = tick()

    while tick() - start < timeout do
        local active = getActivePets()

        if not active or #active == 0 then
            return true
        end

        task.wait(0.15)
    end

    return false
end

local function beginClearLoad()
    PnP.ClearLoading = true
    PnP.SyncPaused = true

    pcall(function()
        unequipAllActive()
    end)

    waitUntilNoActivePets(5)
end

local function endClearLoad()
    task.wait(0.2)
    PnP.ClearLoading = false
    PnP.SyncPaused = false
end

local function safeEquipLoad(load)
    beginClearLoad()

    if load and #load > 0 then
        equipList(load)
    end

    endClearLoad()
end

