local function boostIsUUIDActive(uuid)
    local found = false
    pcall(function()
        for _, child in ipairs(getPetDisplay():GetChildren()) do
            if child.Name == uuid and child:IsA("Frame") and child:FindFirstChild("Main") then
                found = true
            end
        end
    end)
    return found
end

local function startBoostLoop()
    -- Use all selected UUIDs (not just expired) for monitor init
    local allUUIDs = boost.UUIDs
    if #allUUIDs == 0 then
        allUUIDs = {}
        for _, disp in ipairs(boost.Selected) do
            local uuid = boost.ScanMap[disp]
            if uuid then table.insert(allUUIDs, uuid) end
        end
    end
    if #allUUIDs == 0 then boost.Running = false; return end

    boost.MonitorUUID   = nil
    boost.SmallPending  = false
    boost.MediumPending = false
    boost.Thread        = nil
    -- Init Monitors for ALL selected UUIDs (needed for DataStream re-apply)
    boost.Monitors = {}
    for _, uuid in ipairs(allUUIDs) do
        boost.Monitors[uuid] = { small = nil, medium = nil }
    end
    -- Apply only to UUIDs whose boost has expired (or never applied)
    task.spawn(function()
        for _, uuid in ipairs(allUUIDs) do
            if not boost.Running then return end
            if not boost.ActiveBoosts[uuid] then
                pcall(function() applyBoostDirect(uuid) end)
                task.wait(0.3)
            end
        end
    end)
    -- Re-apply handled automatically by DataStream listener
end

