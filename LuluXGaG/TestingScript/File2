-- (semua egg di farm kita = punya kita, jauh lebih robust)
local function aeCountMyEggs()
    local count = 0
    pcall(function()
        local myFarm = aeGetMyFarm()
        if not myFarm then return end
        local objPhys = myFarm:FindFirstChild("Objects_Physical", true)
        if not objPhys then return end
