local function clearESP()
    for _, bg in pairs(ESP.Bills) do pcall(function() bg:Destroy() end) end
    ESP.Bills = {}
end

local function espFindPart(obj)
    -- Try the object itself first, then shallow, then deep
    if obj:IsA("BasePart") then return obj end
    local shallow = obj:FindFirstChildWhichIsA("BasePart")
    if shallow then return shallow end
    return obj:FindFirstChildWhichIsA("BasePart", true)
end

local function updateESP()
    local seen = {}
    pcall(function()
        for _, farm in ipairs(workspace.Farm:GetChildren()) do
            local objPhys = farm:FindFirstChild("Objects_Physical", true)
            if not objPhys then continue end

            for _, obj in ipairs(objPhys:GetChildren()) do
                local objType = obj:GetAttribute("OBJECT_TYPE")
                if not objType then continue end
                local rawUUID = obj:GetAttribute("OBJECT_UUID")
                if not rawUUID then continue end
                local uuid = aeNormUUID(rawUUID)

                local isGolden = objType:lower():find("golden") ~= nil
                -- Show MY pet eggs always (not just when ready)
                local isPetEgg = (objType == "PetEgg") and aeIsMyEgg(obj:GetAttribute("OWNER"))
                if not isGolden and not isPetEgg then continue end

                seen[uuid] = true

                local attachPart = espFindPart(obj)
                if not attachPart then continue end

                -- Recreate if missing, destroyed, or adornee changed
                local bill = ESP.Bills[uuid]
                if not bill or not bill.Parent
                or bill.Adornee ~= attachPart then
                    if bill then pcall(function() bill:Destroy() end) end
                    bill = espCreateBillboard(attachPart, uuid)
                    ESP.Bills[uuid] = bill
                end

                local lblTop, lblBot = espGetLabels(bill)
                if not lblTop or not lblBot then continue end

                local mon = HatchMonitor[uuid]

                -- ── GOLDEN EGG ────────────────────────────────────────
                if isGolden then
                    local petName = (mon and mon.petName) or "Golden Egg"
                    local kg      = (mon and mon.baseWeight) or 0
                    local catStr  = kg > 0 and ("(" .. getWeightCategory(kg) .. ")") or ""

                    lblTop.Text       = petName
                    lblTop.TextColor3 = Color3.fromRGB(30, 30, 30)

                    lblBot.Text       = kg > 0 and string.format("%.2f kg %s", kg, catStr) or "? kg"
                    lblBot.TextColor3 = Color3.fromRGB(80, 60, 0)

                    espSetFrame(bill, Color3.fromRGB(255, 230, 120), 0.05)

                -- ── PET EGG ───────────────────────────────────────────
                elseif isPetEgg then
                    local kg      = (mon and mon.baseWeight) or 0
                    local isReady = mon and (mon.readyNotified or mon.canHatch)
                    local catStr  = getWeightCategory(kg)
                    local petName = (mon and mon.petName) or nil

                    -- Cache egg display name into HatchMonitor for info panel
                    if mon and not mon.eggName then
                        mon.eggName = obj:GetAttribute("EggName")
                                   or obj:GetAttribute("EggType")
                                   or obj:GetAttribute("ObjectType")
                                   or obj.Name or "Egg"
                    end
                    local eggName = (mon and mon.eggName) or obj.Name or "Egg"

                    if isReady then
                        -- ✓ READY → top: pet name, bot: weight(category)
                        lblTop.Text       = petName or "Ready!"
                        lblTop.TextColor3 = Color3.fromRGB(80, 255, 80)
                        lblBot.Text       = kg > 0
                            and string.format("%.2fkg(%s)", kg, catStr)
                            or  "✓ Ready"
                        lblBot.TextColor3 = Color3.fromRGB(80, 255, 80)
                        espSetFrame(bill, Color3.fromRGB(0, 40, 0), 0.2)
                    else
                        -- Placing → top: egg name, bot: time remaining only
                        local timeStr = fmtTimeToHatch(mon and mon.timeToHatch)
                        lblTop.Text       = eggName
                        lblTop.TextColor3 = Color3.fromRGB(255, 220, 100)
                        lblBot.Text       = timeStr
                        local goodThresh  = AutoEgg.MinGoodHatch or 0
                        local isGood      = goodThresh > 0 and kg >= goodThresh
                        lblBot.TextColor3 = isGood
                            and Color3.fromRGB(80, 220, 80)
                            or  Color3.fromRGB(220, 120, 60)
                        espSetFrame(bill, Color3.fromRGB(0, 0, 0), 0.25)
                    end
                end
            end
        end
    end)

    -- Remove stale billboards
    for uuid, bill in pairs(ESP.Bills) do
        if not seen[uuid] then
            pcall(function() bill:Destroy() end)
            ESP.Bills[uuid] = nil
        end
    end
end

local function startESP()
    ESP.Enabled = true
    ESP.Thread  = task.spawn(function()
        while ESP.Enabled do updateESP(); task.wait(1) end
        clearESP()
    end)
end

local function stopESP()
    ESP.Enabled = false
    if ESP.Thread then pcall(function() task.cancel(ESP.Thread) end); ESP.Thread = nil end
    clearESP()
end

