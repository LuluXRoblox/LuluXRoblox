local tabShop = win:Tab("Shop")

local SelItems   = { seed={}, gear={}, egg={} }
local BuyRunning = { seed=false, gear=false, egg=false }
local BuyThreads = { seed=nil,  gear=nil,  egg=nil  }

local ShopRemote = {
    seed = function(n) pcall(function() RS.GameEvents.BuySeedStock:FireServer(n) end) end,
    gear = function(n) pcall(function() RS.GameEvents.BuyGearStock:FireServer(n) end) end,
    egg  = function(n) pcall(function() RS.GameEvents.BuyPetEgg:FireServer(n)   end) end,
}

local ShopData = {
    seed = {"Carrot","Strawberry","Blueberry","Orange Tulip","Buttercup","Tomato",
            "Daffodil","Corn","Watermelon","Pumpkin","Apple","Bamboo","Coconut",
            "Cactus","Dragon Fruit","Mango","Mushroom","Grape","Pepper","Cacao",
            "Sunflower","Beanstalk","Ember Lily","Sugar Apple","Burning Bud",
            "Giant Pinecone","Elder Strawberry","Romanesco","Pollenvine",
            "Crimson Thorn","Zebrazinkle","Octobloom","Alien Apple"},
    gear = {"Basic Sprinkler","Watering Can","Advanced Sprinkler","Trading Ticket",
            "Trowel","Godly Sprinkler","Recall Wrench","Medium Toy","Medium Treat",
            "Pet Name Reroller","Magnifying Glass","Master Sprinkler","Cleaning Spray",
            "Friendship Pot","Favorite Tool","Pet Lead","Harvest Tool",
            "Cleansing Pet Shard","Grandmaster Sprinkler","Levelup Lollipop"},
    egg  = {"Common Egg","Uncommon Egg","Rare Egg","Legendary Egg",
            "Mythical Egg","Bug Egg","Jungle Egg"},
}

local GuiMap = { seed="Seed_Shop", gear="Gear_Shop", egg="PetShop_UI" }

local function GetStockCount(key, itemName)
    local n=0
    pcall(function()
        local gui=LP:WaitForChild("PlayerGui"):FindFirstChild(GuiMap[key]); if not gui then return end
        local sf=gui:FindFirstChild("Frame") and gui.Frame:FindFirstChild("ScrollingFrame"); if not sf then return end
        local fr=sf:FindFirstChild(itemName); if not fr then return end
        local lbl=fr:FindFirstChild("Main_Frame") and fr.Main_Frame:FindFirstChild("Stock_Text"); if not lbl then return end
        n=tonumber(lbl.Text:match("[Xx]%s*(%d+)")) or tonumber(lbl.Text:match("%d+")) or 0
    end)
    return n
end

local function BuyItem(key, itemName)
    local n=GetStockCount(key,itemName); if n<=0 then return 0 end
    for _=1,n do ShopRemote[key](itemName); task.wait(0.4) end
    if n>0 and G.sendWebhook and G.Webhook and G.Webhook.AB then
        G.sendWebhook({title="Auto Buy",description="Bought **"..n.."x "..itemName.."**",color=0x5865F2})
    end
    return n
end

local function StopBuying(key)
    BuyRunning[key]=false
    if BuyThreads[key] then task.cancel(BuyThreads[key]); BuyThreads[key]=nil end
end

local function StartBuying(key)
    if BuyThreads[key] then return end
    BuyRunning[key]=true
    BuyThreads[key]=task.spawn(function()
        while BuyRunning[key] do
            local total=0
            for _, name in ipairs(SelItems[key]) do
                if not BuyRunning[key] then break end
                total=total+BuyItem(key,name)
            end
            if total>0 then win:luluNotify("Bought "..total.."x ("..key..")","success") end
            -- Check every 10 seconds (no manual delay input)
            local t=0; while t<10 and BuyRunning[key] do task.wait(1); t=t+1 end
        end
        BuyThreads[key]=nil
    end)
end

local function BuildShopUI(sec, key, label)
    local keys={}; for _, k in ipairs(ShopData[key]) do table.insert(keys,k) end
    sec:MultiDropdown("Select "..label, keys, {}, function(sel) SelItems[key]=sel end)
    sec:Button("Buy Now", function()
        if #SelItems[key]==0 then win:luluNotify("Select items first!","warning"); return end
        task.spawn(function()
            local total=0
            for _, name in ipairs(SelItems[key]) do total=total+BuyItem(key,name) end
            win:luluNotify("Bought x"..total,"success")
        end)
    end)
    sec:Toggle("Auto Buy "..label, false, function(on)
        if on then
            if #SelItems[key]==0 then win:luluNotify("Select items first!","warning"); return end
            StartBuying(key)
        else StopBuying(key) end
    end)
end

tabShop:Accordion("Seed Shop", function(sec) BuildShopUI(sec,"seed","Seed") end)
tabShop:Accordion("Gear Shop", function(sec) BuildShopUI(sec,"gear","Gear") end)
tabShop:Accordion("Egg Shop",  function(sec) BuildShopUI(sec,"egg", "Egg")  end)

tabShop:Button("Stop All", function()
    for _, k in ipairs({"seed","gear","egg"}) do StopBuying(k) end
    win:luluNotify("All auto buy stopped","warning")
end)
