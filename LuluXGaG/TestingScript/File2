local function loadSettings()
    pcall(function()
        if type(isfile) ~= "function" or not isfile(SETTINGS_PATH) then return end
        local ok, s = pcall(function() return HttpService:JSONDecode(readfile(SETTINGS_PATH)) end)
        if not ok or not s then return end

        if s.KGMany       then KG.Many        = s.KGMany       end
        if s.KGTargetBase then KG.TargetBase  = s.KGTargetBase end
        if s.KGByStep   ~= nil then KG.ByStep     = s.KGByStep    end
        if s.KGBridge   ~= nil then KG.Bridge     = s.KGBridge    end
        if s.ShowInfo   ~= nil then State.ShowInfo     = s.ShowInfo     end
        if s.DetailInfo ~= nil then State.DetailInfo   = s.DetailInfo   end
        if s.ShowProgress ~= nil then State.ShowProgress = s.ShowProgress end
        if s.ShowBlessing ~= nil then State.ShowBlessing = s.ShowBlessing end
        if s.ShowPnp    ~= nil then State.ShowPnp      = s.ShowPnp      end
        if s.ShowAllProg ~= nil then State.ShowAllProg  = s.ShowAllProg  end
        if s.ShowBoost  ~= nil then State.ShowBoost    = s.ShowBoost    end
        if s.LVMany       then LV.Many        = s.LVMany       end
        if s.LVTargetAge  then LV.TargetAge   = s.LVTargetAge  end
        if s.PnPDelayPick  then PnP.DelayPick  = s.PnPDelayPick  end
        if s.PnPDelayPlace then PnP.DelayPlace = s.PnPDelayPlace end
        if s.PnPSync    ~= nil then PnP.Sync      = s.PnPSync     end
        if s.WebhookUrl   then Webhook.Url = s.WebhookUrl   end
        if s.WebhookKG  ~= nil then Webhook.KG = s.WebhookKG   end
        if s.WebhookLV  ~= nil then Webhook.LV = s.WebhookLV   end
        if s.WebhookAE  ~= nil then Webhook.AE = s.WebhookAE   end
        if s.WebhookAB  ~= nil then Webhook.AB = s.WebhookAB   end
        -- AE stats
        if s.AEStatsReturn then AEStats.eggReturn  = s.AEStatsReturn end
        if s.AEStatsGood   then AEStats.goodHatch  = s.AEStatsGood   end
        if s.AEStatsSell   then AEStats.sellReturn = s.AEStatsSell   end
        if s.AEStatsHatch  then AEStats.hatchTotal = s.AEStatsHatch  end
        if s.ShowAEStats ~= nil then State.ShowAEStats = s.ShowAEStats end
        if s.ShowAMInfo  ~= nil then State.ShowAMInfo  = s.ShowAMInfo  end
        -- Session restore flags
        if s.AEWasRunning  then State.RestoreAE  = true end
        if s.PnPWasRunning then State.RestorePnP = true end
        if s.KGWasRunning  then State.RestoreKG  = true end
        if s.LVWasRunning  then State.RestoreLV  = true end
        if s.boostSelectedUUIDs and type(s.boostSelectedUUIDs) == "table" then
            boost.SavedUUIDs = s.boostSelectedUUIDs
        end
        if s.boostToyMode  then boost.ToyMode  = s.boostToyMode  end
        if s.Disable3D  ~= nil then State.Disable3D = s.Disable3D  end
        if s.LagSpider  ~= nil then Lag.Spider      = s.LagSpider  end
        if s.LagPets    ~= nil then Lag.Pets        = s.LagPets    end
        if s.LagSpotted ~= nil then Lag.Spotted     = s.LagSpotted end
        -- loadout names
        if s.SelKGLv1   and s.SelKGLv1   ~= "" then selNames.KGLv1    = s.SelKGLv1   end
        if s.SelKGLv2   and s.SelKGLv2   ~= "" then selNames.KGLv2    = s.SelKGLv2   end
        if s.SelKGUpKG  and s.SelKGUpKG  ~= "" then selNames.KGUpKG   = s.SelKGUpKG  end
        if s.SelLVLv1   and s.SelLVLv1   ~= "" then selNames.LVLv1    = s.SelLVLv1   end
        if s.SelLVLv2   and s.SelLVLv2   ~= "" then selNames.LVLv2    = s.SelLVLv2   end
        if s.SelAEReduce and s.SelAEReduce ~= "" then selNames.AEReduce = s.SelAEReduce end
        if s.SelAEHatch and s.SelAEHatch  ~= "" then selNames.AEHatch  = s.SelAEHatch  end
        if s.SelAEGood  and s.SelAEGood   ~= "" then selNames.AEGood   = s.SelAEGood   end
        if s.SelAESell  and s.SelAESell   ~= "" then selNames.AESell   = s.SelAESell   end
        if s.SelOther   and s.SelOther    ~= "" then selNames.Other    = s.SelOther    end
        -- AutoMutate
        if s.SelMutateHelper and s.SelMutateHelper ~= "" then selNames.MutateHelper = s.SelMutateHelper end
        if s.SelMutateReduce and s.SelMutateReduce ~= "" then selNames.MutateReduce = s.SelMutateReduce end
        -- AutoEgg
        if s.AEMaxPlace      then AutoEgg.MaxPlace      = s.AEMaxPlace      end
        if s.AEMinGoodHatch  then AutoEgg.MinGoodHatch  = s.AEMinGoodHatch  end
        if s.AEMaxWeightSell then AutoEgg.MaxWeightSell = s.AEMaxWeightSell end
        if s.AEChosenEggs  and type(s.AEChosenEggs)  == "table" then AutoEgg.ChosenEggs    = s.AEChosenEggs  end
        if s.AESellPets    and type(s.AESellPets)    == "table" then AutoEgg.SellPets       = s.AESellPets    end
        if s.AEGoodPets    and type(s.AEGoodPets)    == "table" then AutoEgg.GoodHatchPets  = s.AEGoodPets    end
