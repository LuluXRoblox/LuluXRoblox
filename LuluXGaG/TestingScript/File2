local function aeFindEggTool(eggName)
    for _, v in ipairs(LP.Backpack:GetChildren()) do
        if v:IsA("Tool") and v.Name:find(eggName, 1, true) then return v end
    end
    local c = LP.Character
    if c then
        for _, v in ipairs(c:GetChildren()) do
            if v:IsA("Tool") and v.Name:find(eggName, 1, true) then return v end
        end
    end
    return nil
end

local function aePlantBatch(needed)
    local c    = LP.Character or LP.CharacterAdded:Wait()
    local hum  = c:FindFirstChildOfClass("Humanoid")
    local hrp2 = c:FindFirstChild("HumanoidRootPart")
    if not hum or not hrp2 then return end

    local farm = aeGetMyFarm()
    if not farm then warn("[AutoEgg] Farm not found"); return end

    local canPlant
    pcall(function() canPlant = farm.Important.Plant_Locations.Can_Plant end)
    if not canPlant then warn("[AutoEgg] Can_Plant not found"); return end

    -- ── Build a grid of ALL valid positions inside Can_Plant ──
    local cf    = canPlant.CFrame
    local sizeX = canPlant.Size.X
    local sizeZ = canPlant.Size.Z
    local STEP  = 4  -- studs between spots — covers the full area

    local positions = {}
    local halfX = math.max(sizeX / 2 - 1, 0)
    local halfZ = math.max(sizeZ / 2 - 1, 0)

    for lx = -halfX, halfX, STEP do
        for lz = -halfZ, halfZ, STEP do
            -- convert local offset → world position
            local worldPos = cf:PointToWorldSpace(Vector3.new(lx, 0, lz))
            table.insert(positions, worldPos)
        end
    end

    if #positions == 0 then
        -- fallback: single centre spot
        table.insert(positions, cf.Position)
    end

    -- ── Cycle through egg types; switch when current type depletes ──
    local planted       = 0
    local eggTypeIdx    = 1   -- index into AutoEgg.ChosenEggs
    local lastEquipped  = nil

    local function nextAvailableEgg()
        -- Try each egg type at most once all the way around
        for _ = 1, #AutoEgg.ChosenEggs do
            local name = AutoEgg.ChosenEggs[((eggTypeIdx - 1) % #AutoEgg.ChosenEggs) + 1]
            if aeFindEggTool(name) then return name end
            eggTypeIdx = eggTypeIdx + 1
            lastEquipped = nil  -- force re-equip when type changes
        end
        return nil  -- all types exhausted
    end

    for _, pos in ipairs(positions) do
        if planted >= needed then break end
        if not AutoEgg.Running then break end

        -- Hard guard: never exceed MaxPlace even if server state differs
        if aeCountMyEggs() >= AutoEgg.MaxPlace then break end

        local eggName = nextAvailableEgg()
        if not eggName then break end  -- no eggs left in backpack

        -- Equip tool only when type changes
        if eggName ~= lastEquipped then
            local tool = aeFindEggTool(eggName)
            if not tool then
                eggTypeIdx = eggTypeIdx + 1; lastEquipped = nil; continue
            end
            hum:EquipTool(tool)
            task.wait(0.3)
            lastEquipped = eggName
        end

        -- Verify egg is actually held (pet toy may have displaced it)
        local heldTool = c:FindFirstChildOfClass("Tool")
        if not heldTool or not heldTool.Name:find(eggName, 1, true) then
            -- Try re-equip once
            local retry = aeFindEggTool(eggName)
            if retry then
                hum:EquipTool(retry)
                task.wait(0.3)
                heldTool = c:FindFirstChildOfClass("Tool")
            end
            -- If still not holding the egg, skip this position
            if not heldTool or not heldTool.Name:find(eggName, 1, true) then
                lastEquipped = nil; continue
            end
        end

        -- Teleport player above the target spot and plant
        hrp2.CFrame = CFrame.new(pos + Vector3.new(0, 3, 0))
        task.wait(0.1)
        local countBefore = aeCountMyEggs()
        pcall(function()
            ReplicatedStorage.GameEvents.PetEggService:FireServer("CreateEgg", pos)
        end)
        task.wait(0.2)  -- tiap place

        -- Hanya hitung planted jika egg benar-benar diterima server
        if aeCountMyEggs() > countBefore then
            planted = planted + 1
            -- If current egg type just ran out, force next loop to search next type
            if not aeFindEggTool(eggName) then
                eggTypeIdx   = eggTypeIdx + 1
                lastEquipped = nil
            end
        end
        -- Jika server reject (posisi sudah terisi), lanjut coba posisi berikutnya
    end

    pcall(function() hum:UnequipTools() end)
end

