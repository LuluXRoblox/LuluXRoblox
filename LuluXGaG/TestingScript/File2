-- ── Weight → category label ──────────────────────────────────
local function getWeightCategory(kg)
    if     kg < 2  then return "small"
    elseif kg < 3  then return "normal"
    elseif kg < 4  then return "semi huge"
    elseif kg < 5  then return "huge"
    elseif kg < 6  then return "semi titanic"
    elseif kg < 7  then return "titanic"
    elseif kg < 8  then return "semi godly"
    elseif kg < 9  then return "godly"
    else                return "super godly" end
end

