local function waitTimerReady(uuid, timeout)
    timeout = timeout or 300
    local t1=0
    while t1<15 and AutoMutate.running do
        if (timerLabel and timerLabel.Text or "") ~= "" then break end
        task.wait(0.5); t1=t1+0.5
    end
    if not AutoMutate.running then return false end
    local t2=0
    while t2<timeout and AutoMutate.running do
        local txt = timerLabel and timerLabel.Text or ""
        if txt=="" or txt=="0" or txt=="0s" or txt:lower()=="ready" then return true end
        if amProgress[uuid] then amProgress[uuid].timer=txt end
        task.wait(1); t2=t2+1
    end
    return false
end

local function loadReduceLoadout()
    local name=AutoMutate.reduceConfigName; if name=="" then return end
    local uuids=getConfigUUIDs("mutate reduce time",name)
    if #uuids>0 then pet.safeEquipLoad(uuids) else win:luluNotify("Reduce: config empty!","warn") end
end

local function holdPet(petUUID)
    pet.safeEquipLoad({}); task.wait(0.8)
    local ch=LP.Character; local hum=ch and ch:FindFirstChildOfClass("Humanoid")
    if not ch or not hum then return false end
    local tool=nil
    for i=1,5 do
        for _, item in ipairs(Backpack:GetChildren()) do
            if item:IsA("Tool") and item:GetAttribute("PET_UUID")==petUUID then tool=item; break end
        end
        if tool then break end; task.wait(0.4)
    end
    if not tool then warn("[AutoMutate] Tool not found in Backpack"); return false end
    pcall(function() hum:EquipTool(tool) end); task.wait(0.5)
    return true
end

local function processMutation(petUUID)
    if not holdPet(petUUID) then
        win:luluNotify("AutoMutate: Failed to hold pet!","error"); return false,""
    end
    fireproximityprompt(proxPrompt); task.wait(3)
    clickConfirm();                   task.wait(0.5)
    fireproximityprompt(proxPrompt); task.wait(1)
    if AutoMutate.reduceConfigName ~= "" then loadReduceLoadout() end
    if not waitTimerReady(petUUID, 300) then
        win:luluNotify("AutoMutate: Timer timeout!","error"); return false,""
    end
    task.wait(10)
    local ch=LP.Character; local hum=ch and ch:FindFirstChildOfClass("Humanoid")
    if hum then pcall(function() hum:UnequipTools() end) end
    pet.safeEquipLoad({}); task.wait(0.5)
    -- Claim via FireServer
    mutResult.pending=false
    local GE=RS:FindFirstChild("GameEvents")
    local mutSvc=GE and GE:FindFirstChild("PetMutationMachineService_RE")
    if mutSvc then pcall(function() mutSvc:FireServer("ClaimMutatedPet") end)
    else fireproximityprompt(proxPrompt) end
    -- Wait for notification (max 8s)
    local t=0
    while t<8 and not mutResult.pending and AutoMutate.running do task.wait(0.5); t=t+0.5 end
    local mutation = mutResult.pending and mutResult.mutation or ""
    mutResult.pending=false; task.wait(0.5)
    return true, mutation
end

