-- ── Helper: format TimeToHatch value for display ─────────────
local function fmtTimeToHatch(v)
    if v == nil then return "-" end
    if type(v) == "number" then
        if v <= 0 then return "Ready" end
        local m = math.floor(v / 60)
        local s = math.floor(v % 60)
        if m > 0 then return m .. "m " .. s .. "s" end
        return s .. "s"
    end
    if type(v) == "table" then
        -- Some games store {minutes=X, seconds=Y}
        local mins = tonumber(v.minutes or v.Minutes or v[1]) or 0
        local secs = tonumber(v.seconds or v.Seconds or v[2]) or 0
        local total = mins * 60 + secs
        if total <= 0 then return "Ready" end
        if mins > 0 then return mins .. "m " .. secs .. "s" end
        return secs .. "s"
    end
    return tostring(v)
end

