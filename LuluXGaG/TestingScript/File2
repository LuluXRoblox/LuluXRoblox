-- Also handles PnP overflow detection.
-- ============================================================

-- PnP overflow fix: when 8/8 fires, a Load B pet failed to equip
-- because a Load A pet is still occupying its slot.
-- Fix: unequip Load A intruder → equip the Load B pet that failed.
local function fixPnPOverflow()
    if not PnP.Running then return end
    task.spawn(function()
        task.wait(0.5)
        local activeList = getActivePets()
        local activeSet  = {}
        for _, p in ipairs(activeList) do activeSet[p.uuid] = true end

        -- Load A (OnSkill) pets that are currently active
        local activeA = {}
        for uuid in pairs(PnP.OnSkillUUIDs) do
            if activeSet[uuid] then table.insert(activeA, uuid) end
        end

        -- Load B (AfterSkill) pets NOT yet active (failed to equip)
        local missingB = {}
        for uuid in pairs(PnP.AfterSkillUUIDs) do
            if not activeSet[uuid] then table.insert(missingB, uuid) end
        end

        if #missingB == 0 then return end  -- nothing to fix

        -- Swap: unequip Load A → equip missing Load B
        local swaps = math.min(#activeA, #missingB)
        for i = 1, swaps do
            pcall(function() unequipPet(activeA[i]) end);  task.wait(0.3)
            pcall(function() equipPet(missingB[i]) end);   task.wait(0.3)
        end
        -- If more Load B missing and no Load A to swap, try direct equip
        for i = swaps + 1, #missingB do
            pcall(function() equipPet(missingB[i]) end);   task.wait(0.3)
        end
    end)
end

