-- ============================================================
-- AM PET SCAN — also extracts current mutation from name
-- ============================================================
local amPetList     = {}
local amDisplayList = {}
local amDispToUUID  = {}

local function amScanPets()
    amPetList = {}; amDisplayList = {}; amDispToUUID = {}
    for _, item in ipairs(Backpack:GetChildren()) do
        local uuid = item:GetAttribute("PET_UUID")
        if not uuid then continue end
        local fullName    = item.Name
        local displayName = fullName:gsub("%s*%[Age %d+%]",""):match("^%s*(.-)%s*$")
        local baseName    = displayName:gsub("%s*%[%d+%.?%d* KG%]",""):match("^%s*(.-)%s*$")
        local baseAttr    = item:GetAttribute("f") or baseName
        -- Detect current mutation: "Rainbow Hootsie Roll" vs baseName "Hootsie Roll"
        local stripped    = displayName:gsub("%s*%[%d+%.?%d* KG%]",""):match("^%s*(.-)%s*$")
        local currentMut  = ""
        if stripped ~= baseAttr then
            local suffix = " " .. baseAttr
            if stripped:sub(-#suffix) == suffix then
                currentMut = stripped:sub(1, #stripped-#suffix):match("^%s*(.-)%s*$") or ""
            end
        end
        if not amDispToUUID[displayName] then
            amDispToUUID[displayName] = uuid
            table.insert(amDisplayList, displayName)
        end
        table.insert(amPetList, {
            uuid=uuid, displayName=displayName,
            baseName=baseName, baseAttr=baseAttr,
            fullName=fullName, currentMutation=currentMut,
        })
    end
end

-- ============================================================
-- AGE — scan ActivePetUI by PET_TYPE/PET_NAME
-- ============================================================
local function amReadAge(m)
    if not m then return 0 end
    local obj = m:FindFirstChild("PET_AGE")
    if obj then
        if obj:IsA("TextLabel") or obj:IsA("TextBox") then
            return tonumber(obj.Text) or tonumber(obj.Text:match("%d+")) or 0
        elseif obj:IsA("IntValue") or obj:IsA("NumberValue") then
            return tonumber(obj.Value) or 0
        end
    end
    return tonumber(m:GetAttribute("Age")) or tonumber(m:GetAttribute("PET_AGE")) or 0
end

local function amGetAge(uuid, baseAttr, petType)
    local age = 0
    pcall(function()
        local display = pet.getPetDisplay()
        for _, child in ipairs(display:GetChildren()) do
            if not child:IsA("Frame") then continue end
            local m = child:FindFirstChild("Main"); if not m then continue end
            if child.Name == uuid then age = amReadAge(m); if age > 0 then return end end
            local tL = m:FindFirstChild("PET_TYPE")
            if petType ~= "" and tL and tL.Text == petType then
                age = amReadAge(m); if age > 0 then return end
            end
            local nL = m:FindFirstChild("PET_NAME")
            if nL and nL.Text == baseAttr then age = amReadAge(m); if age > 0 then return end end
        end
    end)
    return age
end

-- ============================================================
-- MUTATION RESULT — via Notification OnClientEvent
-- ============================================================
local mutResult = { pending=false, petName="", mutation="" }
local mutNotifConn = nil

local function connectMutNotif()
    if mutNotifConn then return end
    local GE = RS:FindFirstChild("GameEvents"); if not GE then return end
    local notif = GE:FindFirstChild("Notification"); if not notif then return end
    mutNotifConn = notif.OnClientEvent:Connect(function(msg)
        if type(msg) ~= "string" then return end
        local stripped = msg:gsub("<[^>]+>",""):match("^%s*(.-)%s*$")
        local pn, mt = stripped:match("^(.+) mutated into (.+)$")
        if pn and mt then
            mutResult.pending  = true
            mutResult.petName  = pn:match("^%s*(.-)%s*$")
            mutResult.mutation = mt:match("^%s*(.-)%s*$")
        end
    end)
end

