local function findBoostTool(toyType)
    for _, item in ipairs(Backpack:GetChildren()) do
        if item:IsA("Tool")
        and string.find(item.Name, toyType .. " Pet Toy")
        and string.find(item.Name, "Passive Boost") then
            return item
        end
    end
    return nil
end

local function applyOneToy(uuid, toyType)
    local tool = findBoostTool(toyType)
    if not tool then return false end
    local char = LP.Character; if not char then return false end
    local hum  = char:FindFirstChildOfClass("Humanoid"); if not hum then return false end
    pcall(function()
        hum:EquipTool(tool); task.wait(0.3)
        ReplicatedStorage.GameEvents.PetBoostService:FireServer("ApplyBoost", uuid)
        task.wait(0.3); hum:UnequipTools(); task.wait(0.3)
    end)
    return true
end

local function applyBoostDirect(uuid)
    local useSmall  = (boost.ToyMode == "Small"  or boost.ToyMode == "Both")
    local useMedium = (boost.ToyMode == "Medium" or boost.ToyMode == "Both")
    if useSmall  and findBoostTool("Small")  then applyOneToy(uuid, "Small")  end
    if useMedium and findBoostTool("Medium") then applyOneToy(uuid, "Medium") end
    -- Mark as active after applying
    boost.ActiveBoosts[uuid] = true
end

