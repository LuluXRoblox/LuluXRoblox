    Two-line billboard:
      ┌─────────────────┐
      │   Pet Name      │  ← lblTop  (bold, bigger)
      │  1.23 kg(small) │  ← lblBot  (regular, smaller)
      └─────────────────┘

    Parented to workspace (not the part) so it survives if the
    part is temporarily removed/re-added by the server.
]]
local function espCreateBillboard(attachPart, uuid)
    local bg = Instance.new("BillboardGui")
    bg.Name              = "LuluESP_" .. uuid
    bg.Size              = UDim2.new(0, 160, 0, 46)
    bg.StudsOffset       = Vector3.new(0, 4, 0)   -- StudsOffset (not WorldSpace) is more stable
    bg.AlwaysOnTop       = true
    bg.LightInfluence    = 0
    bg.ResetOnSpawn      = false
    bg.Adornee           = attachPart
    bg.Parent            = workspace   -- ← workspace parent avoids death when part moves

    local frame = Instance.new("Frame")
    frame.Size                   = UDim2.new(1, 0, 1, 0)
    frame.BackgroundColor3       = Color3.fromRGB(0, 0, 0)
    frame.BackgroundTransparency = 1
    frame.BorderSizePixel        = 0
    frame.Parent                 = bg
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 6)

    -- Top label: Pet name
    local lblTop = Instance.new("TextLabel")
    lblTop.Name                  = "LblTop"
    lblTop.Size                  = UDim2.new(1, -6, 0.52, 0)
    lblTop.Position              = UDim2.new(0, 3, 0, 1)
    lblTop.BackgroundTransparency = 1
    lblTop.TextColor3            = Color3.fromRGB(255, 255, 255)
