-- ============================================================
-- MAIN LOOP
-- ============================================================
local function autoMutateLoop()
    if not initRefs() then
        win:luluNotify("AutoMutate: Machine not found!","error"); AutoMutate.running=false; return
    end
    win:luluNotify("AutoMutate started...","info"); AutoMutate.doneCount=0
    local helperUUIDs={}
    if AutoMutate.helperConfigName~="" then helperUUIDs=getConfigUUIDs("mutate helper lv",AutoMutate.helperConfigName) end
    local needed=AutoMutate.multiCount
    amProgress={}; amOrder={}
    for _, uuid in ipairs(AutoMutate.targetUUIDs) do
        local info=nil; for _, p in ipairs(amPetList) do if p.uuid==uuid then info=p; break end end
        amProgress[uuid]={name=info and info.baseName or uuid, status="waiting", age=0, mutation="", timer="-"}
        table.insert(amOrder, uuid)
    end
    updateInfoPanel()
    local petIdx=1
    while AutoMutate.running and AutoMutate.doneCount<needed do
        if #AutoMutate.targetUUIDs==0 then win:luluNotify("No target pet selected!","warn"); break end
        local uuid=AutoMutate.targetUUIDs[petIdx]
        petIdx=(petIdx % #AutoMutate.targetUUIDs)+1
        if amProgress[uuid] and amProgress[uuid].status=="done" then task.wait(0.3); continue end
        local petInfo=nil
        for _, p in ipairs(amPetList) do if p.uuid==uuid then petInfo=p; break end end
        if not petInfo then amScanPets(); task.wait(0.3); for _, p in ipairs(amPetList) do if p.uuid==uuid then petInfo=p; break end end end
        if not petInfo then win:luluNotify("Pet not in backpack, skipping!","warn"); task.wait(1); continue end
        local baseName=petInfo.baseName; local baseAttr=petInfo.baseAttr
        local petType=(State.UUIDToType and State.UUIDToType[uuid]) or ""
        local currentMut = petInfo.currentMutation or ""
        -- Update Current mutation immediately on first read
        if amProgress[uuid] then
            amProgress[uuid].mutation = (currentMut~="") and currentMut or "NOMUT"
        end
        -- Auto-done: if pet already has target mutation
        local petDone=false
        if currentMut~="" and #AutoMutate.targetMutations>0 then
            for _, tm in ipairs(AutoMutate.targetMutations) do
                if currentMut:lower():find(tm:lower(),1,true) then
                    petDone=true; AutoMutate.doneCount+=1
                    amProgress[uuid].status="done"; updateInfoPanel()
                    win:luluNotify("[done] "..baseName.." already has "..currentMut,"success"); break
                end
            end
        end
        if petDone then amScanPets(); task.wait(0.5); continue end
        -- Inner retry loop
        while AutoMutate.running and not petDone do
            amProgress[uuid].status="leveling"; amProgress[uuid].age=0; updateInfoPanel()
            local toEquip={uuid}
            for _, uid in ipairs(helperUUIDs) do table.insert(toEquip,uid) end
            pet.safeEquipLoad(toEquip); task.wait(1)
            win:luluNotify("Leveling "..baseName.."...","info")
            local elapsed=0
            while elapsed<300 and AutoMutate.running do
                local age=amGetAge(uuid,baseAttr,petType)
                amProgress[uuid].age=age; updateInfoPanel()
                if age>=50 then break end; task.wait(2); elapsed=elapsed+2
            end
            if not AutoMutate.running then break end
            amProgress[uuid].status="wait_mutation"; amProgress[uuid].timer="-"; updateInfoPanel()
            win:luluNotify("Age 50! Entering machine...","info")
            local ok,mutation=processMutation(uuid)
            if not ok then break end
            -- Update Current from notification result
            local mutLabel=(mutation~="") and mutation or "NOMUT"
            amProgress[uuid].mutation=mutLabel; amProgress[uuid].timer="-"
            win:luluNotify("Result: "..mutLabel.." ("..baseName..")","info")
            local targetHit=false
            if #AutoMutate.targetMutations==0 then targetHit=(mutation~="")
            else for _, tm in ipairs(AutoMutate.targetMutations) do if mutation:lower():find(tm:lower(),1,true) then targetHit=true; break end end end
            if targetHit then
                petDone=true; AutoMutate.doneCount+=1; amProgress[uuid].status="done"; updateInfoPanel()
                pet.safeEquipLoad({})
                win:luluNotify("[done] "..baseName.." -> "..mutation.." ["..AutoMutate.doneCount.."/"..needed.."]","success")
            else
                amProgress[uuid].status="leveling"; amProgress[uuid].mutation=""; updateInfoPanel()
                local ts=#AutoMutate.targetMutations>0 and table.concat(AutoMutate.targetMutations,"/") or "any"
                win:luluNotify("Not target ("..ts.."), retry leveling...","warn")
            end
        end
        amScanPets(); task.wait(1)
    end
    AutoMutate.running=false; grp.AMInfo:Hide(); grp.AMAll:Hide()
    win:luluNotify("Done: "..AutoMutate.doneCount.."/"..needed,"success")
end

