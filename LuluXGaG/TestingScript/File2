local function getBoostSelectedUUIDs()
    -- Only return UUIDs whose boost has expired (not currently active)
    local all = boost.UUIDs
    if #all == 0 then
        -- Legacy fallback
        local uuids = {}
        for _, disp in ipairs(boost.Selected) do
            local uuid = boost.ScanMap[disp]
            if uuid then table.insert(uuids, uuid) end
        end
        all = uuids
    end
    -- Filter: only UUIDs where ActiveBoosts[uuid] is not true
    local expired = {}
    for _, uuid in ipairs(all) do
        if not boost.ActiveBoosts[uuid] then
            table.insert(expired, uuid)
        end
    end
    return expired
end

