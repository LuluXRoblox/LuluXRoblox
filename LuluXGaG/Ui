task.defer(function()
    refreshAll()
    rebuildConfigDropdowns()

    local function restoreDD(dd, configType, selName)
        if selName == "" then return end
        pcall(function() if dd then dd:SetSelected(selName) end end)
        return getConfigUUIDs(configType, selName)
    end

    local r1 = restoreDD(ddKG.Lv1,         "leveling kg 1",  selNames.KGLv1)
    local r2 = restoreDD(ddKG.Lv2,         "leveling kg 2",  selNames.KGLv2)
    local r3 = restoreDD(ddKG.UpKg,        "upgrading kg",   selNames.KGUpKG)
    local r4 = restoreDD(ddLV.Lv1,         "leveling lv 1",  selNames.LVLv1)
    local r5 = restoreDD(ddLV.Lv2,         "leveling lv 2",  selNames.LVLv2)
    -- AE slots restore from their own folders
    local r6 = restoreDD(ddAE.ReduceTime,  "ae reduce time", selNames.AEReduce)
    local r7 = restoreDD(ddAE.HatchEgg,    "ae hatch egg",   selNames.AEHatch)
    local r8 = restoreDD(ddAE.GoodHatch,   "ae good hatch",  selNames.AEGood)
    local r9 = restoreDD(ddAE.Selling,     "ae selling",     selNames.AESell)
    restoreDD(ddMisc.Others, "custom loadout", selNames.Other)

    if r1 then KG.Lv1  = r1 end
    if r2 then KG.Lv2  = r2 end
    if r3 then KG.UpKG = r3 end
    if r4 then LV.Lv1  = r4 end
    if r5 then LV.Lv2  = r5 end
    if r6 then AutoEgg.ReduceTimeUUIDs = r6 end
    if r7 then AutoEgg.HatchEggUUIDs   = r7 end
    if r8 then AutoEgg.GoodHatchUUIDs  = r8 end
    if r9 then AutoEgg.SellingUUIDs    = r9 end

    if #AutoEgg.ChosenEggs > 0 then
        pcall(function() if ddAE.Choose then ddAE.Choose:SetSelected(AutoEgg.ChosenEggs) end end)
        if ddAE.SellPets      then ddAE.SellPets:SetOptions(getEggPetNamesForChosen()) end
        if ddAE.GoodHatchPets then ddAE.GoodHatchPets:SetOptions(getEggPetNamesForChosen()) end
    end
    if #AutoEgg.SellPets > 0 then
        pcall(function() if ddAE.SellPets then ddAE.SellPets:SetSelected(AutoEgg.SellPets) end end)
    end
    if #AutoEgg.GoodHatchPets > 0 then
        pcall(function() if ddAE.GoodHatchPets then ddAE.GoodHatchPets:SetSelected(AutoEgg.GoodHatchPets) end end)
    end

    local count, restored = 0, {}
    for _, pair in ipairs({
        {selNames.KGLv1,"KG Lv1"},{selNames.KGLv2,"KG Lv2"},{selNames.KGUpKG,"UpKG"},
        {selNames.LVLv1,"LV Lv1"},{selNames.LVLv2,"LV Lv2"},
        {selNames.AEReduce,"AE Reduce"},{selNames.AEHatch,"AE Hatch"},
        {selNames.AEGood,"AE Good"},{selNames.AESell,"AE Sell"},
        {selNames.MutateHelper,"AM Helper"},{selNames.MutateReduce,"AM Reduce"},
        {selNames.Other,"Other"},
    }) do
        if pair[1] ~= "" then count=count+1; table.insert(restored, pair[2]) end
    end
    if count > 0 then
        win:luluNotify("V8: "..count.." loadout(s) restored! ("..table.concat(restored,", ")..")", "success")
    end
end)

