tab.Main:Accordion("Auto Up KG", function(sec)
    ddKG.Target = sec:MultiDropdown("Select Pets", State.DisplayKGTarget, {}, function(sel) KG.Targets=sel end)
    sec:NumberInput("Target Session",  KG.Many,        1,    1, 7,   function(v) KG.Many       =v; saveSettings() end)
    sec:NumberInput("Target Base KG",  KG.TargetBase,  0.01, 0, 999, function(v) KG.TargetBase =v; saveSettings() end)
    sec:Toggle("Step Mode", KG.ByStep, function(on) KG.ByStep=on; saveSettings() end)
    ddKG.Lv1  = sec:Dropdown("Leveling 1",  getConfigsByType("leveling kg 1"), selNames.KGLv1,  function(sel) if not sel or sel=="" then return end; selNames.KGLv1 =sel; KG.Lv1 =getConfigUUIDs("leveling kg 1",sel);  saveSettings() end)
    ddKG.Lv2  = sec:Dropdown("Leveling 2",  getConfigsByType("leveling kg 2"), selNames.KGLv2,  function(sel) if not sel or sel=="" then return end; selNames.KGLv2 =sel; KG.Lv2 =getConfigUUIDs("leveling kg 2",sel);  saveSettings() end)
    ddKG.UpKg = sec:Dropdown("Upgrade KG",  getConfigsByType("upgrading kg"),  selNames.KGUpKG, function(sel) if not sel or sel=="" then return end; selNames.KGUpKG=sel; KG.UpKG=getConfigUUIDs("upgrading kg",sel);   saveSettings() end)

    tgl.KGStart = sec:Toggle("Start Auto Up KG", false, function(on)
        KG.Running = on
        if on then
            if #KG.Targets==0  then KG.Running=false; pcall(function() tgl.KGStart:SetState(false) end); win:luluNotify("No target pet!", "warning"); return end
            if #boost.Selected==0 then KG.Running=false; pcall(function() tgl.KGStart:SetState(false) end); win:luluNotify("Helper not selected!", "warning"); return end
            if #KG.Lv1==0 then KG.Running=false; pcall(function() tgl.KGStart:SetState(false) end); win:luluNotify("Leveling 1 (KG) not selected!", "warning"); return end
            if #KG.UpKG==0 then KG.Running=false; pcall(function() tgl.KGStart:SetState(false) end); win:luluNotify("Upgrade KG not selected!", "warning"); return end
            KG.Session=0; KG.AllDone=false; KG.Status={}; KG.DoneUUIDs={}
            KG.ActivePhases={}; KG.LastKnown={}; KG.LastKnownAge={}; KG.CurrentKG={}
            Jmb.FiredPerHelper={}; State.AllProgLastStatus=""
            for _, dn in ipairs(KG.Targets) do local p=petOf(dn); if p then KG.Status[p.uuid]="waiting" end end
            kgStartLoop(); task.spawn(function() notifyKGStarted(KG.Targets, KG.TargetBase) end)
        else
            if KG.CompletedNaturally then KG.CompletedNaturally=false; return end
            pcall(function() if KG.Thread then task.cancel(KG.Thread) end end)
            KG.Thread=nil; KG.ActivePhases={}; Jmb.FiredPerHelper={}; PnP.ActiveHelperUUIDs={}
            State.AllProgLastStatus=""
            task.spawn(function() unequipAllActive(); task.wait(0.5); refreshTargets() end)
        end
    end)

    sec:Toggle("Bridge (KG→LV)", KG.Bridge, function(on)
        KG.Bridge=on; saveSettings()
        win:luluNotify(on and "Bridge ON — auto LV after KG" or "Bridge OFF", "info")
    end)
end)

