-- ============================================================
-- SESSION RESTORE — re-activate features that were running
-- before script was re-executed
-- ============================================================
task.spawn(function()
    task.wait(3)  -- wait for UI + features to fully initialize
    local restored = {}

    if State.RestoreKG and tgl.KGStart then
        pcall(function() tgl.KGStart:SetState(true) end)
        table.insert(restored, "Auto KG")
    end
    if State.RestoreLV and tgl.LVStart then
        pcall(function() tgl.LVStart:SetState(true) end)
        table.insert(restored, "Auto LV")
    end
    if State.RestoreAE and tgl.AEStart then
        pcall(function() tgl.AEStart:SetState(true) end)
        table.insert(restored, "Auto Egg")
    end
    if State.RestorePnP and tgl.PnPStart then
        pcall(function() tgl.PnPStart:SetState(true) end)
        table.insert(restored, "PnP")
    end

    if #restored > 0 then
        win:luluNotify("Session restored: " .. table.concat(restored, ", "), "info")
    end

    -- Clear restore flags
    State.RestoreAE  = false
    State.RestorePnP = false
    State.RestoreKG  = false
    State.RestoreLV  = false
end)
