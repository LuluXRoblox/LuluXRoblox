local function findBoostTool(toyType)
    for _, item in ipairs(Backpack:GetChildren()) do
        if item:IsA("Tool")
        and string.find(item.Name, toyType .. " Pet Toy")
        and string.find(item.Name, "Passive Boost") then
            return item
        end
    end
    return nil
end

local function applyOneToy(uuid, toyType)
    local tool = findBoostTool(toyType)
    if not tool then return false end
    local char = LP.Character; if not char then return false end
    local hum  = char:FindFirstChildOfClass("Humanoid"); if not hum then return false end
    pcall(function() hum:EquipTool(tool) end)
    task.wait(0.3)
    pcall(function() ReplicatedStorage.GameEvents.PetBoostService:FireServer("ApplyBoost", uuid) end)
    task.wait(0.3)
    pcall(function() hum:UnequipTools() end)
    task.wait(0.4)
    return true
end

local function applyBoostDirect(uuid)
    local useSmall  = (boost.ToyMode == "Small"  or boost.ToyMode == "Both")
    local useMedium = (boost.ToyMode == "Medium" or boost.ToyMode == "Both")
    local applied = false
    if useSmall  and findBoostTool("Small")  then applyOneToy(uuid, "Small");  applied = true end
    if useMedium and findBoostTool("Medium") then applyOneToy(uuid, "Medium"); applied = true end
    if applied then
        boost.ActiveBoosts[aeNormUUID(uuid)] = true
    end
end

