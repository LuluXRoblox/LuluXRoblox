local function kgStartLoop()
    if KG.Thread then pcall(function() task.cancel(KG.Thread) end) end
    KG.ActivePhases = {}; KG.FaseCount = {}
    KG.Thread = task.spawn(function()
        unequipAllActive()
        local allPets = {}
        for _, dn in ipairs(KG.Targets) do
            local p = petOf(dn); if p then table.insert(allPets, p) end
        end
        if #allPets == 0 then
            KG.Running = false
            pcall(function() if tgl.KGStart then tgl.KGStart:SetState(false) end end)
            win:luluNotify("No KG target — select pet first!", "warning"); return
        end

        local active, upkgQueue, upkgChecks = {}, {}, {}
        KG.UpkgSlot = nil  -- exposed untuk fixPnPOverflow
        local currentBatch = {}; local kgPetCounter = 0
        local kgTotalQueue = #allPets; local kgCounted = {}

        local function getBatchRemaining()
            local r = {}
            for _, p in ipairs(currentBatch) do
                if KG.Status[p.uuid] ~= "done" then table.insert(r, p) end
            end
            return r
        end

        local function loadNextBatch()
            currentBatch = {}
            if KG.ByStep then
                while #allPets > 0 do table.insert(currentBatch, table.remove(allPets,1)) end
            else
                while #currentBatch < KG.Many and #allPets > 0 do
                    table.insert(currentBatch, table.remove(allPets,1))
                end
            end
            for _, p in ipairs(currentBatch) do
                if KG.Status[p.uuid] ~= "done" then KG.Status[p.uuid] = "waiting" end
            end
            return #currentBatch > 0
        end

        local function startBatchCycle()
            local remaining = getBatchRemaining(); local canAdd = KG.Many - #active
            if canAdd <= 0 or #remaining == 0 then return end
            local added = false
            for _, p in ipairs(remaining) do
                if canAdd <= 0 then break end
                if KG.Status[p.uuid] == "waiting" then
                    if not kgCounted[p.uuid] then
                        kgPetCounter = kgPetCounter + 1; kgCounted[p.uuid] = true
                    end
                    KG.FaseCount[p.uuid]    = (KG.FaseCount[p.uuid] or 0) + 1
                    KG.Status[p.uuid]       = "progres"
                    KG.ActivePhases[p.uuid] = "lv1"
                    table.insert(active, { uuid=p.uuid, display=p.display, name=p.name, phase="lv1" })
                    task.spawn(notifyPetKGLevelingSwitch, p.name, "lv1", kgPetCounter, kgTotalQueue, KG.Session, KG.FaseCount[p.uuid])
                    equipPet(p.uuid); task.wait(0.4); canAdd=canAdd-1; added=true
                end
            end
            if added then
                if #KG.Lv1 > 0 then equipList(KG.Lv1) end
            end
        end

        local function checkAllHelpersFired()
            if #Jmb.LabelOrder == 0 then return false end
            for _, uuid in ipairs(Jmb.LabelOrder) do
                if not Jmb.FiredPerHelper[uuid] then return false end
            end
            return true
        end
        local function resetHelperFiredStatus()
            for _, uuid in ipairs(Jmb.LabelOrder) do Jmb.FiredPerHelper[uuid] = nil end
        end

        local function startNextUpkg(keepHelper)
            if KG.UpkgSlot or #upkgQueue == 0 then return end
            KG.UpkgSlot = table.remove(upkgQueue, 1); resetHelperFiredStatus()
            KG.Status[KG.UpkgSlot.uuid] = "progres"; KG.ActivePhases[KG.UpkgSlot.uuid] = "upkg"
            equipPet(KG.UpkgSlot.uuid); task.wait(0.4)
            if not keepHelper then
                if #KG.Lv2 > 0 then unequipList(KG.Lv2) end
                if #KG.Lv1 > 0 then unequipList(KG.Lv1) end
                if #KG.UpKG > 0 then equipList(KG.UpKG) end
            end
        end

        local function finalizeUpkgBatch()
            unequipAllActive(); task.wait(0.8); resetHelperFiredStatus()
            for _, checked in ipairs(upkgChecks) do
                local prevKG = KG.CurrentKG[checked.uuid] or KG.LastKnown[checked.uuid] or 0
                local finalKG = nil
                for _ = 1, 5 do
                    local scan = rescanPetTarget(checked.uuid)
                    if scan.kg > 0 then finalKG=scan.kg; KG.CurrentKG[checked.uuid]=finalKG; break end
                    task.wait(1)
                end
                if finalKG == nil then finalKG = KG.LastKnown[checked.uuid] or 0; KG.CurrentKG[checked.uuid]=finalKG end
                task.spawn(function() notifyPetKGUpdate(checked.name, prevKG, finalKG) end)
                if KG.TargetBase == 0 or finalKG >= KG.TargetBase then
                    KG.Status[checked.uuid]="done"; KG.DoneUUIDs[checked.uuid]=checked.name or ""; KG.ActivePhases[checked.uuid]=nil
                    task.spawn(function() notifyPetKGDone(checked.name, finalKG, KG.FaseCount[checked.uuid]) end)
                else
                    KG.Status[checked.uuid]="waiting"; KG.ActivePhases[checked.uuid]=nil
                end
            end
            upkgChecks = {}; rebuildKGTargetDisplay()
            local remaining = getBatchRemaining()
            if #remaining > 0 then kgPetCounter=0; kgCounted={}; startBatchCycle()
            elseif loadNextBatch() then KG.Session=KG.Session+1; startBatchCycle() end
        end

        loadNextBatch()
KG.Session = KG.Session + 1
startBatchCycle()

        while KG.Running do
            task.wait(1)
            if KG.UpkgSlot then
                local targetAge = getAge(KG.UpkgSlot.uuid)
                if targetAge == 1 then
                    local savedSlot = KG.UpkgSlot; unequipPet(savedSlot.uuid); task.wait(0.8)
                    local prevKGSlot = KG.CurrentKG[savedSlot.uuid] or KG.LastKnown[savedSlot.uuid] or 0
                    local finalKG = nil
                    for _ = 1, 5 do
                        local scan = rescanPetTarget(savedSlot.uuid)
                        if scan.kg > 0 then finalKG=scan.kg; KG.CurrentKG[savedSlot.uuid]=finalKG; break end
                        task.wait(1)
                    end
                    if finalKG == nil then finalKG=KG.LastKnown[savedSlot.uuid] or 0; KG.CurrentKG[savedSlot.uuid]=finalKG end
                    task.spawn(function() notifyPetKGUpdate(savedSlot.name, prevKGSlot, finalKG) end)
                    if KG.TargetBase == 0 or finalKG >= KG.TargetBase then
                        KG.Status[savedSlot.uuid]="done"; KG.DoneUUIDs[savedSlot.uuid]=savedSlot.name or ""; KG.ActivePhases[savedSlot.uuid]=nil
                        task.spawn(function() notifyPetKGDone(savedSlot.name, finalKG, KG.FaseCount[savedSlot.uuid]) end)
                    else
                        KG.Status[savedSlot.uuid]="waiting"; KG.ActivePhases[savedSlot.uuid]=nil
                    end
                    resetHelperFiredStatus(); KG.UpkgSlot=nil; rebuildKGTargetDisplay()
                    if #upkgQueue > 0 then startNextUpkg(true) else finalizeUpkgBatch() end

                elseif checkAllHelpersFired() then
                    resetHelperFiredStatus(); unequipPet(KG.UpkgSlot.uuid); task.wait(0.3)
                    KG.ActivePhases[KG.UpkgSlot.uuid]="check"; table.insert(upkgChecks, KG.UpkgSlot); KG.UpkgSlot=nil
                    if #upkgQueue > 0 then startNextUpkg(true) else finalizeUpkgBatch() end
                end
            end

            local i = 1
            while i <= #active do
                local t = active[i]; local age = getAge(t.uuid)
                if t.phase == "lv1" then
                    if age >= 30 and #KG.Lv2 > 0 then
                        t.phase="lv2"; KG.ActivePhases[t.uuid]="lv2"; switchList(KG.Lv1, KG.Lv2)
                    elseif age >= 50 then
                        KG.LastKnownAge[t.uuid]=age; KG.Status[t.uuid]="waiting_kg"; KG.ActivePhases[t.uuid]="upkg_wait"
                        unequipPet(t.uuid); task.wait(0.3)
                        table.insert(upkgQueue, {uuid=t.uuid,display=t.display,name=t.name})
                        table.remove(active,i)
                        local needLv1 = false
                        for _, a in ipairs(active) do if a.phase=="lv1" then needLv1=true;break end end
                        if not needLv1 then unequipList(KG.Lv1) end
                        if KG.ByStep then startBatchCycle() end; continue
                    end
                elseif t.phase == "lv2" then
                    if age >= 50 then
                        KG.LastKnownAge[t.uuid]=age; KG.Status[t.uuid]="waiting_kg"; KG.ActivePhases[t.uuid]="upkg_wait"
                        unequipPet(t.uuid); task.wait(0.3)
                        table.insert(upkgQueue, {uuid=t.uuid,display=t.display,name=t.name})
                        table.remove(active,i)
                        local needLv2 = false
                        for _, a in ipairs(active) do if a.phase=="lv2" then needLv2=true;break end end
                        if not needLv2 then unequipList(KG.Lv2) end
                        if KG.ByStep then startBatchCycle() end; continue
                    end
                end
                i=i+1
            end

            if #active == 0 and not KG.UpkgSlot and #upkgQueue > 0 then
                if not KG.ByStep then
                    startNextUpkg(false)
                else
                    local stillLeveling = false
                    for _, p in ipairs(currentBatch) do
                        local s = KG.Status[p.uuid]
                        if s=="waiting" or s=="progres" then stillLeveling=true;break end
                    end
                    if not stillLeveling then startNextUpkg(false) end
                end
            end

            if not KG.UpkgSlot and #upkgQueue==0 and #active==0 and #upkgChecks==0 then
                if #allPets==0 and #getBatchRemaining()==0 then break end
            end
        end

        KG.ActivePhases = {}
        for _, t in ipairs(active) do pcall(function() unequipPet(t.uuid) end) end
        if KG.UpkgSlot then pcall(function() unequipPet(KG.UpkgSlot.uuid) end) end

        if KG.Running then
            KG.Running=false; KG.AllDone=true; unequipAllActive(); task.wait(0.5)
            KG.Thread=nil; KG.CompletedNaturally=true
            pcall(function() if tgl.KGStart then tgl.KGStart:SetState(false) end end)
            win:luluNotify("Auto KG All Done!", "success")
            if Webhook.KG then task.spawn(function() notifyAllKGDone() end) end
            if KG.Bridge then task.spawn(triggerLVAfterKG) end
        end
    end)
end

lvStartLoop = function()
    if LV.Thread then pcall(function() task.cancel(LV.Thread) end) end
    LV.Thread = task.spawn(function()
        unequipAllActive()
        local queue = {}
        for _, dn in ipairs(LV.Targets) do local p=petOf(dn); if p then table.insert(queue,p) end end
        local active = {}; local qi = 1
        local function pickNext()
            while qi <= #queue do
                local p = queue[qi]; qi=qi+1
                if LV.Status[p.uuid] ~= "done" then return p end
            end
            return nil
        end
        while #active < LV.Many do
            local nxt = pickNext(); if not nxt then break end
            LV.Status[nxt.uuid]="progres"
            table.insert(active,{uuid=nxt.uuid,display=nxt.display,name=nxt.name,phase="lv1"})
            equipPet(nxt.uuid); task.wait(0.4)
        end
        if #LV.Lv1 > 0 then equipList(LV.Lv1) end

        while LV.Running do
            task.wait(1)
            local i = 1
            while i <= #active do
                local t   = active[i]; local age = getAge(t.uuid)
                if t.phase == "lv1" and age >= 40 and #LV.Lv2 > 0 then
                    t.phase="lv2"; switchList(LV.Lv1, LV.Lv2)
                    task.spawn(function() notifyPetLVPhase(t.name, age, "lv2") end)
                elseif age >= LV.TargetAge then
                    LV.Status[t.uuid]="done"; LV.DoneUUIDs[t.uuid]=true
                    rebuildLVTargetDisplay(); unequipPet(t.uuid); task.wait(0.5)
                    local lvDoneCount=0; for _ in pairs(LV.DoneUUIDs) do lvDoneCount=lvDoneCount+1 end
                    local freshKG=nil
                    pcall(function() local scan=rescanPetTarget(t.uuid); if scan.kg and scan.kg>0 then freshKG=scan.kg end end)
                    task.spawn(function() notifyPetLVDone(t.name, age, lvDoneCount, #LV.Targets, freshKG) end)
                    local nxt = pickNext()
                    if nxt then
                        LV.Status[nxt.uuid]="progres"
                        active[i]={uuid=nxt.uuid,display=nxt.display,name=nxt.name,phase="lv1"}
                        if t.phase=="lv2" then switchList(LV.Lv2, LV.Lv1) end
                        equipPet(nxt.uuid); task.wait(0.4)
                    else
                        table.remove(active,i); continue
                    end
                end
                i=i+1
            end
            if #active == 0 then break end
            local lvAdded = false
            while #active < LV.Many do
                local nxt=pickNext(); if not nxt then break end
                LV.Status[nxt.uuid]="progres"
                table.insert(active,{uuid=nxt.uuid,display=nxt.display,name=nxt.name,phase="lv1"})
                equipPet(nxt.uuid); task.wait(0.4); lvAdded=true
            end
            if lvAdded then if #LV.Lv1 > 0 then equipList(LV.Lv1) end end
        end

        for _, t in ipairs(active) do pcall(function() unequipPet(t.uuid) end) end
        if LV.Running then
            LV.Running=false; LV.AllDone=true; unequipAllActive(); task.wait(0.5)
            refreshTargets()
            pcall(function() if tgl.LVStart then tgl.LVStart:SetState(false) end end)
            win:luluNotify("All Pets Success Leveling to Age " .. LV.TargetAge .. "!", "success")
            if Webhook.LV then task.spawn(function() notifyAllLVDone() end) end
        end
    end)
end

