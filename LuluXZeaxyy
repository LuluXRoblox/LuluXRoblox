local function readPetAge(m)
    if not m then return 0 end
    local obj = m:FindFirstChild("PET_AGE")
    if obj then
        if obj:IsA("TextLabel") or obj:IsA("TextBox") then
            return tonumber(obj.Text) or tonumber(obj.Text:match("%d+")) or 0
        elseif obj:IsA("IntValue") or obj:IsA("NumberValue") then
            return tonumber(obj.Value) or 0
        elseif obj:IsA("Frame") then
            for _, c in ipairs(obj:GetChildren()) do
                if c:IsA("TextLabel") or c:IsA("TextBox") then
                    local v = tonumber(c.Text) or tonumber(c.Text:match("%d+"))
                    if v and v > 0 then return v end
                end
            end
        end
    end
    local attr = m:GetAttribute("Age") or m:GetAttribute("PET_AGE")
    if attr then return tonumber(attr) or 0 end
    return 0
end

local function getActivePets()
    local pets = {}
    pcall(function()
        for _, child in ipairs(getPetDisplay():GetChildren()) do
            if child:IsA("Frame") and child:FindFirstChild("Main") then
                local m = child.Main
                table.insert(pets, {
                    uuid = child.Name,
                    name = m:FindFirstChild("PET_NAME") and m.PET_NAME.Text or "",
                    type = m:FindFirstChild("PET_TYPE") and m.PET_TYPE.Text or "",
                    age  = readPetAge(m),
                })
            end
        end
    end)
    return pets
end

local function getAge(uuid)
