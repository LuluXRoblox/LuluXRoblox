    local ok, err = pcall(function() delfile(typeToFolder(configType) .. name .. ".json") end)
    return ok, (err or "")
end

local function getConfigsByType(configType)
    local names = {}
    pcall(function()
        if type(listfiles) ~= "function" then return end
        for _, fullPath in ipairs(listfiles(typeToFolder(configType))) do
            local filename = fullPath:match("([^/\\]+)$") or fullPath
            local name     = filename:match("^(.+)%.json$") or filename
            table.insert(names, name)
        end
        table.sort(names)
    end)
    return names
end

local function getConfigUUIDs(configType, name)
    local uuids = {}
    pcall(function()
        if type(readfile) ~= "function" then return end
        local path = typeToFolder(configType) .. name .. ".json"
        if type(isfile) == "function" and not isfile(path) then return end
        local ok, data = pcall(function() return HttpService:JSONDecode(readfile(path)) end)
        if ok and type(data) == "table" then uuids = data end
    end)
    return uuids
end

local function getAllConfigEntries()
    local entries = {}
    pcall(function()
        if type(listfiles) ~= "function" then return end
        for _, t in ipairs(CONFIG_TYPES) do
            local folder = typeToFolder(t)
            for _, fullPath in ipairs(listfiles(folder)) do
                local filename = fullPath:match("([^/\\]+)$") or fullPath
                local name     = filename:match("^(.+)%.json$") or filename
                table.insert(entries, t .. " : " .. name)
            end
        end
        table.sort(entries)
    end)
    return entries
end

