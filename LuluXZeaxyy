local function parseName(itemName)
    local kg  = itemName:match("%[(%d+%.%d+) KG%]")
    local age = itemName:match("%[Age (%d+)%]")
    local base = itemName:match("^(.-)%s*%[") or itemName
    return { base = base:match("^%s*(.-)%s*$"), kg = kg, age = age }
end

local function buildDisplay(petName, kg, age)
    local s = petName
    if kg  then s = s .. " [" .. kg  .. " KG]"  end
    if age then s = s .. " [Age " .. age .. "]" end
    return s
end

