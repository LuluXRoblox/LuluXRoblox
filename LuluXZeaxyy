local function saveNamedConfig(configType, name, uuids)
    if name == "" then return false, "Name cannot be empty" end
    if type(writefile) ~= "function" then return false, "writefile not available" end
    local ok, err = pcall(function()
        writefile(typeToFolder(configType) .. name .. ".json", HttpService:JSONEncode(uuids))
    end)
    return ok, (err or "")
end

local function deleteNamedConfig(configType, name)
