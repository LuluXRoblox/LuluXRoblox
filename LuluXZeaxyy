local function aeIsMyEgg(v)
    if not v then return false end; v = tostring(v)
    return v == LP.Name or v == tostring(LP.UserId)
end

pcall(function()
    local DataStreamRemote = ReplicatedStorage:WaitForChild("GameEvents",10):WaitForChild("DataStream",10)
    if not DataStreamRemote then return end
    DataStreamRemote.OnClientEvent:Connect(function(...)
        local args = {...}
        if args[1] ~= "UpdateData" then return end
        local updates = args[3]
        if type(updates) ~= "table" then return end
        for _, data in ipairs(updates) do
            if type(data) ~= "table" then continue end
            local path    = tostring(data[1] or "")
            local value   = data[2]

            local rawUUID = path:match("SavedObjects/(%b{})") or path:match("SavedObjects/([%w%-]+)")
            if rawUUID then
                local uuid  = aeNormUUID(rawUUID)
                local field = path:match("/Data/(.+)")
                if field then
                    if not HatchMonitor[uuid] then HatchMonitor[uuid] = {} end
                    local e = HatchMonitor[uuid]
                    if field == "RandomPetData" and type(value) == "table" then
                        e.petName = value["Name"]
                        local gpd = value["GeneratedPetData"]
                        if type(gpd) == "table" then
                            e.hugeChance = gpd["HugeChance"]
                            local wr = gpd["WeightRange"]
                            if type(wr) == "table" then e.weightMin = wr[1]; e.weightMax = wr[2] end
                        end
                    elseif field == "BaseWeight" then
                        e.baseWeight = tonumber(value) or 0
                    elseif field == "TimeToHatch" then
                        e.timeToHatch = value
                    elseif field == "CanHatch" then
                        e.canHatch = value
                    end
                end
            end

            if boost.Running then
                local rawBoostUUID = path:match("PetInventory/Data/{([^}]+)}")
                                  or path:match("PetInventory/Data/([%w%-]+)")
                if rawBoostUUID and path:match("/PetData/Boosts$") and type(value) == "table" then
                    local normUUID   = aeNormUUID(rawBoostUUID)
                    local isSelected = false
                    for _, u in ipairs(boost.UUIDs) do
                        if aeNormUUID(u) == normUUID then isSelected = true; break end
                    end
                    if isSelected then
                        local mon = boost.Monitors[normUUID]
                        if not mon then
                            mon = { small = nil, medium = nil }
                            boost.Monitors[normUUID] = mon
                        end

                        local prevSmall  = mon.small
                        local prevMedium = mon.medium
                        local sm, md = nil, nil
                        for _, entry in ipairs(value) do
                            if type(entry) ~= "table" then continue end
                            local t   = tonumber(entry.Time) or 0
                            local amt = entry.BoostAmount
                            if amt == 0.1 and t > 0 then sm = t end
                            if amt == 0.2 and t > 0 then md = t end
                        end
                        mon.small  = sm
                        mon.medium = md

                        local useSmall  = (boost.ToyMode == "Small"  or boost.ToyMode == "Both")
                        local useMedium = (boost.ToyMode == "Medium" or boost.ToyMode == "Both")

                        local valueEmpty    = (#value == 0)
                        local smallExpired  = useSmall  and (prevSmall  ~= nil and sm  == nil or (valueEmpty and sm  == nil))
                        local mediumExpired = useMedium and (prevMedium ~= nil and md  == nil or (valueEmpty and md  == nil))

                        if (smallExpired or mediumExpired) and boost.ActiveBoosts[normUUID] ~= false then
                            boost.ActiveBoosts[normUUID] = false
                            local originalUUID = nil
                            for _, u in ipairs(boost.UUIDs) do
                                if aeNormUUID(u) == normUUID then originalUUID = u; break end
                            end
                            if originalUUID then
                                task.spawn(function()
                                    if not boost.Running then return end
                                    pcall(function() applyBoostDirect(originalUUID) end)
                                end)
                            end
                        end
                    end
                end
            end
        end
    end)
end)

