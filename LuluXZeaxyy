PnP.CDConn = PetCooldownsUpdated.OnClientEvent:Connect(function(uuid, data)
    uuid = uuid or "unknown"
    local foundJumbo = false

    for _, skill in ipairs(data) do
        if skill.Passive == "Jumbo Blessing" then
            local prev = Jmb.Blessings[uuid] and Jmb.Blessings[uuid].time
            local cur  = tonumber(skill.Time) or 0
            if prev ~= nil and cur > prev then Jmb.FiredPerHelper[uuid] = true end
            if not Jmb.LabelSet[uuid] then Jmb.LabelSet[uuid]=true; table.insert(Jmb.LabelOrder,uuid) end
            Jmb.Blessings[uuid]={time=cur}; Jmb.LastSeen[uuid]=tick(); foundJumbo=true
        end
    end

    local function handlePnP(uuidMap, getPrevCD, setPrevCD)
        if not PnP.Running or not uuidMap[uuid] or PnP.ClearLoading then
            return
        end
        local firstSkill = data and data[1]; if not firstSkill then return end
        local cd = tonumber(firstSkill.Time) or 0
        local prevCD = getPrevCD()
        setPrevCD(cd)
        PnP.Status[uuid]={skill=firstSkill.Passive,cd=cd}; PnP.LastSeen[uuid]=tick()
        if not PnP.LabelSet[uuid] then PnP.LabelSet[uuid]=true; table.insert(PnP.LabelOrder,uuid) end
        local shouldFire = false
        if uuidMap == PnP.OnSkillUUIDs    then shouldFire = (cd == 0) end
        if uuidMap == PnP.AfterSkillUUIDs then shouldFire = ((prevCD or 0)==0 and cd>0) end
        if shouldFire and not PnP.Processing[uuid] then
            if PnP.Sync and (KG.Status[uuid]=="progres" or KG.ActivePhases[uuid]~=nil or LV.Status[uuid]=="progres") then return end
            PnP.Processing[uuid] = true
            task.spawn(function()
                local function cleanup() PnP.Processing[uuid]=nil end
                local budget=10
                if PnP.Sync then while PnP.SyncPaused and budget>0 do task.wait(0.5);budget=budget-0.5 end end
                if not PnP.Running then cleanup(); return end
                local ok, frame = pcall(function() return getPetDisplay():FindFirstChild(uuid) end)
                if not ok or not frame then cleanup(); return end
                task.wait(PnP.DelayPick)
                if not PnP.Running or not uuidMap[uuid] then cleanup(); return end
                if PnP.Sync then while PnP.SyncPaused and budget>0 do task.wait(0.5);budget=budget-0.5 end end
                if not PnP.Running or not uuidMap[uuid] then cleanup(); return end
                pcall(function() unequipPet(uuid) end); task.wait(PnP.DelayPlace)
                if not PnP.ClearLoading then
                    pcall(function()
                        equipPet(uuid)
                    end)
                end
                
                cleanup()
            end)
        end
    end

    handlePnP(PnP.OnSkillUUIDs,
        function() return PnP.PrevCD_On[uuid] end,
        function(v) PnP.PrevCD_On[uuid]=v end)

    handlePnP(PnP.AfterSkillUUIDs,
        function() return PnP.PrevCD[uuid] end,
        function(v) PnP.PrevCD[uuid]=v end)

    if not foundJumbo then
        if Jmb.Blessings[uuid] then
            for i, u in ipairs(Jmb.LabelOrder) do if u==uuid then table.remove(Jmb.LabelOrder,i);break end end
        end
        Jmb.Blessings[uuid]=nil; Jmb.FiredPerHelper[uuid]=nil; Jmb.LabelSet[uuid]=nil
    end
end)

