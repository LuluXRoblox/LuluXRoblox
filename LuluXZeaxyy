            end
            local placed = aeCountMyEggs()
            if placed < AutoEgg.MaxPlace and #AutoEgg.ChosenEggs > 0 then
                task.wait(1)
                aePlantBatch(AutoEgg.MaxPlace - placed)
            end

            local waitStart4   = tick()
            local zeroStreak   = 0       
            local ZERO_CONFIRM = 3      
            while AutoEgg.Running do
                local curPlaced = aeCountMyEggs()
                local readyNow  = aeGetReadyEggObjects()
                if curPlaced > 0 and #readyNow >= curPlaced then break end
                if curPlaced == 0 then
                    zeroStreak += 1
                    if zeroStreak >= ZERO_CONFIRM then break end 
                else
                    zeroStreak = 0 
                end
                if tick() - waitStart4 > 300 then break end 
                task.wait(2)
            end
            if not AutoEgg.Running then break end

            unequipAllActive(); task.wait(0.5)

            local readyList = aeGetReadyEggObjects()
            if #readyList == 0 then task.wait(2); continue end

            AEStats.hatchTotal = AEStats.hatchTotal + #readyList

            local normalEggs, goodEggs = {}, {}
            for _, entry in ipairs(readyList) do
                local baseWt     = (entry.mon and entry.mon.baseWeight) or 0
                local isUnknown  = entry.noData or (baseWt == 0)
                local petName    = (entry.mon and entry.mon.petName) or ""
                local inGoodList = false
                for _, gn in ipairs(AutoEgg.GoodHatchPets) do
                    if petName ~= "" and petName:lower():find(gn:lower(), 1, true) then
                        inGoodList = true; break
                    end
                end
                local isGood = inGoodList or isUnknown or ((AutoEgg.MinGoodHatch > 0) and (baseWt >= AutoEgg.MinGoodHatch))
                if isGood then table.insert(goodEggs, entry)
                else            table.insert(normalEggs, entry) end
            end

            AEStats.goodHatch = AEStats.goodHatch + #goodEggs

            local snapshotUUIDs = {}
            for _, item in ipairs(LP.Backpack:GetChildren()) do
                snapshotUUIDs[item:GetAttribute("PET_UUID") or item.Name] = true
            end

            if #normalEggs > 0 then
                if #AutoEgg.HatchEggUUIDs > 0 then
                    safeEquipLoad(AutoEgg.HatchEggUUIDs)
                end
                AutoEgg.LastLoadWasGoodHatch = false
                task.wait(1.5) 
                for _, entry in ipairs(normalEggs) do
                    if not AutoEgg.Running then break end
                    aeHatchEgg(entry.obj); task.wait(0.1)
                    HatchMonitor[entry.uuid] = nil
                end
                unequipAllActive(); task.wait(0.5)
            end

            if #goodEggs > 0 then
                if not AutoEgg.LastLoadWasGoodHatch and #AutoEgg.GoodHatchUUIDs > 0 then
                    safeEquipLoad(AutoEgg.GoodHatchUUIDs)
                    AutoEgg.LastLoadWasGoodHatch = true
                end
                task.wait(1.5)
                local preGoodSnap = {}
                for _, item in ipairs(LP.Backpack:GetChildren()) do
                    preGoodSnap[item:GetAttribute("PET_UUID") or item.Name] = true
                end
                for _, entry in ipairs(goodEggs) do
                    if not AutoEgg.Running then break end
                    aeHatchEgg(entry.obj); task.wait(0.1)
                    HatchMonitor[entry.uuid] = nil
                end
                unequipAllActive(); task.wait(1)
                AutoEgg.LastLoadWasGoodHatch = false
                if Webhook.AE then
                    task.spawn(function()
                        task.wait(1)
                        local helperSet = {}
                        for _, u in ipairs(AutoEgg.GoodHatchUUIDs) do helperSet[u] = true end
                        for _, item in ipairs(LP.Backpack:GetChildren()) do
                            local uuid = item:GetAttribute("PET_UUID") or item.Name
                            if preGoodSnap[uuid]  then continue end   -- sudah ada sebelumnya
                            if helperSet[uuid]    then continue end   -- skip helper pet
                            if item:GetAttribute("PetType") ~= "Pet" then continue end
                            local petName = item:GetAttribute("f") or ""
                            local parsed  = parseName(item.Name)
                            local kg      = tonumber(parsed.kg) or 0
                            if AutoEgg.MinGoodHatch > 0 and kg < AutoEgg.MinGoodHatch then continue end
                            sendWebhookEmbed({
                                title       = "Good Hatch",
                                description = "**You get " .. petName .. "**\nCurrent: " .. kg .. " KG",
                                color       = 0x57F287,
                                footer      = { text = "LuluXGAG " .. SCRIPT_VERSION },
                                timestamp   = os.date("!%Y-%m-%dT%H:%M:%S"),
                            })
                            task.wait(0.3)
                        end
                    end)
                end
            end

            if #AutoEgg.SellingUUIDs > 0 and #AutoEgg.SellPets > 0 then
                local ch  = LP.Character
                local hum = ch and ch:FindFirstChildOfClass("Humanoid")
                if hum then hum:UnequipTools(); task.wait(0.3) end 

                local newPets = {}
                for _, item in ipairs(LP.Backpack:GetChildren()) do
                    if item:GetAttribute("PetType") ~= "Pet" then continue end
                    local uuid = item:GetAttribute("PET_UUID") or item.Name
                    if snapshotUUIDs[uuid] then continue end
                    local parsed  = parseName(item.Name)
                    local petName = item:GetAttribute("f") or ""
                    local kg      = tonumber(parsed.kg) or 0
                    table.insert(newPets, { item = item, uuid = uuid, name = petName, kg = kg })
                end

                local toSell = {}
                for _, pet in ipairs(newPets) do
                    if not pet.item or not pet.item.Parent then continue end
                    local inList = false
                    for _, sn in ipairs(AutoEgg.SellPets) do
                        if pet.name:find(sn, 1, true) then inList = true; break end
                    end
                    if not inList then continue end
                    if AutoEgg.MinGoodHatch > 0 and pet.kg >= AutoEgg.MinGoodHatch then continue end
                    table.insert(toSell, pet)
                end
                if #toSell > 0 then
                    task.wait(1)
                    safeEquipLoad(AutoEgg.SellingUUIDs); task.wait(0.5)
                    local ch  = LP.Character
                    local hum = ch and ch:FindFirstChildOfClass("Humanoid")
                    if ch and hum then
                        for _, pet in ipairs(toSell) do
                            if not AutoEgg.Running then break end
                            if not pet.item or not pet.item.Parent then continue end
                            pcall(function()
                                hum:EquipTool(pet.item)
                                task.wait(0.2)
                                local equipped = nil
                                for _, obj in ipairs(ch:GetChildren()) do
                                    if obj:IsA("Tool") then
                                        local u = obj:GetAttribute("PET_UUID") or obj.Name
                                        if u == pet.uuid or obj == pet.item then
                                            equipped = obj; break
                                        end
                                    end
                                end
                                if equipped then
                                    ReplicatedStorage.GameEvents.SellPet_RE:FireServer(equipped)
                                    task.wait(0.2)
                                else
                                    hum:UnequipTools(); task.wait(0.2)
                                end
                            end)
                        end
                    end
                    unequipAllActive(); task.wait(0.5)
                end
            end

            task.wait(1)
        end
    end)
end

local function stopAutoEgg()
    AutoEgg.Running = false
    if AutoEgg.Thread then pcall(function() task.cancel(AutoEgg.Thread) end); AutoEgg.Thread = nil end
    AEStats.eggReturn  = 0
    AEStats.goodHatch  = 0
    AEStats.sellReturn = 0
    saveSettings()
end

