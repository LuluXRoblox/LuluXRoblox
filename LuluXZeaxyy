local function fixPnPOverflow()
    task.spawn(function()
        task.wait(0.5)
        local activeList = getActivePets()
        local activeSet  = {}
        for _, p in ipairs(activeList) do activeSet[aeNormUUID(p.uuid)] = p.uuid end

        local expectedSet = {}

        if KG.Running then
            if KG.UpkgSlot then expectedSet[aeNormUUID(KG.UpkgSlot.uuid)] = true end
            local phase = KG.UpkgSlot and "upkg" or nil
            if not phase then
                for uuid, ph in pairs(KG.ActivePhases) do
                    if ph == "lv1" or ph == "lv2" then
                        expectedSet[aeNormUUID(uuid)] = true
                        phase = ph
                    end
                end
            end
            local loadout = phase == "upkg" and KG.UpKG
                         or phase == "lv2"  and KG.Lv2
                         or KG.Lv1
            if loadout then
                for _, uuid in ipairs(loadout) do expectedSet[aeNormUUID(uuid)] = true end
            end
        end

        if LV.Running then
            for uuid, st in pairs(LV.Status) do
                if st == "progres" then expectedSet[aeNormUUID(uuid)] = true end
            end
            for _, uuid in ipairs(LV.Lv1) do expectedSet[aeNormUUID(uuid)] = true end
            for _, uuid in ipairs(LV.Lv2) do expectedSet[aeNormUUID(uuid)] = true end
        end

        local leaked = {}
        for normUUID, rawUUID in pairs(activeSet) do
            if not expectedSet[normUUID] then table.insert(leaked, rawUUID) end
        end

        local i = 1
        while i <= #leaked do
            pcall(function() unequipPet(leaked[i]) end); task.wait(0.3)
            local freshNorm = {}
            pcall(function()
                for _, p in ipairs(getActivePets()) do freshNorm[aeNormUUID(p.uuid)] = true end
            end)
            for normUUID in pairs(expectedSet) do
                if not freshNorm[normUUID] then
                    local origUUID = nil
                    for _, u in ipairs(KG.Lv1)  do if aeNormUUID(u)==normUUID then origUUID=u; break end end
                    if not origUUID then for _, u in ipairs(KG.Lv2)  do if aeNormUUID(u)==normUUID then origUUID=u; break end end end
                    if not origUUID then for _, u in ipairs(KG.UpKG) do if aeNormUUID(u)==normUUID then origUUID=u; break end end end
                    if not origUUID then for _, u in ipairs(LV.Lv1)  do if aeNormUUID(u)==normUUID then origUUID=u; break end end end
                    if not origUUID then for _, u in ipairs(LV.Lv2)  do if aeNormUUID(u)==normUUID then origUUID=u; break end end end
                    if not origUUID and KG.UpkgSlot and aeNormUUID(KG.UpkgSlot.uuid)==normUUID then origUUID=KG.UpkgSlot.uuid end
                    if origUUID then pcall(function() equipPet(origUUID) end); task.wait(0.3) end
                    break
                end
            end
            i = i + 1
        end
        local finalNorm = {}
        pcall(function()
            for _, p in ipairs(getActivePets()) do finalNorm[aeNormUUID(p.uuid)] = true end
        end)
        for normUUID in pairs(expectedSet) do
            if not finalNorm[normUUID] then
                local origUUID = nil
                for _, u in ipairs(KG.Lv1)  do if aeNormUUID(u)==normUUID then origUUID=u; break end end
                if not origUUID then for _, u in ipairs(KG.Lv2)  do if aeNormUUID(u)==normUUID then origUUID=u; break end end end
                if not origUUID then for _, u in ipairs(KG.UpKG) do if aeNormUUID(u)==normUUID then origUUID=u; break end end end
                if not origUUID then for _, u in ipairs(LV.Lv1)  do if aeNormUUID(u)==normUUID then origUUID=u; break end end end
                if not origUUID then for _, u in ipairs(LV.Lv2)  do if aeNormUUID(u)==normUUID then origUUID=u; break end end end
                if not origUUID and KG.UpkgSlot and aeNormUUID(KG.UpkgSlot.uuid)==normUUID then origUUID=KG.UpkgSlot.uuid end
                if origUUID then pcall(function() equipPet(origUUID) end); task.wait(0.3) end
            end
        end
    end)
end

