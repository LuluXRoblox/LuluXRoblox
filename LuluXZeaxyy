-- ============================================================
-- AUTO ATTACK WASP
-- ============================================================
local Wasp = {
    Running  = false,
    Thread   = nil,
    Delay    = 0.3,
    Queue    = {},
    DescConn = nil,
    HitWasp  = nil,
}

local function waspEquipShovel()
    local char = LP.Character; if not char then return false end
    local hum  = char:FindFirstChildOfClass("Humanoid"); if not hum then return false end
    local bp   = LP:WaitForChild("Backpack", 5); if not bp then return false end
    local tool = bp:FindFirstChild("Shovel [Destroy Plants]")
    if not tool then return false end
    pcall(function() hum:EquipTool(tool) end)
    task.wait(0.3)
    local shovel = char:FindFirstChild("Shovel [Destroy Plants]")
    local hitWasp = shovel and shovel:FindFirstChild("HitWasp")
    if not hitWasp then return false end
    Wasp.HitWasp = hitWasp
    return true
end

local function waspIsExcluded(obj)
    local cur = obj
    while cur do
        if cur == workspace:FindFirstChild("Interaction") then return true end
        cur = cur.Parent
    end
    return false
end

local function waspAdd(obj)
    local id   = obj:GetAttribute("BeeIdentifier")
    local name = obj:GetAttribute("BeeName")
    if not id then return end
    if not name or not name:find("Wasp") then return end
    if waspIsExcluded(obj) then return end
    for _, w in ipairs(Wasp.Queue) do if w.id == id then return end end
    table.insert(Wasp.Queue, {name=name, id=id, obj=obj})
    table.sort(Wasp.Queue, function(a,b) return a.id < b.id end)
end

local function waspScan()
    Wasp.Queue = {}
    for _, v in ipairs(workspace:GetDescendants()) do waspAdd(v) end
end

local function startWasp()
    if Wasp.Running then return end
    local ok = waspEquipShovel()
    if not ok then win:luluNotify("Shovel Not Found,Unequip For You Hand!", "warning"); return end
    Wasp.Running = true
    waspScan()
    if Wasp.DescConn then pcall(function() Wasp.DescConn:Disconnect() end) end
    Wasp.DescConn = workspace.DescendantAdded:Connect(function(v)
        task.wait()
        if not Wasp.Running then return end
        local name = v:GetAttribute("BeeName")
        if not name or not name:find("Wasp") then return end
        waspAdd(v)
    end)
    Wasp.Thread = task.spawn(function()
        while Wasp.Running do
            if #Wasp.Queue > 0 then
                local wasp = table.remove(Wasp.Queue, 1)
                if wasp.obj and wasp.obj.Parent then
                    while Wasp.Running and wasp.obj and wasp.obj.Parent do
                        pcall(function() Wasp.HitWasp:FireServer(wasp.id) end)
                        task.wait(Wasp.Delay)
                    end
                    task.wait(0.3)
                end
            else
                task.wait(0.1)
            end
        end
    end)
end

local function stopWasp()
    Wasp.Running = false
    if Wasp.DescConn then pcall(function() Wasp.DescConn:Disconnect() end); Wasp.DescConn=nil end
    if Wasp.Thread   then task.cancel(Wasp.Thread); Wasp.Thread=nil end
    Wasp.Queue   = {}
    Wasp.HitWasp = nil
end

