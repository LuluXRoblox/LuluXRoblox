local function sendWebhook(content)
    if Webhook.Url == "" then return end
    pcall(function()
        local body = HttpService:JSONEncode({ content = content })
        local reqFn = (syn and syn.request) or (http and http.request) or request
        if reqFn then
            reqFn({ Url = Webhook.Url, Method = "POST",
                    Headers = { ["Content-Type"] = "application/json" }, Body = body })
        end
    end)
end

local function sendWebhookEmbed(embedData)
    if Webhook.Url == "" then return end
    pcall(function()
        local payload = {
            username   = "LuluXGAG",
            avatar_url = "https://i.imgur.com/mwf869e.jpeg",
            embeds     = { embedData },
        }
        local body  = HttpService:JSONEncode(payload)
        local reqFn = (syn and syn.request) or (http and http.request) or request
        if not reqFn then return end
        reqFn({ Url = Webhook.Url, Method = "POST",
                Headers = { ["Content-Type"] = "application/json" }, Body = body })
    end)
end

local function notifyPetKGUpdate(petName, prevKG, newKG)
    if not Webhook.KG then return end
    if newKG <= prevKG then return end
    local desc = "**" .. (petName or "Unknown") .. "**\n"
               .. string.format("%.2f KG", prevKG) .. "  →  **" .. string.format("%.2f KG", newKG) .. "**"
    if KG.TargetBase > 0 then
        local pct = math.min(newKG / KG.TargetBase * 100, 100)
        desc = desc .. string.format("\nTarget: `%.2f KG` (%.1f%%)", KG.TargetBase, pct)
    end
    sendWebhookEmbed({
        title = "BASE KG Updated", description = desc, color = 0x3498DB,
        footer = { text = "LuluXGAG " .. SCRIPT_VERSION },
        timestamp = os.date("!%Y-%m-%dT%H:%M:%S"),
    })
end

local function notifyPetKGDone(petName, finalKG, fase)
    if not Webhook.KG then return end
    local doneCount = 0
    for _ in pairs(KG.DoneUUIDs) do doneCount = doneCount + 1 end
    local kgStr = finalKG and string.format("%.2f KG", finalKG) or "?"
    local desc  = "**[" .. (petName or "Unknown") .. "]**\nCurrent: `" .. kgStr .. "`"
    if KG.TargetBase > 0 then desc = desc .. "\nTarget: `" .. string.format("%.2f KG", KG.TargetBase) .. "`" end
    if fase and fase > 0  then desc = desc .. "\ndone in: `" .. fase .. " fase`" end
    sendWebhookEmbed({
        title = "Upgrade Base KG Done", description = desc, color = 0x57F287,
        footer = { text = "Done: " .. doneCount .. "|" .. #KG.Targets .. " pets | LuluXGAG " .. SCRIPT_VERSION },
        timestamp = os.date("!%Y-%m-%dT%H:%M:%S"),
    })
end

