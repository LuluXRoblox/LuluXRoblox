                    if entry.mon.readyNotified or entry.mon.canHatch then
                        readyCount = readyCount + 1
                    end
                end
                grp.EggInfo:QuestLine("Ready", readyCount .. " / " .. #eggList)

                for _, entry in ipairs(eggList) do
                    local mon     = entry.mon
                    local isReady = mon.readyNotified or mon.canHatch
                    if isReady then
                        local kg     = mon.baseWeight or 0
                        local catStr = getWeightCategory(kg)
                        local wt     = kg > 0
                            and string.format("%.2fkg(%s)", kg, catStr)
                            or  "? kg"
                        grp.EggInfo:QuestLine(mon.petName or "Pet", wt)
                    else
                        local eggName = mon.eggName or "Egg"
                        local timeStr = fmtTimeToHatch(mon.timeToHatch)
                        grp.EggInfo:QuestLine(eggName, timeStr)
                    end
                end
            else
                grp.EggInfo:Hide()
            end

            if AutoEgg.Running and State.ShowAEStats then
                grp.AEStats:Show()
                grp.AEStats:Clear()
                grp.AEStats:Header("Egg Stats")
                grp.AEStats:QuestLine("Current Egg",  tostring(aeCountMyEggs()) .. " / " .. AutoEgg.MaxPlace)
                grp.AEStats:QuestLine("Egg Return",   tostring(AEStats.eggReturn))
                grp.AEStats:QuestLine("Good Hatch",   tostring(AEStats.goodHatch))
                grp.AEStats:QuestLine("Sell Return",  tostring(AEStats.sellReturn))
                grp.AEStats:QuestLine("Hatch Total",  tostring(AEStats.hatchTotal))
            else
                grp.AEStats:Hide()
            end

            local activePets = getActivePets()
            local activeMap  = {}
            for _, ap in ipairs(activePets) do
                activeMap[ap.uuid] = ap
                if ap.type and ap.type ~= "" then State.UUIDToType[ap.uuid] = ap.type end
            end

            local targets, statusMap
            if     KG.Running  then targets=KG.Targets; statusMap=KG.Status
            elseif LV.Running  then targets=LV.Targets; statusMap=LV.Status
            elseif KG.AllDone  then targets=KG.Targets; statusMap=KG.Status
            elseif LV.AllDone  then targets=LV.Targets; statusMap=LV.Status
            else                    targets={};          statusMap={} end

            local cntProgres, cntWaiting, cntDone = 0, 0, 0
            for _, dn in ipairs(targets) do
                local p = petOf(dn); if not p then continue end
                local st = statusMap[p.uuid] or "waiting"
                if st=="progres" or st=="waiting_kg" then cntProgres=cntProgres+1
                elseif st=="waiting"                 then cntWaiting=cntWaiting+1
                else                                      cntDone=cntDone+1 end
            end

            local modeName
            if     KG.Running  then modeName = "Auto KG" .. (KG.Bridge and " → LV" or "")
            elseif LV.Running  then modeName = "Auto Leveling"
            elseif KG.AllDone  then modeName = "KG Done"
            elseif LV.AllDone  then modeName = "LV Done" end

            local jumboCount, pnpCount = 0, 0
            for _, uuid in ipairs(Jmb.LabelOrder) do
                if Jmb.LastSeen[uuid] and (now-Jmb.LastSeen[uuid]) < AUTOHIDE_TIMEOUT then jumboCount=jumboCount+1 end
            end
            for _, uuid in ipairs(PnP.LabelOrder) do
                if PnP.LastSeen[uuid] and (now-PnP.LastSeen[uuid]) < AUTOHIDE_TIMEOUT then pnpCount=pnpCount+1 end
            end

            if not State.DetailInfo then
                if State.ShowProgress and modeName and #targets > 0 then
                    grp.OnProgress:Show(); grp.OnProgress:Clear()
                    grp.OnProgress:Header("On Progress")
                    grp.OnProgress:QuestLine("Mode",    modeName)
                    grp.OnProgress:QuestLine("Progress", tostring(cntProgres))
                    grp.OnProgress:QuestLine("Waiting",  tostring(cntWaiting))
                    grp.OnProgress:QuestLine("Done",     tostring(cntDone))
                else grp.OnProgress:Hide() end

                if State.ShowBlessing and jumboCount > 0 then
                    grp.Jumbo:Show(); grp.Jumbo:Clear()
                    grp.Jumbo:Header("Jumbo Panel")
                    grp.Jumbo:QuestLine("Pets", tostring(jumboCount))
                else grp.Jumbo:Hide() end

                if State.ShowPnp and PnP.Running and pnpCount > 0 then
                    grp.Pnp:Show(); grp.Pnp:Clear()
                    grp.Pnp:Header("PnP Panel")
                    grp.Pnp:QuestLine("Pets", tostring(pnpCount))
                else grp.Pnp:Hide() end

                grp.AllProgress:Hide(); return
            end

            local progresItems = {}
            for _, dn in ipairs(targets) do
                local p = petOf(dn); if not p then continue end
                if (statusMap[p.uuid] or "waiting") == "progres" then table.insert(progresItems, p) end
            end

            if State.ShowProgress and #progresItems > 0 then
                grp.OnProgress:Show(); grp.OnProgress:Clear()
                grp.OnProgress:Header("On Progress")
                for _, p in ipairs(progresItems) do
                    local ap      = activeMap[p.uuid]
                    local phase   = KG.ActivePhases[p.uuid]
                    local petType = State.UUIDToType[p.uuid] or ""
                    local name    = petType ~= "" and petType or p.name
                    local age     = ap and tostring(ap.age)
                                 or (phase=="upkg" and tostring(KG.LastKnownAge[p.uuid] or 50))
                                 or tostring(getAge(p.uuid))
                    local baseStr
                    if KG.Running then
                        baseStr = KG.CurrentKG[p.uuid] and (string.format("%.2f",KG.CurrentKG[p.uuid]).." KG") or "-"
                    else
                        baseStr = age .. " Age"
                    end
                    grp.OnProgress:QuestLine("Name", name)
                    grp.OnProgress:QuestLine("Age",  age)
                    grp.OnProgress:QuestLine("Base", baseStr)
                end
            else grp.OnProgress:Hide() end

            if State.ShowBlessing and jumboCount > 0 then
                grp.Jumbo:Show(); grp.Jumbo:Clear()
                grp.Jumbo:Header("Jumbo Panel")
                for _, uuid in ipairs(Jmb.LabelOrder) do
                    local jb = Jmb.Blessings[uuid]
                    if not jb then continue end
                    if not Jmb.LastSeen[uuid] or (now-Jmb.LastSeen[uuid])>=AUTOHIDE_TIMEOUT then continue end
                    local petType = State.UUIDToType[uuid] or ""
                    local label   = petType ~= "" and petType or uuid:sub(1,8)
                    local cdStr   = jb.time==0 and "ready" or (tostring(jb.time)..(Jmb.FiredPerHelper[uuid] and " ✓" or ""))
                    grp.Jumbo:QuestLine(label, cdStr)
                end
            else grp.Jumbo:Hide() end

            if boost.Running and State.ShowBoost then
                local selectedUUIDs = getBoostSelectedUUIDs()
                local dispSm, dispMd = nil, nil
                local hasAnyMonitor = false
                for _, uuid in ipairs(selectedUUIDs) do
                    local mon = boost.Monitors[aeNormUUID(uuid)]
                    if mon then
                        hasAnyMonitor = true
                        if mon.small  ~= nil then dispSm = (dispSm == nil) and mon.small  or math.min(dispSm,  mon.small)  end
                        if mon.medium ~= nil then dispMd = (dispMd == nil) and mon.medium or math.min(dispMd, mon.medium) end
                    end
                end
                if hasAnyMonitor then
                    grp.Boost:Show(); grp.Boost:Clear()
                    grp.Boost:Header("Boost Monitor")
                    grp.Boost:QuestLine("Small",  dispSm ~= nil and tostring(dispSm)  or "-")
                    grp.Boost:QuestLine("Medium", dispMd ~= nil and tostring(dispMd) or "-")
                else grp.Boost:Hide() end
            else grp.Boost:Hide() end
            local hasActivePnp = false
            for _, uuid in ipairs(PnP.LabelOrder) do
                if PnP.LastSeen[uuid] and (now-PnP.LastSeen[uuid]) < AUTOHIDE_TIMEOUT then hasActivePnp=true;break end
            end
            if State.ShowPnp and PnP.Running and hasActivePnp then
                grp.Pnp:Show(); grp.Pnp:Clear()
                grp.Pnp:Header("PnP Panel")
                for _, uuid in ipairs(PnP.LabelOrder) do
                    local entry = PnP.Status[uuid]; if not entry then continue end
                    if not PnP.LastSeen[uuid] or (now-PnP.LastSeen[uuid])>=AUTOHIDE_TIMEOUT then continue end
                    local petType = State.UUIDToType[uuid] or ""
                    local label   = petType ~= "" and petType or uuid:sub(1,8)
                    grp.Pnp:QuestLine(label, entry.cd==0 and "ready" or tostring(entry.cd))
                end
            else grp.Pnp:Hide() end

            local function sortOrder(st)
                if st=="progres" then return 1 elseif st=="waiting_kg" then return 2
                elseif st=="waiting" then return 3 else return 4 end
            end

            if State.ShowAllProg and #targets > 0 then
                local snapParts = {}
                for _, dn in ipairs(targets) do
                    local p=petOf(dn); if not p then continue end
                    local st=statusMap[p.uuid] or "waiting"
                    local extra=""
                    if st=="progres" and KG.Running then
                        local kg=KG.CurrentKG[p.uuid]
                        if kg then extra=string.format("%.1f",kg) end
                    end
                    snapParts[#snapParts+1]=p.uuid..st..extra
                end
                local snapshot = table.concat(snapParts,"|")

                if snapshot ~= State.AllProgLastStatus then
                    State.AllProgLastStatus = snapshot
                    grp.AllProgress:Show(); grp.AllProgress:Clear()
                    grp.AllProgress:Header("All Progress")

                    local sorted = {}
                    for _, dn in ipairs(targets) do
                        local p=petOf(dn); if not p then continue end
                        local st=statusMap[p.uuid] or "waiting"
                        table.insert(sorted,{p=p,st=st,order=sortOrder(st)})
                    end
                    table.sort(sorted, function(a,b) return a.order < b.order end)

                    for _, item in ipairs(sorted) do
                        local p=item.p; local st=item.st
                        local petType=State.UUIDToType[p.uuid] or ""
                        local label=petType~="" and petType or p.name
                        local valueStr
                        if st=="progres" then
                            if KG.Running then
                                local kg=KG.CurrentKG[p.uuid]
                                valueStr="on progress"..(kg and (" ["..string.format("%.2f",kg).." KG]") or "")
                            else
                                local ap=activeMap[p.uuid]; local age=ap and tostring(ap.age) or tostring(getAge(p.uuid))
                                valueStr="on progress [Age "..age.."]"
                            end
                        elseif st=="waiting_kg" then valueStr="waiting KG"
                        elseif st=="waiting"    then valueStr="waiting..."
                        else
                            if KG.Running or KG.AllDone then
                                local kg=KG.CurrentKG[p.uuid] or KG.LastKnown[p.uuid]
                                valueStr="Done ["..(kg and string.format("%.2f",kg) or "?").." KG]"
                            else
                                valueStr="Done [Age "..LV.TargetAge.."]"
                            end
                        end
                        grp.AllProgress:QuestLine(label, valueStr)
                    end
                end
            else
                grp.AllProgress:Hide()
                State.AllProgLastStatus = ""
            end
        end)
    end
end)

