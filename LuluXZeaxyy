                local tL = m:FindFirstChild("PET_TYPE")
                if petType ~= "" and tL and tL.Text == petType then
                    age = amReadAge(m); if age > 0 then return end
                end
                local nL = m:FindFirstChild("PET_NAME")
                if nL and nL.Text == baseAttr then age = amReadAge(m); if age > 0 then return end end
