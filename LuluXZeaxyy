local bpPets     = {}
local bpDisplays = {}
local bpDispMap  = {}

local function scanBPPets()
    bpPets = {}; bpDisplays = {}; bpDispMap = {}
    for _, item in ipairs(Backpack:GetChildren()) do
        local uuid = item:GetAttribute("PET_UUID")
        if not uuid then continue end
        local fullName = item.Name
        local display  = fullName:gsub("%s*%[Age %d+%]",""):match("^%s*(.-)%s*$")
        local baseName = item:GetAttribute("f") or
            display:gsub("%s*%[%d+%.?%d* KG%]",""):match("^%s*(.-)%s*$")
        local key = display; local n = 2
        while bpDispMap[key] do key = display.." ("..n..")"; n=n+1 end
        bpDispMap[key] = uuid
        table.insert(bpDisplays, key)
        table.insert(bpPets, {uuid=uuid, display=key, baseName=baseName})
    end
    boost.Displays = bpDisplays
    boost.DispMap  = bpDispMap
    boost.ScanMap  = bpDispMap 
    return #bpDisplays
end

local function getBPData() return bpPets, bpDisplays, bpDispMap end

local function rebuildPnPUUIDs()
